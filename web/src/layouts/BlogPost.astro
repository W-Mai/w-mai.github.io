---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<title>{title}</title>
	</head>
	<body>
		<!-- Reading progress bar -->
		<div id="progress-bar"
			class="fixed top-0 left-0 h-0.5 bg-slate-700 z-50 transition-all duration-100"
			style="width: 0%">
		</div>

		<Header />

		<main class="max-w-3xl mx-auto px-4 py-10">
			<!-- Back link -->
			<a href="/blog"
			   class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-700
			          transition-colors mb-8 no-underline group">
				<span class="group-hover:-translate-x-0.5 transition-transform">←</span>
				<span>返回文章列表</span>
			</a>

			<article>
				{heroImage && (
					<div class="rounded-3xl overflow-hidden shadow-md mb-8">
						<Image
							width={1020} height={510}
							src={heroImage}
							alt=""
							class="w-full object-cover rounded-none"
						/>
					</div>
				)}

				<!-- Article header -->
				<header class="mb-10">
					<div class="flex items-center gap-2 text-sm text-slate-400 mb-4">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<>
								<span>·</span>
								<span class="italic">updated <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
					<h1 class="text-3xl md:text-4xl font-bold text-slate-800 leading-tight m-0 mb-3">
						{title}
					</h1>
					{description && (
						<p class="text-lg text-slate-500 leading-relaxed m-0">{description}</p>
					)}
					<hr class="mt-6 border-slate-200" />
				</header>

				<!-- Article body -->
				<div class="prose prose-slate prose-lg max-w-none
				            prose-headings:font-bold prose-headings:text-slate-800
				            prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
				            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
				            prose-p:text-slate-600 prose-p:leading-relaxed
				            prose-a:text-slate-700 prose-a:underline prose-a:underline-offset-2
				            hover:prose-a:text-slate-900
				            prose-strong:text-slate-800
				            prose-code:text-slate-700 prose-code:bg-slate-100
				            prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
				            prose-pre:bg-slate-900 prose-pre:rounded-2xl prose-pre:shadow-md
				            prose-blockquote:border-slate-300 prose-blockquote:text-slate-500
				            prose-img:rounded-2xl prose-img:shadow-md
				            prose-hr:border-slate-200
				            prose-li:text-slate-600">
					<slot />
				</div>
			</article>

			<!-- Bottom back link -->
			<div class="mt-16 pt-8 border-t border-slate-200">
				<a href="/blog"
				   class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-700
				          transition-colors no-underline group">
					<span class="group-hover:-translate-x-0.5 transition-transform">←</span>
					<span>返回文章列表</span>
				</a>
			</div>
		</main>

		<Footer />

		<script>
			// Hide chrome when embedded in an iframe (e.g. live editor preview)
			if (window !== window.parent) {
				const style = document.createElement('style');
				style.textContent = `
					body > header, body > footer,
					#progress-bar { display: none !important; }
					main > a[href="/blog"] { display: none !important; }
					main > div:last-child { display: none !important; }
					main { padding-top: 1rem !important; }
				`;
				document.head.appendChild(style);
			}

			// Update reading progress bar on scroll
			const bar = document.getElementById('progress-bar');
			function updateProgress() {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
				if (bar) bar.style.width = pct + '%';
			}
			window.addEventListener('scroll', updateProgress, { passive: true });
			updateProgress();
		</script>
	</body>
</html>
