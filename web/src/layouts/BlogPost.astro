---
import { Image, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '~/components/layout/BaseHead.astro';
import BlogHeroFallback from '~/components/blog/BlogHeroFallback.astro';
import BusuanziCounter from '~/components/shared/BusuanziCounter.astro';
import Footer from '~/components/layout/Footer.astro';
import FormattedDate from '~/components/shared/FormattedDate.astro';
import Giscus from '~/components/shared/Giscus.astro';
import Header from '~/components/layout/Header.astro';
import SeriesNav from '~/components/blog/SeriesNav.astro';
import ShareCard from '~/components/shared/ShareCard';
import Sidebar from '~/components/layout/Sidebar.astro';
import TagChip from '~/components/blog/TagChip.astro';
import type { SeriesData } from '~/lib/blog/series';
import { AVATAR_URL, NICK_NAME, SITE_URL } from '~/consts';

type Props = CollectionEntry<'blog'>['data'] & {
	bodyHeroImage?: ImageMetadata | null;
	readingTime?: string;
	wordCount?: number;
	seriesData?: SeriesData | null;
	postId?: string;
};

const { title, description, pubDate, updatedDate, heroImage, bodyHeroImage, readingTime, wordCount, tags = [], category, seriesData, postId } = Astro.props;

const isEditorMode = import.meta.env.DEV && import.meta.env.EDITOR_MODE;
const ogImageUrl = `/og/posts/${postId}.png`;
const pageFullUrl = `${import.meta.env.SITE ?? 'https://benign.host'}/blog/${postId}/`;
const avatarImg = await getImage({ src: AVATAR_URL, width: 64, height: 64 });

// Pre-render sidebar slot if provided by the page
const hasSidebar = Astro.slots.has('sidebar');
let sidebarHtml = '';
if (hasSidebar) {
	sidebarHtml = await Astro.slots.render('sidebar', []);
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": `${SITE_URL}/og/posts/${postId}.png`,
			"datePublished": pubDate.toISOString(),
			...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
			"author": { "@type": "Person", "name": NICK_NAME, "url": `${SITE_URL}/about` },
			"publisher": { "@type": "Person", "name": NICK_NAME },
			"mainEntityOfPage": { "@type": "WebPage", "@id": `${SITE_URL}/blog/${postId}/` },
			...(tags.length > 0 ? { "keywords": tags.join(', ') } : {}),
		})} />
		<script is:inline>
			// Embed mode: hide chrome and restore scroll position
			if (new URLSearchParams(window.location.search).has('embed')) {
				document.documentElement.dataset.embed = '';

				// Block Vite HMR full-reload inside embed iframe;
				// the parent editor controls refresh explicitly.
				var OrigWS = window.WebSocket;
				window.WebSocket = function(url, protocols) {
					var ws = new OrigWS(url, protocols);
					ws.addEventListener('message', function(e) {
						try {
							var d = JSON.parse(e.data);
							if (d.type === 'full-reload') {
								e.stopImmediatePropagation();
								return;
							}
						} catch(ex) {}
					}, true);
					return ws;
				};
				window.WebSocket.prototype = OrigWS.prototype;

				// Restore scroll position from hash (#sr=0.1234)
				var m = window.location.hash.match(/sr=([\d.]+)/);
				if (m) {
					var ratio = parseFloat(m[1]);
					var applyScroll = function() {
						var max = document.documentElement.scrollHeight - window.innerHeight;
						if (max > 0) window.scrollTo(0, ratio * max);
					};
					window.addEventListener('DOMContentLoaded', applyScroll);
					window.addEventListener('load', applyScroll);
					document.fonts && document.fonts.ready && document.fonts.ready.then(applyScroll);
				}

				// Notify parent that embed content is ready (after scroll restore)
				window.addEventListener('load', function() {
					// Use rAF to ensure scroll has been applied
					requestAnimationFrame(function() {
						requestAnimationFrame(function() {
							if (window.parent !== window) {
								window.parent.postMessage('embed:ready', '*');
							}
						});
					});
				});

				// Listen for theme-sync messages from parent editor
				window.addEventListener('message', function(e) {
					if (e.data && e.data.type === 'theme-sync') {
						var t = e.data.theme;
						if (t === 'dark') document.documentElement.classList.add('dark');
						else document.documentElement.classList.remove('dark');
						try { localStorage.setItem('theme', t); } catch(ex) {}
					}
				});
			}
		</script>
		<style is:global>
			.neu-hero-img {
				box-shadow: 12px 12px 24px var(--neu-shadow-dark), -12px -12px 24px var(--neu-shadow-light);
				background: var(--neu-bg);
			}
			.neu-hero-img img {
				display: block;
			}
			html[data-embed] body > header,
			html[data-embed] body > footer,
			html[data-embed] #progress-bar,
			html[data-embed] .embed-hide {
				display: none !important;
			}
			html[data-embed] .giscus-wrapper {
				display: none !important;
			}
			html[data-embed] .blog-sidebar-wrapper {
				display: none !important;
			}
			html[data-embed] main {
				padding-top: 1rem !important;
			}
		</style>
	</head>
	<body class="neu-bg">
		<!-- Reading progress bar -->
		<div id="progress-bar"
			class="fixed top-0 left-0 h-0.5 bg-[var(--text-primary)] z-50 transition-all duration-100"
			style="width: 0%">
		</div>

		<Header />

		<div class="flex flex-col md:flex-row min-h-screen max-w-[1400px] mx-auto">
			{hasSidebar && (
				<div class="blog-sidebar-wrapper">
					<Sidebar>
						<Fragment slot="sidebar" set:html={sidebarHtml} />
					</Sidebar>
				</div>
			)}

			<main class:list={[
				'box-border flex-1 flex-col w-full',
				hasSidebar ? 'md:p-16 p-6' : 'max-w-3xl mx-auto px-4 py-10',
			]}>
				<!-- Back link -->
				<div class="mb-8">
					<div class="embed-hide flex items-center gap-2">
						<a href="/blog"
						   class="neu-btn neu-link-btn gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text-link)]
						          group">
							<span class="group-hover:-translate-x-0.5 transition-transform">←</span>
							<span>返回文章列表</span>
						</a>
						{isEditorMode && postId && (
							<a href={`/admin/live-editor?slug=${postId}`}
							   class="neu-btn neu-link-btn gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text-link)]
							          group">
								<span>✏️</span>
								<span>编辑</span>
							</a>
						)}
						{postId && (
							<ShareCard client:idle ogUrl={ogImageUrl} pageUrl={pageFullUrl} title={title} avatarUrl={avatarImg.src} />
						)}
					</div>
				</div>

				<article class="max-w-3xl mx-auto w-full">
					{seriesData && postId && (
						<SeriesNav seriesData={seriesData} currentPostId={postId} />
					)}
					<div class="neu-hero-img rounded-3xl overflow-hidden mb-8">
						{heroImage ? (
							<Image
								width={1020} height={510}
								src={heroImage}
								alt=""
								class="w-full object-cover rounded-none"
							/>
						) : bodyHeroImage ? (
							<Image
								width={1020} height={510}
								src={bodyHeroImage}
								alt=""
								class="w-full object-cover rounded-none"
							/>
						) : (
							<div class="h-48 md:h-64">
								<BlogHeroFallback title={title} />
							</div>
						)}
					</div>

					<!-- Article header -->
					<header class="mb-10">
						<div class="flex flex-wrap items-center gap-2 text-sm text-[var(--text-muted)] mb-4">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<>
									<span>·</span>
									<span class="italic">updated <FormattedDate date={updatedDate} /></span>
								</>
							)}
							{readingTime && (
								<>
									<span>·</span>
									<span>{readingTime}</span>
								</>
							)}
							{wordCount != null && (
								<>
									<span>·</span>
									<span>共 {wordCount} 字</span>
								</>
							)}
							<BusuanziCounter />
						</div>
						<h1 class="text-3xl md:text-4xl font-bold text-[var(--text-heading)] leading-tight m-0 mb-3">
							{title}
						</h1>
						{description && (
							<p class="text-lg text-[var(--text-secondary)] leading-relaxed m-0">{description}</p>
						)}
						{tags.length > 0 && (
							<div class="flex flex-wrap gap-1.5 mt-3">
								{tags.map((tag) => (
									<TagChip tag={tag} />
								))}
							</div>
						)}
						{category && (
							<p class="text-[var(--text-secondary)] text-sm mt-2 m-0">
								📂 <a href={`/blog/categories/${category}/`} class="text-[var(--text-link)] hover:text-[var(--text-link-hover)]">{category}</a>
							</p>
						)}
						<hr class="mt-6 border-[var(--border-divider)]" />
					</header>

					<!-- Article body -->
					<div class="prose prose-slate prose-lg max-w-none
					            dark:prose-invert
					            prose-h1:font-bold prose-h1:text-[var(--text-heading)]
					            prose-h2:font-bold prose-h2:text-[var(--text-heading)] prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
					            prose-h3:font-bold prose-h3:text-[var(--text-heading)] prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
					            prose-h4:font-bold prose-h4:text-[var(--text-heading)]
					            prose-p:text-[var(--text-primary)] prose-p:leading-relaxed
					            prose-a:text-[var(--text-link)] prose-a:underline prose-a:underline-offset-2
					            hover:prose-a:text-[var(--text-link-hover)]
					            prose-strong:text-[var(--text-heading)]
					            prose-code:text-[var(--text-link)] prose-code:bg-[var(--bg-code)]
					            prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
					            prose-code:before:content-none prose-code:after:content-none
					            prose-pre:bg-[var(--bg-pre)] prose-pre:rounded-2xl prose-pre:shadow-md
					            prose-blockquote:border-[var(--border-divider)] prose-blockquote:text-[var(--text-secondary)]
					            prose-img:rounded-2xl prose-img:shadow-md
					            prose-hr:border-[var(--border-divider)]
					            prose-li:text-[var(--text-primary)]">
						<slot />
					</div>
				</article>

				<!-- Related posts -->
				{Astro.slots.has('related') && (
					<div class="max-w-3xl mx-auto w-full mt-12">
						<slot name="related" />
					</div>
				)}

				<!-- Comments -->
				<div class="max-w-3xl mx-auto w-full">
					<Giscus />
				</div>

				<!-- Bottom back link -->
				<div class="embed-hide max-w-3xl mx-auto w-full mt-16 pt-8 border-t border-[var(--border-divider)]">
					<a href="/blog"
					   class="neu-btn neu-link-btn gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text-link)]
					          group">
						<span class="group-hover:-translate-x-0.5 transition-transform">←</span>
						<span>返回文章列表</span>
					</a>
				</div>
			</main>
		</div>

		<Footer />

		<!-- Zen mode floating exit button — outside sidebar so it stays visible -->
		<button
			id="rs-zen-exit"
			class="neu-rs-zen-exit"
			aria-label="Exit zen reading mode"
			title="退出阅读模式 (ESC)"
		>
			<span class="neu-rs-icon">✕</span>
		</button>

		<script>
			async function initTypography() {
				const article = document.querySelector('article .prose');
				if (!article) return;

				try {
					const { default: Heti } = await import('heti/js/heti-addon');
					const heti = new Heti('.prose');
					heti.autoSpacing();
				} catch { /* graceful degradation */ }

				try {
					// Vite resolves to browser bundle which has spacingNode()
					const { default: pangu } = await import('pangu') as any;
					pangu.spacingNode(article);
				} catch { /* graceful degradation */ }
			}
			document.addEventListener('astro:page-load', initTypography);
		</script>

		<script>
			function initProgressBar() {
				const bar = document.getElementById('progress-bar');
				if (!bar) return;
				function updateProgress() {
					const scrollTop = window.scrollY;
					const docHeight = document.documentElement.scrollHeight - window.innerHeight;
					const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
					bar!.style.width = pct + '%';
				}
				window.addEventListener('scroll', updateProgress, { passive: true });
				updateProgress();
			}
			document.addEventListener('astro:page-load', initProgressBar)
		</script>
	</body>
</html>
