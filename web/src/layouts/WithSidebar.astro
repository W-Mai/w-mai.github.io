---
import {SITE_DESCRIPTION, SITE_TITLE} from "../consts";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Sidebar from '~/components/Sidebar.astro'

interface Props {
    /** When true (default), sidebar collapses to drawer on mobile */
    collapsible?: boolean
}

const { collapsible = true } = Astro.props
let html = '';
if (Astro.slots.has('sidebar')) {
    html = await Astro.slots.render('sidebar', []);
}
---


<html>
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION}/>
    <title>{SITE_TITLE}</title>
</head>

<body class="neu-bg">
<Header/>

<div class="flex flex-col md:flex-row min-h-screen max-w-[1400px] mx-auto">
    <Sidebar collapsible={collapsible}>
        <Fragment slot="sidebar" set:html={html}/>
    </Sidebar>

    <main class="box-border flex-1 flex-col md:p-16 p-6 w-full">
        <slot/>
    </main>
</div>

<Footer/>
</body>
</html>
