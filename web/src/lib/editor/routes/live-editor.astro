---
import LiveEditor from '../../components/editor/post/Live';
import '../../styles/global.css';

// Editor page: only available when EDITOR_MODE is enabled
if (!import.meta.env.DEV || !import.meta.env.EDITOR_MODE) {
  return Astro.redirect('/404');
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Live Editor</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; overflow: hidden; }
    </style>
    <script is:inline>
      // Theme initialization (same logic as BaseHead.astro)
      (function() {
        var doc = document.documentElement;
        function getStoredTheme() {
          try { return localStorage.getItem('theme'); } catch(e) { return null; }
        }
        function getSystemTheme() {
          return typeof window.matchMedia === 'function' && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        function applyTheme(t) {
          if (t === 'dark') doc.classList.add('dark'); else doc.classList.remove('dark');
        }
        function resolveTheme() {
          var s = getStoredTheme();
          return s === 'dark' || s === 'light' ? s : getSystemTheme();
        }
        applyTheme(resolveTheme());
        window.__toggleTheme = function() {
          var isDark = doc.classList.contains('dark');
          var newTheme = isDark ? 'light' : 'dark';
          applyTheme(newTheme);
          try { localStorage.setItem('theme', newTheme); } catch(e) {}
          window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: newTheme } }));
        };
      })();
    </script>
    <script is:inline>
      // Intercept Vite HMR full-reload to prevent editor page from refreshing
      // when posts/*.mdx files are saved. Instead, dispatch a custom event
      // that the React editor component listens for to refresh the preview iframe.
      (function() {
        const OrigWebSocket = window.WebSocket;
        window.WebSocket = function(url, protocols) {
          const ws = new OrigWebSocket(url, protocols);

          ws.addEventListener('message', function(event) {
            try {
              const data = JSON.parse(event.data);
              // Block full-reload to keep editor state
              if (data.type === 'full-reload') {
                event.stopImmediatePropagation();
                window.dispatchEvent(new CustomEvent('editor:hmr-reload'));
                return;
              }
              // Block error overlay from covering the editor
              if (data.type === 'error') {
                event.stopImmediatePropagation();
                console.warn('[editor] Suppressed Vite error overlay:', data.err?.message || data);
                return;
              }
            } catch {}
          }, true);

          return ws;
        };
        window.WebSocket.prototype = OrigWebSocket.prototype;
        Object.defineProperty(window, 'WebSocket', { writable: true, configurable: true });

        // Remove any existing Vite error overlay
        new MutationObserver(function(mutations) {
          for (var m of mutations) {
            for (var node of m.addedNodes) {
              if (node.tagName === 'VITE-ERROR-OVERLAY') node.remove();
            }
          }
        }).observe(document.documentElement, { childList: true, subtree: true });
      })();
    </script>
  </head>
  <body>
    <LiveEditor client:only="react" />
  </body>
</html>
