---
import { skillTreeData } from '~/data/skill-tree'

const nodeMap = new Map(skillTreeData.nodes.map(n => [n.id, n]))
const categoryMap = new Map(skillTreeData.categories.map(c => [c.id, c]))

// Group categories by domain
const categoriesByDomain = new Map<string, typeof skillTreeData.categories[number][]>()
for (const cat of skillTreeData.categories) {
  const list = categoriesByDomain.get(cat.domainId) ?? []
  list.push(cat)
  categoriesByDomain.set(cat.domainId, list)
}

// Build prerequisite names for accessibility
const prereqNames = new Map<string, string[]>()
for (const edge of skillTreeData.edges) {
  const list = prereqNames.get(edge.target) ?? []
  const src = nodeMap.get(edge.source)
  if (src) list.push(src.name)
  prereqNames.set(edge.target, list)
}

// Build tree levels per domain via topological sort
function buildDomainTree(domainId: string) {
  const cats = categoriesByDomain.get(domainId) ?? []
  const catIds = new Set(cats.map(c => c.id))
  const domainNodeIds = new Set<string>()
  for (const n of skillTreeData.nodes) {
    if (catIds.has(n.categoryId)) domainNodeIds.add(n.id)
  }

  const domainEdges = skillTreeData.edges.filter(
    e => domainNodeIds.has(e.source) && domainNodeIds.has(e.target)
  )

  const children = new Map<string, string[]>()
  const inDegree = new Map<string, number>()
  for (const id of domainNodeIds) {
    children.set(id, [])
    inDegree.set(id, 0)
  }
  for (const e of domainEdges) {
    children.get(e.source)!.push(e.target)
    inDegree.set(e.target, (inDegree.get(e.target) ?? 0) + 1)
  }

  const levels = new Map<string, number>()
  const queue: string[] = []
  for (const [id, deg] of inDegree) {
    if (deg === 0) { queue.push(id); levels.set(id, 0) }
  }
  while (queue.length > 0) {
    const curr = queue.shift()!
    const currLevel = levels.get(curr)!
    for (const child of children.get(curr) ?? []) {
      const newLevel = currLevel + 1
      levels.set(child, Math.max(levels.get(child) ?? 0, newLevel))
      inDegree.set(child, inDegree.get(child)! - 1)
      if (inDegree.get(child) === 0) queue.push(child)
    }
  }

  const maxLevel = Math.max(0, ...levels.values())
  const levelGroups: typeof skillTreeData.nodes[number][][] = []
  for (let i = 0; i <= maxLevel; i++) levelGroups.push([])
  for (const [id, lv] of levels) {
    const n = nodeMap.get(id)
    if (n) levelGroups[lv].push(n)
  }

  return { levelGroups, edges: domainEdges }
}

const domainTrees = new Map<string, ReturnType<typeof buildDomainTree>>()
for (const domain of skillTreeData.domains) {
  domainTrees.set(domain.id, buildDomainTree(domain.id))
}
---

<section class="neu-card rounded-2xl p-4 sm:p-6 md:p-8 mb-8 sm:mb-12 anim-fade" style="--delay:4" aria-labelledby="skill-tree-heading">
  <h2 id="skill-tree-heading" class="text-lg sm:text-xl font-bold text-slate-800 mb-4 sm:mb-6 flex items-center gap-2">
    🌳 技能树
    <span class="h-0.5 flex-1 bg-slate-200/60 rounded-full"></span>
  </h2>

  <!-- Domain filter -->
  <div class="flex flex-wrap gap-2 sm:gap-3 mb-3 sm:mb-4" role="tablist" aria-label="技能分类筛选">
    <button
      class="skill-filter-btn neu-inset px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
      data-domain="all" role="tab" aria-selected="true"
    >🔮 全部</button>
    {skillTreeData.domains.map(domain => (
      <button
        class="skill-filter-btn neu-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
        data-domain={domain.id} role="tab" aria-selected="false"
      >{domain.icon} {domain.name}</button>
    ))}
  </div>

  <!-- Category filter -->
  <div id="category-filter" class="flex flex-wrap gap-2 sm:gap-3 mb-3 sm:mb-4" role="tablist" aria-label="技能类别筛选">
    <button class="category-filter-btn neu-inset px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
      data-category="all" role="tab" aria-selected="true">📂 全部类别</button>
    {skillTreeData.categories.map(cat => {
      const domain = skillTreeData.domains.find(d => d.id === cat.domainId)
      return (
        <button
          class="category-filter-btn neu-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
          data-category={cat.id} data-cat-domain={cat.domainId} role="tab" aria-selected="false"
        >{cat.name}</button>
      )
    })}
  </div>

  <!-- Status filter -->
  <div class="flex flex-wrap gap-2 sm:gap-3 mb-5 sm:mb-6" role="tablist" aria-label="技能状态筛选">
    <button class="status-filter-btn neu-inset px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
      data-status="all" role="tab" aria-selected="true">📋 全部状态</button>
    <button class="status-filter-btn neu-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
      data-status="learned" role="tab" aria-selected="false">✅ 已学会</button>
    <button class="status-filter-btn neu-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
      data-status="learning" role="tab" aria-selected="false">📖 学习中</button>
    <button class="status-filter-btn neu-btn px-3 sm:px-4 py-1.5 sm:py-2 rounded-xl text-xs sm:text-sm text-slate-600 transition-all"
      data-status="blocked" role="tab" aria-selected="false">🚫 已禁止</button>
  </div>

  <!-- Skill tree per domain -->
  <div id="skill-tree-container" class="space-y-6">
    {skillTreeData.domains.map(domain => {
      const tree = domainTrees.get(domain.id)!
      return (
        <div class="skill-domain-group" data-domain-id={domain.id}>
          <h3 class="text-sm sm:text-base font-semibold text-slate-700 mb-3 flex items-center gap-1.5">
            <span>{domain.icon}</span>
            <span>{domain.name}</span>
          </h3>
          <div class="skill-tree-area relative overflow-x-auto" data-domain-tree={domain.id}>
            <!-- SVG edge layer (rendered first, sits below nodes) -->
            <svg class="skill-tree-svg absolute inset-0 pointer-events-none" style="z-index: 0">
              {tree.edges.map(edge => (
                <path
                  class="skill-edge transition-all duration-200"
                  data-edge-source={edge.source}
                  data-edge-target={edge.target}
                  stroke="#b0b8c4"
                  stroke-width="1.5"
                  fill="none"
                  opacity="0.5"
                />
              ))}
            </svg>
            <!-- Node layer (rendered after SVG, naturally above) -->
            <div class="skill-tree-nodes relative flex items-start gap-4 sm:gap-8 min-w-max py-3 px-1" style="z-index: 1">
              {tree.levelGroups.map((levelNodes, _levelIdx) => (
                <div class="flex flex-col items-center gap-3 sm:gap-4">
                  {levelNodes.map(node => {
                    const prereqs = prereqNames.get(node.id)
                    const prereqDesc = prereqs ? `前置技能: ${prereqs.join(', ')}` : undefined
                    const cat = categoryMap.get(node.categoryId)
                    const status = node.status ?? 'learned'
                    const isBlocked = status === 'blocked'
                    const isLearning = status === 'learning'

                    // Status-based style classes
                    const statusClass = isBlocked
                      ? 'skill-node-blocked opacity-50 line-through'
                      : isLearning
                        ? 'skill-node-learning'
                        : ''

                    // Status-based shadow style
                    const nodeStyle = isBlocked
                      ? 'box-shadow: inset 4px 4px 8px var(--neu-shadow-dark-strong), inset -4px -4px 8px var(--neu-shadow-light-strong); background: var(--neu-bg)'
                      : 'box-shadow: 5px 5px 10px var(--neu-shadow-dark), -5px -5px 10px var(--neu-shadow-light); background: var(--neu-bg)'

                    // Status badge
                    const statusBadge = isBlocked ? '🚫' : isLearning ? '📖' : ''

                    return (
                      <div
                        class={`skill-node relative px-3 py-2 rounded-xl cursor-default select-none
                               text-xs sm:text-sm text-slate-700 transition-all duration-200
                               ${isBlocked ? '' : 'hover:-translate-y-0.5'} ${statusClass}`}
                        style={nodeStyle}
                        data-node-id={node.id}
                        data-domain-id={domain.id}
                        data-category-id={node.categoryId}
                        data-detail={node.detail ?? ''}
                        data-status={status}
                        tabindex="0"
                        role="treeitem"
                        aria-describedby={prereqDesc ? `prereq-${node.id}` : undefined}
                      >
                        <span class={`flex items-center gap-1.5 whitespace-nowrap ${isBlocked ? 'line-through decoration-slate-400' : ''}`}>
                          {node.icon && <span class="text-sm sm:text-base">{node.icon}</span>}
                          <span>{node.name}</span>
                          {statusBadge && <span class="text-[10px] ml-0.5">{statusBadge}</span>}
                        </span>
                        {cat && (
                          <span class="block text-[10px] text-slate-400 mt-0.5">{cat.name}</span>
                        )}
                        {prereqDesc && (
                          <span id={`prereq-${node.id}`} class="sr-only">{prereqDesc}</span>
                        )}
                      </div>
                    )
                  })}
                </div>
              ))}
            </div>
          </div>
        </div>
      )
    })}
  </div>
</section>

<script>
function initSkillTree() {
  const container = document.getElementById('skill-tree-container')
  if (!container) return

  const section = container.parentElement

  // Edge position calculation for each domain tree area
  function updateAllEdges() {
    const treeAreas = container!.querySelectorAll<HTMLElement>('.skill-tree-area')
    treeAreas.forEach(area => {
      const nodesLayer = area.querySelector('.skill-tree-nodes') as HTMLElement
      const svg = area.querySelector('.skill-tree-svg') as unknown as SVGSVGElement
      if (!nodesLayer || !svg) return

      // Sync SVG size to nodes layer
      const w = nodesLayer.scrollWidth
      const h = nodesLayer.scrollHeight
      svg.setAttribute('width', String(w))
      svg.setAttribute('height', String(h))
      svg.style.width = w + 'px'
      svg.style.height = h + 'px'

      const areaRect = nodesLayer.getBoundingClientRect()

      svg.querySelectorAll<SVGPathElement>('.skill-edge').forEach(path => {
        const srcId = path.dataset.edgeSource
        const tgtId = path.dataset.edgeTarget
        if (!srcId || !tgtId) return

        const srcEl = nodesLayer.querySelector(`[data-node-id="${srcId}"]`) as HTMLElement | null
        const tgtEl = nodesLayer.querySelector(`[data-node-id="${tgtId}"]`) as HTMLElement | null
        if (!srcEl || !tgtEl) { path.setAttribute('d', ''); return }

        const sr = srcEl.getBoundingClientRect()
        const tr = tgtEl.getBoundingClientRect()
        if (sr.width === 0 || tr.width === 0) { path.setAttribute('d', ''); return }

        // Source: right edge center; Target: left edge center
        const sx = sr.right - areaRect.left
        const sy = sr.top + sr.height / 2 - areaRect.top
        const tx = tr.left - areaRect.left
        const ty = tr.top + tr.height / 2 - areaRect.top

        // Horizontal bezier curve
        const cpx = (sx + tx) / 2
        path.setAttribute('d', `M ${sx} ${sy} C ${cpx} ${sy}, ${cpx} ${ty}, ${tx} ${ty}`)
      })
    })
  }

  // Active filters state
  let activeDomain = 'all'
  let activeCategory = 'all'
  let activeStatus = 'all'

  const filterBtns = section?.querySelectorAll<HTMLButtonElement>('.skill-filter-btn')
  const categoryBtns = section?.querySelectorAll<HTMLButtonElement>('.category-filter-btn')
  const statusBtns = section?.querySelectorAll<HTMLButtonElement>('.status-filter-btn')
  const domainGroups = container.querySelectorAll<HTMLElement>('.skill-domain-group')

  // Update category button visibility based on active domain
  function updateCategoryButtons() {
    categoryBtns?.forEach(btn => {
      const catDomain = btn.dataset.catDomain
      if (!catDomain || activeDomain === 'all' || catDomain === activeDomain) {
        btn.style.display = ''
      } else {
        btn.style.display = 'none'
      }
    })
  }

  function applyFilters() {
    domainGroups.forEach(group => {
      if (activeDomain === 'all' || group.dataset.domainId === activeDomain) {
        group.style.display = ''
      } else {
        group.style.display = 'none'
      }
    })

    // Node-level filtering by category and status
    const allNodes = container!.querySelectorAll<HTMLElement>('.skill-node')
    allNodes.forEach(node => {
      const nodeStatus = node.dataset.status || 'learned'
      const nodeCat = node.dataset.categoryId || ''
      const matchStatus = activeStatus === 'all' || nodeStatus === activeStatus
      const matchCategory = activeCategory === 'all' || nodeCat === activeCategory
      node.style.display = (matchStatus && matchCategory) ? '' : 'none'
    })

    requestAnimationFrame(updateAllEdges)
  }

  // Domain filtering
  filterBtns?.forEach(btn => {
    btn.addEventListener('click', () => {
      activeDomain = btn.dataset.domain || 'all'
      filterBtns.forEach(b => {
        b.classList.remove('neu-inset')
        b.classList.add('neu-btn')
        b.setAttribute('aria-selected', 'false')
      })
      btn.classList.add('neu-inset')
      btn.classList.remove('neu-btn')
      btn.setAttribute('aria-selected', 'true')
      // Reset category to "all" when domain changes
      activeCategory = 'all'
      categoryBtns?.forEach(b => {
        b.classList.remove('neu-inset')
        b.classList.add('neu-btn')
        b.setAttribute('aria-selected', 'false')
      })
      const allCatBtn = section?.querySelector<HTMLButtonElement>('.category-filter-btn[data-category="all"]')
      if (allCatBtn) {
        allCatBtn.classList.add('neu-inset')
        allCatBtn.classList.remove('neu-btn')
        allCatBtn.setAttribute('aria-selected', 'true')
      }
      updateCategoryButtons()
      applyFilters()
    })
  })

  // Category filtering
  categoryBtns?.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category || 'all'
      categoryBtns.forEach(b => {
        b.classList.remove('neu-inset')
        b.classList.add('neu-btn')
        b.setAttribute('aria-selected', 'false')
      })
      btn.classList.add('neu-inset')
      btn.classList.remove('neu-btn')
      btn.setAttribute('aria-selected', 'true')
      applyFilters()
    })
  })

  // Status filtering
  statusBtns?.forEach(btn => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status || 'all'
      statusBtns.forEach(b => {
        b.classList.remove('neu-inset')
        b.classList.add('neu-btn')
        b.setAttribute('aria-selected', 'false')
      })
      btn.classList.add('neu-inset')
      btn.classList.remove('neu-btn')
      btn.setAttribute('aria-selected', 'true')
      applyFilters()
    })
  })

  // Hover: highlight connected edges + show tooltip
  // Create tooltip on body to avoid containing block issues from transform/transition ancestors
  let tooltip = document.getElementById('skill-tooltip')
  if (!tooltip) {
    tooltip = document.createElement('div')
    tooltip.id = 'skill-tooltip'
    tooltip.className = 'fixed pointer-events-none z-50 px-3 py-1.5 rounded-lg text-xs text-slate-600 whitespace-nowrap hidden'
    tooltip.style.cssText = 'box-shadow: 4px 4px 8px var(--neu-shadow-dark), -4px -4px 8px var(--neu-shadow-light); background: var(--neu-bg)'
    tooltip.setAttribute('role', 'tooltip')
    document.body.appendChild(tooltip)
  }
  const nodes = container.querySelectorAll<HTMLElement>('.skill-node')
  nodes.forEach(node => {
    node.addEventListener('mouseenter', () => {
      const nodeId = node.dataset.nodeId
      const detail = node.dataset.detail
      // Highlight connected edges
      const area = node.closest('.skill-tree-area')
      if (area) {
        area.querySelectorAll<SVGPathElement>('.skill-edge').forEach(edge => {
          if (edge.dataset.edgeSource === nodeId || edge.dataset.edgeTarget === nodeId) {
            edge.setAttribute('opacity', '1')
            edge.setAttribute('stroke', '#6366f1')
            edge.setAttribute('stroke-width', '2.5')
          }
        })
      }
      // Show global tooltip
      if (tooltip && detail) {
        tooltip.textContent = detail
        tooltip.classList.remove('hidden')
        const rect = node.getBoundingClientRect()
        tooltip.style.left = rect.left + rect.width / 2 + 'px'
        tooltip.style.top = rect.top - 8 + 'px'
        tooltip.style.transform = 'translate(-50%, -100%)'
      }
    })

    node.addEventListener('mouseleave', () => {
      // Reset edges
      const area = node.closest('.skill-tree-area')
      if (area) {
        area.querySelectorAll<SVGPathElement>('.skill-edge').forEach(edge => {
          edge.setAttribute('opacity', '0.5')
          edge.setAttribute('stroke', '#b0b8c4')
          edge.setAttribute('stroke-width', '1.5')
        })
      }
      // Hide tooltip
      if (tooltip) {
        tooltip.classList.add('hidden')
      }
    })

    node.addEventListener('focus', () => node.dispatchEvent(new MouseEvent('mouseenter')))
    node.addEventListener('blur', () => node.dispatchEvent(new MouseEvent('mouseleave')))
  })

  // Initial draw + observers
  requestAnimationFrame(updateAllEdges)
  const ro = new ResizeObserver(() => requestAnimationFrame(updateAllEdges))
  ro.observe(container)
  window.addEventListener('resize', () => requestAnimationFrame(updateAllEdges))
}

document.addEventListener('astro:page-load', initSkillTree)
</script>

<style>
  .skill-node:hover {
    box-shadow: 2px 2px 5px var(--neu-shadow-dark), -2px -2px 5px var(--neu-shadow-light) !important;
  }
  .skill-node-blocked:hover {
    box-shadow: inset 4px 4px 8px var(--neu-shadow-dark-strong), inset -4px -4px 8px var(--neu-shadow-light-strong) !important;
    transform: none !important;
  }
  .skill-node:focus-visible {
    outline: 2px solid #6366f1;
    outline-offset: 2px;
  }

  /* Learning status: rotating gradient border */
  .skill-node-learning {
    position: relative;
    background: var(--neu-bg) !important;
    z-index: 0;
  }
  .skill-node-learning::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 14px;
    background: conic-gradient(
      from var(--learning-angle, 0deg),
      #6366f1, #a78bfa, #818cf8, #6366f1
    );
    z-index: -1;
    animation: skill-border-spin 3s linear infinite;
    opacity: 0.7;
  }
  .skill-node-learning::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: var(--neu-bg);
    z-index: -1;
  }
  @keyframes skill-border-spin {
    to { --learning-angle: 360deg; }
  }
  @property --learning-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-node, .skill-tooltip, .skill-edge {
      transition: none !important;
    }
  }
</style>
