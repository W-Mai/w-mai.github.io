---
// Article table of contents sidebar widget — nested h2/h3 list with scroll-spy and reading progress

interface Heading {
  depth: number
  slug: string
  text: string
}

interface TocNode {
  heading: Heading
  children: Heading[]
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props

// Adaptive level detection: find the two shallowest depths used in the article
// e.g. only h3+h4 → topLevel=3, subLevel=4; h2+h3 → topLevel=2, subLevel=3
const depths = [...new Set(headings.map((h) => h.depth))].sort((a, b) => a - b)
const topLevel = depths[0] ?? 2
const subLevel = depths[1] ?? topLevel + 1

const filtered = headings.filter((h) => h.depth === topLevel || h.depth === subLevel)

// Build nested structure: sub-level items grouped under preceding top-level
const tocTree: TocNode[] = []
for (const h of filtered) {
  if (h.depth === topLevel) {
    tocTree.push({ heading: h, children: [] })
  } else if (h.depth === subLevel && tocTree.length > 0) {
    tocTree[tocTree.length - 1].children.push(h)
  } else {
    // sub-level without preceding top-level → promote to top
    tocTree.push({ heading: h, children: [] })
  }
}

// Do not render if fewer than 2 filtered headings
if (filtered.length < 2) return
---

<nav aria-label="Table of contents">
  <!-- Section heading -->
  <h3 class="neu-section-title mb-3">
    目录
    <span class="neu-section-divider"></span>
  </h3>

  <div class="toc-list-container relative">
    <!-- CSS-only reading progress line -->
    <div class="toc-progress-line" aria-hidden="true"></div>

    <ul class="flex flex-col gap-0.5 pl-3">
      {tocTree.map(({ heading, children }) => (
        <li>
          <a
            href={`#${heading.slug}`}
            data-toc-link={heading.slug}
            class="toc-link text-[var(--text-secondary)] block px-3 py-1.5 rounded-lg text-sm no-underline
              transition-all duration-200 ease
              hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
              hover:text-[var(--text-link-hover)] hover:-translate-y-px"
          >
            {heading.text}
          </a>
          {children.length > 0 && (
            <ul class="flex flex-col gap-0.5 pl-4">
              {children.map((child) => (
                <li>
                  <a
                    href={`#${child.slug}`}
                    data-toc-link={child.slug}
                    class="toc-link text-[var(--text-secondary)] block px-3 py-1 rounded-lg text-xs no-underline
                      transition-all duration-200 ease
                      hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
                      hover:text-[var(--text-link-hover)] hover:-translate-y-px"
                  >
                    {child.text}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  /* Reading progress line — CSS scroll-driven animation */
  .toc-progress-line {
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: var(--text-muted);
    border-radius: 2px;
    transform-origin: top;
    transform: scaleY(0);
    animation: toc-progress-fill linear;
    animation-timeline: scroll();
  }

  @keyframes toc-progress-fill {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }

  /* Fallback: hide if scroll-driven animations not supported */
  @supports not (animation-timeline: scroll()) {
    .toc-progress-line {
      display: none;
    }
  }

  /* Active TOC link highlight */
  .toc-link.toc-active {
    color: var(--text-heading);
    font-weight: 600;
  }
</style>

<script>
  // Scroll-spy: highlight active heading in TOC via IntersectionObserver
  function initTocScrollSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
    if (tocLinks.length === 0) return

    const slugs = Array.from(tocLinks).map((a) => a.dataset.tocLink!)
    const headingEls = slugs
      .map((slug) => document.getElementById(slug))
      .filter((el): el is HTMLElement => el !== null)

    if (headingEls.length === 0) return

    let activeSlug: string | null = null

    function setActive(slug: string | null) {
      if (slug === activeSlug) return
      activeSlug = slug
      tocLinks.forEach((a) => {
        if (a.dataset.tocLink === slug) {
          a.classList.add('toc-active')
        } else {
          a.classList.remove('toc-active')
        }
      })
    }

    // Trigger when heading is in top 20% of viewport
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id)
          }
        }
      },
      { rootMargin: '-20% 0px -80% 0px' },
    )

    headingEls.forEach((el) => observer.observe(el))
  }

  // Support Astro page transitions
  document.addEventListener('astro:page-load', initTocScrollSpy)
  // Fallback for initial load without View Transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTocScrollSpy)
  } else {
    initTocScrollSpy()
  }
</script>
