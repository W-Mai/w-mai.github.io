---
// Article table of contents — card-style with numbered badges and expand/collapse

interface Heading {
  depth: number
  slug: string
  text: string
}

interface TocNode {
  heading: Heading
  children: Heading[]
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props

// Adaptive level detection: use the two shallowest depths as top/sub level
const depths = [...new Set(headings.map((h) => h.depth))].sort((a, b) => a - b)
const topLevel = depths[0] ?? 2
const subLevel = depths[1] ?? topLevel + 1

const filtered = headings.filter((h) => h.depth === topLevel || h.depth === subLevel)

// Build nested structure: sub-level items grouped under preceding top-level
const tocTree: TocNode[] = []
for (const h of filtered) {
  if (h.depth === topLevel) {
    tocTree.push({ heading: h, children: [] })
  } else if (h.depth === subLevel && tocTree.length > 0) {
    tocTree[tocTree.length - 1].children.push(h)
  } else {
    tocTree.push({ heading: h, children: [] })
  }
}

if (filtered.length < 2) return

// Global sequential numbering
let seq = 0
---

<nav aria-label="Table of contents" class="toc-card-nav">
  <h3 class="neu-section-title mb-5">
    目录
    <span class="neu-section-divider"></span>
  </h3>

  <div class="flex flex-col gap-2">
    {tocTree.map(({ heading, children }) => {
      const parentSeq = ++seq
      const hasChildren = children.length > 0
      return (
        <div class="toc-card-group">
          <a
            href={`#${heading.slug}`}
            data-toc-link={heading.slug}
            class="toc-card neu-btn flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-[1.125rem] text-sm no-underline
              transition-all duration-200 ease"
          >
            <span class="toc-badge">{parentSeq}</span>
            <span class="text-[var(--text-primary)] flex-1 truncate text-sm font-medium">{heading.text}</span>
            {hasChildren && (
              <span class="toc-expand text-[var(--text-muted)] text-xs transition-transform duration-200">▶</span>
            )}
          </a>
          {hasChildren && (
            <div class="toc-children flex flex-col gap-1.5 pl-4 mt-1.5">
              {children.map((child) => {
                const childSeq = ++seq
                return (
                  <a
                    href={`#${child.slug}`}
                    data-toc-link={child.slug}
                    class="toc-card toc-card-sub neu-btn flex items-center gap-2 pl-1 pr-2.5 py-1 rounded-[0.875rem] text-sm no-underline
                      transition-all duration-200 ease"
                  >
                    <span class="toc-badge toc-badge-sub">{childSeq}</span>
                    <span class="text-[var(--text-secondary)] flex-1 truncate text-xs">{child.text}</span>
                  </a>
                )
              })}
            </div>
          )}
        </div>
      )
    })}
  </div>
</nav>

<style>
  /* Badge — numbered circle */
  .toc-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--neu-bg);
    box-shadow: inset 1.5px 1.5px 3px var(--neu-shadow-dark-strong),
                inset -1.5px -1.5px 3px var(--neu-shadow-light-strong);
    flex-shrink: 0;
  }

  .toc-badge-sub {
    width: 1.25rem;
    height: 1.25rem;
    font-size: 0.5625rem;
  }

  /* Active card — pressed state */
  .toc-card.toc-active {
    color: var(--text-heading);
    box-shadow: inset 3px 3px 6px var(--neu-shadow-dark-strong),
                inset -3px -3px 6px var(--neu-shadow-light-strong);
  }
  .toc-card.toc-active .toc-badge {
    background: linear-gradient(145deg, var(--neu-gradient-light), var(--neu-gradient-dark));
    box-shadow: 2px 2px 4px var(--neu-shadow-dark),
                -2px -2px 4px var(--neu-shadow-light);
    color: var(--text-heading);
  }
  .toc-card.toc-active span:not(.toc-badge):not(.toc-expand) {
    color: var(--text-heading);
    font-weight: 600;
  }

  /* Expand arrow rotation when parent is active */
  .toc-card.toc-active .toc-expand {
    transform: rotate(90deg);
  }
</style>

<script>
  // Scroll-spy: highlight active heading in TOC via IntersectionObserver
  function initTocScrollSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
    if (tocLinks.length === 0) return

    const slugs = Array.from(tocLinks).map((a) => a.dataset.tocLink!)
    const headingEls = slugs
      .map((slug) => document.getElementById(slug))
      .filter((el): el is HTMLElement => el !== null)

    if (headingEls.length === 0) return

    let activeSlug: string | null = null

    function setActive(slug: string | null) {
      if (slug === activeSlug) return
      activeSlug = slug
      tocLinks.forEach((a) => {
        if (a.dataset.tocLink === slug) {
          a.classList.add('toc-active')
        } else {
          a.classList.remove('toc-active')
        }
      })
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id)
          }
        }
      },
      { rootMargin: '-80px 0px -70% 0px' },
    )

    headingEls.forEach((el) => observer.observe(el))
  }

  document.addEventListener('astro:page-load', initTocScrollSpy)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTocScrollSpy)
  } else {
    initTocScrollSpy()
  }
</script>
