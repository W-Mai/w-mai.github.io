---
// Article table of contents — inset container with scroll-spy and reading progress

interface Heading {
  depth: number
  slug: string
  text: string
}

interface TocNode {
  heading: Heading
  children: Heading[]
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props

// Adaptive level detection: use the two shallowest depths as top/sub level
const depths = [...new Set(headings.map((h) => h.depth))].sort((a, b) => a - b)
const topLevel = depths[0] ?? 2
const subLevel = depths[1] ?? topLevel + 1

const filtered = headings.filter((h) => h.depth === topLevel || h.depth === subLevel)

// Build nested structure: sub-level items grouped under preceding top-level
const tocTree: TocNode[] = []
for (const h of filtered) {
  if (h.depth === topLevel) {
    tocTree.push({ heading: h, children: [] })
  } else if (h.depth === subLevel && tocTree.length > 0) {
    tocTree[tocTree.length - 1].children.push(h)
  } else {
    tocTree.push({ heading: h, children: [] })
  }
}

if (filtered.length < 2) return
---

<nav aria-label="Table of contents">
  <h3 class="neu-section-title mb-3">
    目录
    <span class="neu-section-divider"></span>
  </h3>

  <div class="neu-inset rounded-xl p-2 relative">
    <!-- Reading progress track (inset groove) -->
    <div class="toc-progress-track" aria-hidden="true">
      <div class="toc-progress-fill"></div>
    </div>

    <ul class="flex flex-col gap-0.5 pl-3">
      {tocTree.map(({ heading, children }) => (
        <li>
          <a
            href={`#${heading.slug}`}
            data-toc-link={heading.slug}
            class="toc-link block px-3 py-1.5 rounded-lg text-sm no-underline
              text-[var(--text-secondary)]
              transition-all duration-200 ease
              hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
              hover:text-[var(--text-primary)] hover:-translate-y-px"
          >
            {heading.text}
          </a>
          {children.length > 0 && (
            <ul class="flex flex-col gap-0.5 pl-4">
              {children.map((child) => (
                <li>
                  <a
                    href={`#${child.slug}`}
                    data-toc-link={child.slug}
                    class="toc-link block px-3 py-1 rounded-lg text-xs no-underline
                      text-[var(--text-muted)]
                      transition-all duration-200 ease
                      hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
                      hover:text-[var(--text-primary)] hover:-translate-y-px"
                  >
                    {child.text}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  /* Progress track — inset groove along left edge */
  .toc-progress-track {
    position: absolute;
    left: 0.5rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 4px;
    border-radius: 2px;
    background: var(--neu-bg);
    box-shadow: inset 1px 1px 2px var(--neu-shadow-dark-strong),
                inset -1px -1px 2px var(--neu-shadow-light-strong);
    overflow: hidden;
  }

  .toc-progress-fill {
    width: 100%;
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(to bottom, var(--text-link), var(--text-link-hover));
    transform-origin: top;
    transform: scaleY(0);
    animation: toc-progress linear;
    animation-timeline: scroll();
  }

  @keyframes toc-progress {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }

  @supports not (animation-timeline: scroll()) {
    .toc-progress-track { display: none; }
  }

  /* Active TOC link — reverse gradient inset like pressed button */
  .toc-link.toc-active {
    color: var(--text-heading);
    font-weight: 600;
    background: linear-gradient(145deg, var(--neu-gradient-dark), var(--neu-gradient-light));
    box-shadow: inset 2px 2px 4px var(--neu-shadow-dark-strong),
                inset -2px -2px 4px var(--neu-shadow-light-strong);
  }
</style>

<script>
  // Scroll-spy: highlight active heading in TOC via IntersectionObserver
  function initTocScrollSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
    if (tocLinks.length === 0) return

    const slugs = Array.from(tocLinks).map((a) => a.dataset.tocLink!)
    const headingEls = slugs
      .map((slug) => document.getElementById(slug))
      .filter((el): el is HTMLElement => el !== null)

    if (headingEls.length === 0) return

    let activeSlug: string | null = null

    function setActive(slug: string | null) {
      if (slug === activeSlug) return
      activeSlug = slug
      tocLinks.forEach((a) => {
        if (a.dataset.tocLink === slug) {
          a.classList.add('toc-active')
        } else {
          a.classList.remove('toc-active')
        }
      })
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id)
          }
        }
      },
      { rootMargin: '-20% 0px -80% 0px' },
    )

    headingEls.forEach((el) => observer.observe(el))
  }

  document.addEventListener('astro:page-load', initTocScrollSpy)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTocScrollSpy)
  } else {
    initTocScrollSpy()
  }
</script>
