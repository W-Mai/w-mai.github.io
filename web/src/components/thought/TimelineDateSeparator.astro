---
import { siteYear, siteDay, siteMonthLong, siteWeekdayLong } from '~/lib/date-utils'

interface Props {
  level: 'year' | 'month' | 'day'
  date: Date
  delay?: number
}

const { level, date, delay = 0 } = Astro.props

const year = siteYear(date)
const month = siteMonthLong(date)
const day = siteDay(date)
const weekday = siteWeekdayLong(date)

const label =
  level === 'year' ? `${year}` :
  level === 'month' ? `${month}` :
  `${day}日 ${weekday}`
---

<div class={`timeline-separator timeline-separator-${level} anim-fade`} style={`--delay:${delay}`}>
  <div class="timeline-dot"></div>
  <div class="timeline-connector"></div>
  <span class="timeline-separator-label">{label}</span>
</div>
