---
import ThoughtCard from './ThoughtCard.astro'
import TimelineDateSeparator from './TimelineDateSeparator.astro'
import type { Thought } from '~/data/thoughts'
import type { ThoughtCommentData } from '~/data/giscus-comments'
import { siteYear, siteMonth, siteDay, parseSiteDate } from '~/lib/date-utils'

interface Props {
  thoughts: readonly Thought[]
  delayStart?: number
  isEditorMode?: boolean
  commentMap?: Map<string, ThoughtCommentData>
}

const { thoughts, delayStart = 3, isEditorMode = false, commentMap } = Astro.props

let prevYear = -1
let prevMonth = -1
let prevDay = -1
let seq = 0
---

<div class="thought-timeline">
  {/* Preview slot — React ThoughtEditor portals live preview here */}
  <div id="thought-preview-slot"></div>

  {thoughts.map((thought) => {
    const d = parseSiteDate(thought.createdAt)
    const y = siteYear(d)
    const m = siteMonth(d)
    const day = siteDay(d)
    const showYear = y !== prevYear
    const showMonth = showYear || m !== prevMonth
    const showDay = showMonth || day !== prevDay
    prevYear = y; prevMonth = m; prevDay = day

    const yearDelay = showYear ? seq++ : -1
    const monthDelay = showMonth ? seq++ : -1
    const dayDelay = showDay ? seq++ : -1
    const itemDelay = seq++

    return (
      <>
        {showYear && <TimelineDateSeparator level="year" date={d} delay={delayStart + yearDelay} />}
        {showMonth && <TimelineDateSeparator level="month" date={d} delay={delayStart + monthDelay} />}
        {showDay && <TimelineDateSeparator level="day" date={d} delay={delayStart + dayDelay} />}
        <div class="timeline-item anim-fade" style={`--delay:${delayStart + itemDelay}`}>
          <div class="timeline-dot"></div>
          <div class="timeline-connector"></div>
          <ThoughtCard thought={thought} isEditorMode={isEditorMode} commentData={commentMap?.get(thought.id)} />
        </div>
      </>
    )
  })}
</div>
