---
// Series sidebar widget — toggleable filter buttons with post counts
interface Props {
  series: Array<{ slug: string; title: string; count: number }>
}

const { series } = Astro.props
if (series.length === 0) return
---

<nav aria-label="Series">
  <h3 class="neu-section-title mb-3">
    系列
    <span class="neu-section-divider"></span>
  </h3>

  <ul class="flex flex-col gap-1.5">
    {series.map(({ slug, title, count }) => (
      <li>
        <button
          type="button"
          data-filter-type="series"
          data-filter-value={slug}
          class="series-filter-btn block px-3 py-2 w-full rounded-lg text-sm
            transition-all duration-200 ease cursor-pointer
            hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
            hover:-translate-y-px"
        >
          <span class="flex items-center justify-between">
            <span class="text-[var(--text-primary)] truncate text-sm font-medium text-left">
              {title}
            </span>
            <span class="text-[var(--text-muted)] ml-2 text-xs font-medium tabular-nums">
              {count}
            </span>
          </span>
        </button>
      </li>
    ))}
  </ul>
</nav>

<style>
  .series-filter-btn {
    background: transparent;
    border: none;
    transition: background 200ms ease, box-shadow 200ms ease, transform 200ms ease, color 200ms ease;
  }
  .series-filter-btn.active {
    background: linear-gradient(145deg, var(--neu-gradient-dark), var(--neu-gradient-light));
    box-shadow: inset 2px 2px 4px var(--neu-shadow-dark-strong),
                inset -2px -2px 4px var(--neu-shadow-light-strong);
    transform: translateY(0);
  }
  .series-filter-btn.active:hover {
    transform: translateY(0);
    background: linear-gradient(145deg, var(--neu-gradient-dark), var(--neu-gradient-light));
  }
</style>
