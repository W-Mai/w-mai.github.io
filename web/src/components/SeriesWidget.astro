---
// Series sidebar widget — displays all series with post counts
interface Props {
  series: Array<{ slug: string; title: string; count: number }>
}

const { series } = Astro.props

// Do not render if no series
if (series.length === 0) return
---

<nav aria-label="Series">
  <!-- Section heading -->
  <h3 class="neu-section-title mb-3">
    系列
    <span class="neu-section-divider"></span>
  </h3>

  <ul class="flex flex-col gap-1.5">
    {series.map(({ slug, title, count }) => (
      <li>
        <a
          href={`/blog/series/${slug}/`}
          class="text-[var(--text-link)] block px-3 py-2 rounded-lg text-sm no-underline
            transition-all duration-200 ease
            hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
            hover:text-[var(--text-link-hover)] hover:-translate-y-px"
        >
          <span class="flex items-center justify-between">
            <span class="text-[var(--text-primary)] truncate text-sm font-medium">
              {title}
            </span>
            <span class="text-[var(--text-muted)] ml-2 text-xs font-medium tabular-nums">
              {count}
            </span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>
