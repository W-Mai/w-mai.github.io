---
// Sidebar widget showing recent thoughts with links to detail pages

import { loadThoughts } from '../data/thoughts'
import { renderMarkdown } from '../lib/markdown/markdown'

interface Props {
  count?: number;
}

const { count = 3 } = Astro.props;
const thoughts = (await loadThoughts()).slice(0, count);

const items = await Promise.all(
  thoughts.map(async (t) => ({
    id: t.id,
    mood: t.mood,
    html: await renderMarkdown(t.content),
    date: new Date(t.createdAt),
  }))
);
---

{items.length > 0 && (
  <div class="neu-inset-subtle rounded-2xl p-4 -mt-6 sm:mt-5 max-w-xs sm:max-w-none mx-auto sm:mx-0">
    <h3 class="neu-section-title mb-1.5 sm:mb-3 text-xs sm:text-sm">
      🧠 近期想法
      <a href="/thoughts" class="text-[0.6rem] sm:text-xs font-normal text-[var(--text-muted)] hover:text-[var(--text-link)] no-underline transition-colors">更多 →</a>
      <span class="neu-section-divider"></span>
    </h3>
    <ul class="neu-recent-thought-list flex flex-col gap-0.5 sm:gap-2 m-0 p-0">
      {items.map((item) => (
        <li class="list-none">
          <a href={`/thoughts/${item.id}/`}
             class="neu-recent-thought block rounded-md sm:rounded-xl p-1.5 sm:p-2.5 no-underline transition-all duration-200">
            <div class="flex items-center gap-1 mb-0.5 sm:mb-1">
              {item.mood && <span class="text-[0.6rem] sm:text-xs">{item.mood}</span>}
              <time class="text-[0.55rem] sm:text-[0.65rem] text-[var(--text-muted)]"
                    datetime={item.date.toISOString()}>
                {item.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
              </time>
            </div>
            <div class="neu-recent-thought-text text-[0.65rem] sm:text-xs text-[var(--text-secondary)] leading-tight sm:leading-relaxed"
                 set:html={item.html} />
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
