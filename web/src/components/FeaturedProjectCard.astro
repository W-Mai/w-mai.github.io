---
import { getImage } from 'astro:assets'
import { getLanguageColor } from '../lib/language-colors'

interface Props {
  name: string
  description: string | null
  language: string | null
  stars: number
  url: string
  homepage: string | null
  bannerUrl: string | null
  logoUrl: string | null
  owner: string
  badges: string[]
}

const { name, description, language, stars, url, homepage, bannerUrl, logoUrl, owner, badges = [] } = Astro.props
const languageColor = getLanguageColor(language)
const hasBanner = !!bannerUrl
const hasLogo = !!logoUrl

// Generate a subtle hue for no-banner fallback
const hue = name.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % 360

// Optimize remote images at build time, output to dist/_astro/ as webp
const bannerSrc = hasBanner
  ? (await getImage({ src: bannerUrl, inferSize: true })).src
  : null
const logoSrc = hasLogo
  ? (await getImage({ src: logoUrl, inferSize: true })).src
  : null
const ownerAvatarSrc = (await getImage({
  src: `https://avatars.githubusercontent.com/${owner}`,
  width: 28,
  height: 28,
})).src

// Pre-compute gradient for no-banner fallback
const fallbackGradient = `linear-gradient(135deg, hsl(${hue}, 60%, 95%) 0%, hsl(${hue + 30}, 50%, 90%) 50%, hsl(${hue + 60}, 40%, 92%) 100%)`
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="featured-card neu-card group block relative rounded-3xl overflow-hidden
         transition-all duration-300 ease-out no-underline
         focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:outline-none"
  style={`--card-accent: ${languageColor}; --card-hue: ${hue}`}
>

  {/* Banner / Visual area */}
  <div class="relative h-40 overflow-hidden">
    {bannerSrc ? (
      <img
        src={bannerSrc}
        alt=""
        class="absolute inset-0 w-full h-full object-cover
               transition-transform duration-700 ease-out
               group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 overflow-hidden"
           style={`background: ${fallbackGradient}`}>
        {/* Geometric decoration */}
        <div class="absolute inset-0">
          <div class="absolute top-4 right-4 size-24 rounded-full opacity-20"
               style={`background: ${languageColor}`} />
          <div class="absolute -bottom-6 -left-6 size-32 rounded-full opacity-10"
               style={`background: ${languageColor}`} />
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
            <span class="text-6xl font-black select-none opacity-[0.08] tracking-wider"
                  style={`color: ${languageColor}`}>
              {name.toUpperCase()}
            </span>
          </div>
        </div>
      </div>
    )}

    {/* Bottom gradient fade to neumorphism background */}
    <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-[var(--neu-bg)]/60 to-transparent" />

    {/* Stars badge */}
    {stars > 0 && (
      <div class="absolute top-3 right-3 z-10">
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full
                      bg-[var(--overlay-bg)] backdrop-blur-md text-[var(--text-primary)] text-xs font-semibold
                      shadow-sm border border-[var(--overlay-border)]">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"
               class="size-3 text-[var(--accent-star)]">
            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z" />
          </svg>
          {stars}
        </span>
      </div>
    )}
  </div>

  {/* Content area */}
  <div class="relative px-5 pb-5">
    {/* Logo + Title row */}
    <div class="flex items-center gap-3.5">
      {/* Logo */}
      {logoSrc && (
        <div class="shrink-0 -mt-7 relative z-10">
          <div class="size-14 rounded-xl overflow-hidden bg-[var(--neu-bg)]
                       shadow-lg ring-[3px] ring-[var(--neu-bg)]
                       flex items-center justify-center">
            <img
              src={logoSrc}
              alt={`${name} logo`}
              class="size-full object-contain p-1.5"
              loading="lazy"
            />
          </div>
        </div>
      )}

      {/* Title + Owner */}
      <div class:list={["min-w-0 flex-1", { "pt-3": !hasLogo, "pt-1": hasLogo }]}>
        <h3 class="featured-title m-0 font-bold truncate text-[var(--text-heading)] transition-colors duration-300">
          {name}
        </h3>
        <div class="flex items-center gap-1.5 mt-0.5">
          <img
            src={ownerAvatarSrc}
            alt=""
            class="size-3.5 rounded-full opacity-60"
            loading="lazy"
          />
          <span class="text-[11px] text-[var(--text-muted)] font-medium">{owner}</span>
        </div>
      </div>
    </div>

    {/* Description */}
    <p class="mt-2.5 mb-0 text-[13px] text-[var(--text-secondary)] line-clamp-2 leading-relaxed">
      {description ?? 'No description provided'}
    </p>

    {/* Badges from README */}
    {badges.length > 0 && (
      <div class="mt-2.5 flex flex-wrap gap-1.5">
        {badges.map((badge) => (
          <img src={badge} alt="" class="h-5 rounded-sm" loading="lazy" />
        ))}
      </div>
    )}

    {/* Footer: language + homepage */}
    <div class="mt-3 pt-3 border-t border-[var(--border-subtle)] flex items-center justify-between gap-2">
      {language ? (
        <span class="inline-flex items-center gap-1.5 text-[11px] font-medium text-[var(--text-secondary)]">
          <span class="size-2.5 rounded-full shrink-0" style={`background-color: ${languageColor}`} />
          {language}
        </span>
      ) : <span />}

      {homepage && (
        <span
          class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-wide uppercase
                 rounded-md px-3 py-1.5 cursor-pointer
                 text-[var(--btn-demo-text)] shadow-sm bg-[var(--btn-demo-bg)]
                 hover:shadow-md hover:bg-[var(--btn-demo-bg-hover)]
                 transition-all duration-200 active:scale-95"
          onclick={`event.preventDefault(); event.stopPropagation(); window.open('${homepage}', '_blank')`}
        >
          Homepage
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"
               class="size-3 transition-transform duration-200 group-hover:translate-x-0.5">
            <path fill-rule="evenodd" d="M4.22 11.78a.75.75 0 0 1 0-1.06L9.44 5.5H5.75a.75.75 0 0 1 0-1.5h5.5a.75.75 0 0 1 .75.75v5.5a.75.75 0 0 1-1.5 0V6.56l-5.22 5.22a.75.75 0 0 1-1.06 0Z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .featured-card {
    will-change: transform, box-shadow;
    color: var(--text-primary) !important;
  }
  .featured-card:hover {
    color: var(--text-primary) !important;
    box-shadow: 12px 12px 24px var(--neu-shadow-dark), -12px -12px 24px var(--neu-shadow-light);
    transform: translateY(-4px);
  }
  .featured-title {
    font-size: 1.5rem !important;
    line-height: 2rem !important;
  }
</style>