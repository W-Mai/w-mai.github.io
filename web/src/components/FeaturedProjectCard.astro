---
import { getLanguageColor } from '../lib/language-colors'

interface Props {
  name: string
  description: string | null
  language: string | null
  stars: number
  url: string
  homepage: string | null
  bannerUrl: string | null
  logoUrl: string | null
  owner: string
}

const { name, description, language, stars, url, homepage, bannerUrl, logoUrl, owner } = Astro.props
const languageColor = getLanguageColor(language)
const hasBanner = !!bannerUrl
const hasLogo = !!logoUrl
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block relative rounded-2xl overflow-hidden
         bg-white border border-slate-200/80
         transition-all duration-300 ease-out no-underline
         hover:shadow-2xl hover:-translate-y-1.5 hover:border-slate-300/60"
>
  {/* Banner area */}
  <div class="relative h-36 overflow-hidden">
    {hasBanner ? (
      <img
        src={bannerUrl}
        alt={`${name} banner`}
        class="absolute inset-0 w-full h-full object-cover
               transition-transform duration-500 ease-out
               group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div
        class="absolute inset-0"
        style={`background: linear-gradient(135deg, ${languageColor}22 0%, ${languageColor}44 50%, ${languageColor}18 100%)`}
      >
        {/* Decorative pattern for non-banner cards */}
        <div class="absolute inset-0 opacity-[0.07]"
             style="background-image: radial-gradient(circle at 20% 50%, currentColor 1px, transparent 1px), radial-gradient(circle at 80% 20%, currentColor 1px, transparent 1px), radial-gradient(circle at 60% 80%, currentColor 1px, transparent 1px); background-size: 40px 40px, 60px 60px, 50px 50px" />
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-5xl font-black select-none opacity-20" style={`color: ${languageColor}`}>
            {name.slice(0, 3).toUpperCase()}
          </span>
        </div>
      </div>
    )}
    {/* Gradient overlay for readability */}
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent" />

    {/* Stars badge floating on banner */}
    <div class="absolute top-3 right-3">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full
                    bg-black/30 backdrop-blur-md text-white text-xs font-medium
                    border border-white/10">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-3">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z" />
        </svg>
        {stars}
      </span>
    </div>

    {/* Language pill floating on banner */}
    {language && (
      <div class="absolute top-3 left-3">
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full
                      bg-black/30 backdrop-blur-md text-white text-xs font-medium
                      border border-white/10">
          <span class="size-2 rounded-full" style={`background-color: ${languageColor}`} />
          {language}
        </span>
      </div>
    )}
  </div>

  {/* Content area */}
  <div class="relative px-5 pb-4 pt-4">
    {/* Logo positioned overlapping the banner/content boundary */}
    {hasLogo && (
      <div class="absolute -top-7 left-5">
        <div class="size-14 rounded-xl overflow-hidden bg-white
                     shadow-lg border-2 border-white
                     flex items-center justify-center">
          <img
            src={logoUrl}
            alt={`${name} logo`}
            class="size-full object-contain p-1.5"
            loading="lazy"
          />
        </div>
      </div>
    )}

    {/* Title row with extra top padding when logo is present */}
    <div class:list={["flex items-start gap-2", { "mt-8": hasLogo }]}>
      <div class="min-w-0 flex-1">
        <h3 class="m-0 text-base font-bold truncate text-slate-800
                    group-hover:text-blue-600 transition-colors">
          {name}
        </h3>
        <div class="flex items-center gap-1.5 mt-1">
          <img
            src={`https://github.com/${owner}.png`}
            alt={owner}
            class="size-4 rounded-full ring-1 ring-slate-200"
            loading="lazy"
          />
          <span class="text-xs text-slate-400">{owner}</span>
        </div>
      </div>
    </div>

    {/* Description */}
    <p class="mt-2.5 mb-0 text-sm text-slate-500 line-clamp-2 leading-relaxed">
      {description ?? 'No description provided'}
    </p>

    {/* Action row */}
    {homepage && (
      <div class="mt-3 pt-3 border-t border-slate-100 flex items-center">
        <span
          class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-600
                 group-hover:text-blue-700 transition-colors"
          onclick={`event.preventDefault(); event.stopPropagation(); window.open('${homepage}', '_blank')`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-3.5">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 0 0-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 0 0 .75-.75v-4a.75.75 0 0 1 1.5 0v4A2.25 2.25 0 0 1 12.75 17h-8.5A2.25 2.25 0 0 1 2 14.75v-8.5A2.25 2.25 0 0 1 4.25 4h5a.75.75 0 0 1 0 1.5h-5Zm7.25-.75a.75.75 0 0 1 .75-.75h3.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0V6.31l-5.47 5.47a.75.75 0 1 1-1.06-1.06l5.47-5.47H12.25a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
          Visit Homepage
        </span>
      </div>
    )}
  </div>
</a>
