---
// Giscus comment system powered by GitHub Discussions
import { SITE_URL } from '../consts';
---

<section class="giscus-wrapper neu-card mt-12 p-6 rounded-2xl">
  <h3 class="text-lg font-bold text-slate-700 mb-4">💬 评论</h3>
  <div class="giscus-inner neu-inset rounded-xl p-4">
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo="W-Mai/w-mai.github.io"
      data-repo-id="R_kgDOPiz_Tg"
      data-category="Blog Comments"
      data-category-id="DIC_kwDOPiz_Ts4C3_Qs"
      data-mapping="url"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="1"
      data-input-position="bottom"
      data-theme={`${SITE_URL}/giscus-neumorphism.css`}
      data-lang="zh-CN"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>
