---
// Giscus comment system — custom React client with neumorphism UI
import { SITE_URL } from '../consts';
import GiscusClient from './GiscusClient';
---

<section class="giscus-wrapper">
  <GiscusClient
    client:visible
    repo="W-Mai/w-mai.github.io"
    repoId="R_kgDOPiz_Tg"
    category="Blog Comments"
    categoryId="DIC_kwDOPiz_Ts4C3_Qs"
    mapping="url"
    theme={`${SITE_URL}/giscus-neumorphism.css`}
    lang="zh-CN"
    reactionsEnabled={true}
    emitMetadata={true}
    inputPosition="bottom"
    loading="lazy"
  />
</section>
