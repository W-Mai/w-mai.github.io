---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE, GA4_MEASUREMENT_ID } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image } = Astro.props;

// Blog posts use auto-generated OG images; other pages use provided image
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '').replace(/^\//, '');
const isBlogPost = Astro.url.pathname.startsWith('/blog/');
const ogImageUrl = isBlogPost
	? new URL(`/og/${slug}.png`, Astro.site).toString()
	: image
		? new URL(image.src, Astro.url).toString()
		: new URL(`/og/${slug || 'index'}.png`, Astro.site).toString();
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="https://github.com/w-mai.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Baidu site verification -->
<meta name="baidu-site-verification" content="codeva-RkbN591qFi" />

<!-- Theme initialization — runs before first paint to prevent FOUC -->
<script is:inline>
(function () {
  var doc = document.documentElement;

  // Read stored theme preference from localStorage
  function getStoredTheme() {
    try {
      return localStorage.getItem('theme');
    } catch (e) {
      return null;
    }
  }

  // Detect system color scheme preference
  function getSystemTheme() {
    if (typeof window.matchMedia === 'function') {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    return 'light';
  }

  // Apply theme by toggling html.dark class
  function applyTheme(theme) {
    if (theme === 'dark') {
      doc.classList.add('dark');
    } else {
      doc.classList.remove('dark');
    }
  }

  // Resolve active theme: user preference > system preference
  function resolveTheme() {
    var stored = getStoredTheme();
    return stored === 'dark' || stored === 'light' ? stored : getSystemTheme();
  }

  // Initialize theme before first paint
  applyTheme(resolveTheme());

  // Global toggle function for ThemeToggle component
  window.__toggleTheme = function () {
    var isDark = doc.classList.contains('dark');
    var newTheme = isDark ? 'light' : 'dark';
    applyTheme(newTheme);
    try {
      localStorage.setItem('theme', newTheme);
    } catch (e) {}
    window.dispatchEvent(
      new CustomEvent('theme-change', { detail: { theme: newTheme } })
    );
  };

  // Watch system preference changes — only apply when no explicit user preference
  if (typeof window.matchMedia === 'function') {
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
      var stored = getStoredTheme();
      if (stored === 'dark' || stored === 'light') return;
      applyTheme(e.matches ? 'dark' : 'light');
      window.dispatchEvent(
        new CustomEvent('theme-change', { detail: { theme: e.matches ? 'dark' : 'light' } })
      );
    });
  }

  // Re-apply theme after View Transitions page swap (prevent flicker)
  document.addEventListener('astro:after-swap', function () {
    applyTheme(resolveTheme());
  });
})();
</script>

<!-- Font preloads -->
<link rel="preload" href="/fonts/ark-pixel-12px-monospaced-zh_cn.ttf" as="font" type="font/ttf" crossorigin />
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Page transition animations -->
<ClientRouter />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />

<!-- Global scroll animation observer -->
<script>
	function initAnimations() {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible')
						entry.target.querySelectorAll('.anim-zoom').forEach(el => {
							el.classList.add('visible')
						})
						observer.unobserve(entry.target)

						// After entrance animation, switch to fast hover transitions
						const delay = parseFloat(getComputedStyle(entry.target).transitionDelay) || 0
						setTimeout(() => {
							entry.target.classList.add('anim-done')
						}, (delay + 0.6) * 1000)
					}
				})
			},
			{ threshold: 0.05, rootMargin: '0px 0px 100px 0px' }
		)
		document.querySelectorAll('.anim-fade').forEach(el => observer.observe(el))
	}
	// Run on initial load and after each page transition
	document.addEventListener('astro:page-load', initAnimations)
</script>

<!-- Re-initialize mermaid diagrams after View Transitions and theme changes -->
<script>
	async function reinitMermaid() {
		const diagrams = document.querySelectorAll('pre.mermaid:not([data-processed])');
		if (diagrams.length === 0) return;
		try {
			const isDark = document.documentElement.classList.contains('dark');
			const { default: mermaid } = await import('mermaid');
			mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });
			for (const el of diagrams) {
				if (!el.getAttribute('data-diagram')) {
					el.setAttribute('data-diagram', el.textContent || '');
				}
				const def = el.getAttribute('data-diagram') || '';
				const id = 'mermaid-vt-' + Math.random().toString(36).slice(2, 11);
				const { svg } = await mermaid.render(id, def);
				el.innerHTML = svg;
				el.setAttribute('data-processed', 'true');
			}
		} catch {}
	}

	async function rerenderMermaid() {
		// Reset all processed diagrams so reinitMermaid picks them up again
		document.querySelectorAll('pre.mermaid[data-processed]').forEach((el) => {
			el.removeAttribute('data-processed');
		});
		await reinitMermaid();
	}

	document.addEventListener('astro:page-load', reinitMermaid);
	window.addEventListener('theme-change', rerenderMermaid);
</script>

{/* GA4 tracking script — production only */}
{import.meta.env.PROD && (
	<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}></script>
	<script define:vars={{ GA4_MEASUREMENT_ID }}>
		if (navigator.doNotTrack !== '1') {
			window.dataLayer = window.dataLayer || [];
			function gtag() { dataLayer.push(arguments); }
			gtag('js', new Date());
			gtag('config', GA4_MEASUREMENT_ID);
		}
	</script>
)}
