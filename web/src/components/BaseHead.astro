---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image } = Astro.props;

// Use provided image or fall back to auto-generated OG image
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const ogImageUrl = image
	? new URL(image.src, Astro.url).toString()
	: new URL(`/og/${slug || 'index'}.png`, Astro.site).toString();
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="https://github.com/w-mai.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Page transition animations -->
<ClientRouter />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />

<!-- Global scroll animation observer -->
<script>
	function initAnimations() {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible')
						entry.target.querySelectorAll('.anim-zoom').forEach(el => {
							el.classList.add('visible')
						})
						observer.unobserve(entry.target)
					}
				})
			},
			{ threshold: 0.1 }
		)
		document.querySelectorAll('.anim-fade').forEach(el => observer.observe(el))
	}
	// Run on initial load and after each page transition
	document.addEventListener('astro:page-load', initAnimations)
</script>

<!-- Re-initialize mermaid diagrams after View Transitions -->
<script>
	async function reinitMermaid() {
		const diagrams = document.querySelectorAll('pre.mermaid:not([data-processed])');
		if (diagrams.length === 0) return;
		try {
			const { default: mermaid } = await import('mermaid');
			mermaid.initialize({ startOnLoad: false, theme: 'default' });
			for (const el of diagrams) {
				if (!el.getAttribute('data-diagram')) {
					el.setAttribute('data-diagram', el.textContent || '');
				}
				const def = el.getAttribute('data-diagram') || '';
				const id = 'mermaid-vt-' + Math.random().toString(36).slice(2, 11);
				const { svg } = await mermaid.render(id, def);
				el.innerHTML = svg;
				el.setAttribute('data-processed', 'true');
			}
		} catch {}
	}
	document.addEventListener('astro:page-load', reinitMermaid);
</script>
