---
// Recent posts sidebar widget — displays up to 5 most recent posts
import FormattedDate from './FormattedDate.astro'

interface Props {
  posts: Array<{ id: string; title: string; pubDate: Date }>
}

const { posts } = Astro.props

// Do not render if fewer than 2 posts
if (posts.length < 2) return

// Take up to 5 most recent (assume pre-sorted by caller)
const recent = posts.slice(0, 5)
---

<nav aria-label="Recent posts">
  <!-- Section heading -->
  <h3 class="neu-section-title mb-3">
    最近文章
    <span class="neu-section-divider"></span>
  </h3>

  <ul class="flex flex-col gap-1.5">
    {recent.map((post) => (
      <li>
        <a
          href={`/blog/${post.id}/`}
          class="text-[var(--text-link)] block px-3 py-2 rounded-lg text-sm no-underline
            transition-all duration-200 ease
            hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
            hover:text-[var(--text-link-hover)] hover:-translate-y-px"
        >
          <span class="block truncate text-[var(--text-primary)] text-sm font-medium">
            {post.title}
          </span>
          <span class="text-[var(--text-muted)] text-xs">
            <FormattedDate date={post.pubDate} />
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>
