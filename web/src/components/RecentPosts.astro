---
// Recent posts sidebar widget — inset list with gradient hover items
import FormattedDate from './FormattedDate.astro'

interface Props {
  posts: Array<{ id: string; title: string; pubDate: Date }>
}

const { posts } = Astro.props
if (posts.length < 2) return

const recent = posts.slice(0, 5)
---

<nav aria-label="Recent posts">
  <h3 class="neu-section-title mb-3">
    最近文章
    <span class="neu-section-divider"></span>
  </h3>

  <div class="neu-inset rounded-xl p-2">
    <ul class="flex flex-col gap-0.5">
      {recent.map((post) => (
        <li>
          <a
            href={`/blog/${post.id}/`}
            class="block px-3 py-2 rounded-lg text-sm no-underline
              transition-all duration-200 ease
              hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
              hover:-translate-y-px"
          >
            <span class="text-[var(--text-primary)] block truncate text-sm font-medium">
              {post.title}
            </span>
            <span class="text-[var(--text-muted)] text-xs">
              <FormattedDate date={post.pubDate} />
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
