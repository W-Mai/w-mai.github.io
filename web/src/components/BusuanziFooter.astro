---
// Site-wide page view and unique visitor counter for the footer (busuanzi v3.6.9).
---
<div class="busuanzi-footer" aria-label="Site statistics">
  <span class="busuanzi-footer-loading">加载中...</span>
  <span class="busuanzi-footer-stats busuanzi-footer-hidden">
    <span>本站被怼了 <span id="busuanzi_site_pv"></span> 下儿</span>
    <span class="busuanzi-sep">·</span>
    <span><span id="busuanzi_site_uv"></span> 个老铁来过</span>
  </span>
</div>

<script>
  function initBusuanziFooter() {
    const container = document.querySelector(
      '.busuanzi-footer',
    ) as HTMLElement | null;
    const loading = container?.querySelector(
      '.busuanzi-footer-loading',
    ) as HTMLElement | null;
    const stats = container?.querySelector(
      '.busuanzi-footer-stats',
    ) as HTMLElement | null;

    if (!container || !loading || !stats) return;

    loading.classList.remove('busuanzi-footer-hidden');
    stats.classList.add('busuanzi-footer-hidden');
    container.style.display = '';

    const timeout = setTimeout(() => {
      container.style.display = 'none';
    }, 5000);

    const trigger =
      (window as any).__triggerBusuanziReload ??
      (() => Promise.reject(new Error('no busuanzi loader')));

    trigger()
      .then(() => {
        let attempts = 0;
        const poll = setInterval(() => {
          const pvEl = document.getElementById('busuanzi_site_pv');
          const uvEl = document.getElementById('busuanzi_site_uv');
          const pvReady =
            pvEl && pvEl.innerText && pvEl.innerText.trim() !== '';
          const uvReady =
            uvEl && uvEl.innerText && uvEl.innerText.trim() !== '';

          if (pvReady && uvReady) {
            clearInterval(poll);
            clearTimeout(timeout);
            loading.classList.add('busuanzi-footer-hidden');
            stats.classList.remove('busuanzi-footer-hidden');
          } else if (++attempts > 100) {
            clearInterval(poll);
            clearTimeout(timeout);
            container.style.display = 'none';
          }
        }, 50);
      })
      .catch(() => {
        clearTimeout(timeout);
        container.style.display = 'none';
      });
  }

  document.addEventListener('astro:page-load', initBusuanziFooter);
</script>

<style>
  .busuanzi-footer {
    margin-top: 0.75em;
    font-size: 0.8rem;
    color: rgb(var(--gray));
    text-align: center;
    transition: opacity 0.3s ease;
  }

  .busuanzi-footer-loading {
    display: inline-block;
    animation: busuanzi-footer-pulse 1.5s ease-in-out infinite;
  }

  .busuanzi-sep {
    margin: 0 0.4em;
    opacity: 0.5;
  }

  .busuanzi-footer-hidden {
    display: none !important;
  }

  @keyframes busuanzi-footer-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
</style>
