---
---

<button
  class="theme-toggle neu-btn"
  type="button"
  aria-label="切换到暗色模式"
>
  <!-- Sun icon (visible in dark mode) -->
  <svg class="icon icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <!-- Moon icon (visible in light mode) -->
  <svg class="icon icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.querySelector('.theme-toggle');
    if (!btn) return;

    function updateToggle(isDark: boolean) {
      const sunIcon = btn!.querySelector('.icon-sun') as HTMLElement;
      const moonIcon = btn!.querySelector('.icon-moon') as HTMLElement;
      if (isDark) {
        sunIcon.classList.add('active');
        moonIcon.classList.remove('active');
        btn!.setAttribute('aria-label', '切换到亮色模式');
      } else {
        sunIcon.classList.remove('active');
        moonIcon.classList.add('active');
        btn!.setAttribute('aria-label', '切换到暗色模式');
      }
    }

    // Set initial state
    updateToggle(document.documentElement.classList.contains('dark'));

    // Handle click
    btn.addEventListener('click', () => {
      if (typeof (window as any).__toggleTheme === 'function') {
        (window as any).__toggleTheme();
      }
    });

    // Listen for theme-change events (from ThemeManager or other sources)
    window.addEventListener('theme-change', ((e: CustomEvent) => {
      updateToggle(e.detail.theme === 'dark');
    }) as EventListener);
  }

  document.addEventListener('astro:page-load', initThemeToggle);
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.4em;
    height: 2.4em;
    border-radius: 50%;
    padding: 0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    color: rgb(var(--gray));
    background: var(--neu-bg);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: rgb(var(--gray-dark));
  }

  .icon {
    width: 1.15em;
    height: 1.15em;
    position: absolute;
    transition: transform 300ms ease, opacity 300ms ease;
  }

  /* Default state (light mode): moon visible, sun hidden */
  .icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0);
  }

  .icon-sun {
    opacity: 0;
    transform: rotate(90deg) scale(0);
  }

  /* Active icon is visible */
  .icon.active {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .icon {
      transition: none;
    }
  }
</style>
