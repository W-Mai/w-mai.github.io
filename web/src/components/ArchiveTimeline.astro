---
// Archive timeline sidebar widget — collapsible year/month groups with neumorphism depth
import type { YearGroup } from '~/lib/blog-archive'

interface Props {
  archives: YearGroup[]
}

const { archives } = Astro.props
if (archives.length === 0) return

const monthLabel = (m: number) => `${m}月`
---

<nav aria-label="Archive timeline">
  <h3 class="neu-section-title mb-3">
    归档
    <span class="neu-section-divider"></span>
  </h3>

  <div class="flex flex-col gap-2">
    {archives.map((group, i) => (
      <details open={i === 0} class="group">
        <summary
          class="neu-btn flex items-center gap-2 px-3 py-2 rounded-xl text-sm font-semibold
            cursor-pointer list-none select-none
            [&::-webkit-details-marker]:hidden"
        >
          <span class="text-[var(--text-muted)] text-xs transition-transform duration-200 group-open:rotate-90">
            ▶
          </span>
          <span class="text-[var(--text-heading)]">{group.year}</span>
        </summary>

        <div class="neu-inset-subtle rounded-xl mt-1.5 p-2">
          <ul class="flex flex-col gap-0.5 list-none">
            {group.months.map(({ month, count }) => (
              <li>
                <a
                  href={`/blog/archive/${group.year}/${month}/`}
                  class="flex items-center justify-between px-3 py-1.5 rounded-lg text-sm no-underline
                    transition-all duration-200 ease
                    hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
                    hover:-translate-y-px"
                >
                  <span class="text-[var(--text-primary)] text-sm">{monthLabel(month)}</span>
                  <span class="text-[var(--text-muted)] ml-2 text-xs font-medium tabular-nums">{count}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    ))}
  </div>
</nav>
