---
// Archive timeline sidebar widget — collapsible year/month groups with post counts
import type { YearGroup } from '~/lib/blog-archive'

interface Props {
  archives: YearGroup[]
}

const { archives } = Astro.props

// Do not render if no archives
if (archives.length === 0) return

// Chinese month names
const monthLabel = (m: number) => `${m}月`
---

<nav aria-label="Archive timeline">
  <!-- Section heading -->
  <h3 class="neu-section-title mb-3">
    归档
    <span class="neu-section-divider"></span>
  </h3>

  <div class="flex flex-col gap-1">
    {archives.map((group, i) => (
      <details open={i === 0} class="group">
        <summary
          class="text-[var(--text-heading)] flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-semibold
            cursor-pointer list-none select-none
            transition-all duration-200 ease
            hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
            hover:-translate-y-px
            [&::-webkit-details-marker]:hidden"
        >
          {/* Arrow indicator */}
          <span class="text-[var(--text-muted)] text-xs transition-transform duration-200 group-open:rotate-90">
            ▶
          </span>
          <span>{group.year}</span>
        </summary>

        <ul class="flex flex-col gap-0.5 mt-0.5 ml-3">
          {group.months.map(({ month, count }) => (
            <li>
              <a
                href={`/blog/archive/${group.year}/${month}/`}
                class="text-[var(--text-link)] block px-3 py-1.5 rounded-lg text-sm no-underline
                  transition-all duration-200 ease
                  hover:bg-[linear-gradient(145deg,var(--neu-gradient-light),var(--neu-gradient-dark))]
                  hover:text-[var(--text-link-hover)] hover:-translate-y-px"
              >
                <span class="flex items-center justify-between">
                  <span class="text-[var(--text-primary)] text-sm">
                    {monthLabel(month)}
                  </span>
                  <span class="text-[var(--text-muted)] ml-2 text-xs font-medium tabular-nums">
                    {count}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </div>
</nav>
