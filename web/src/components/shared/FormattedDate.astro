---
import { SITE_TZ_OFFSET } from '~/consts';

interface Props {
	date: Date;
}

const { date } = Astro.props;

// Shift UTC timestamp by site timezone offset to get display time,
// so the output is consistent regardless of build environment timezone.
const shifted = new Date(date.getTime() + SITE_TZ_OFFSET * 60 * 60 * 1000);

const pad2 = (n: number) => String(n).padStart(2, '0');
const hours = shifted.getUTCHours();
const minutes = shifted.getUTCMinutes();
const seconds = shifted.getUTCSeconds();
const year = shifted.getUTCFullYear();
const month = shifted.getUTCMonth();
const day = shifted.getUTCDate();
const time = `${pad2(hours)}:${pad2(minutes)}`;

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

const now = new Date();
const nowShifted = new Date(now.getTime() + SITE_TZ_OFFSET * 60 * 60 * 1000);
const sameYear = year === nowShifted.getUTCFullYear();
const sameDay = sameYear && month === nowShifted.getUTCMonth() && day === nowShifted.getUTCDate();

const display = sameDay
	? time
	: sameYear
		? `${MONTHS[month]} ${day} ${time}`
		: `${MONTHS[month]} ${day}, ${year} ${time}`;

const tzSign = SITE_TZ_OFFSET >= 0 ? '+' : '-';
const tzAbs = Math.abs(SITE_TZ_OFFSET);
const tz = `UTC${tzSign}${pad2(tzAbs)}:00`;
const full = `${MONTHS[month]} ${day}, ${year} ${time}:${pad2(seconds)} ${tz}`;
---

<time datetime={date.toISOString()} title={full}>
	{display}
</time>
