---
// Compact post card for homepage — hero image + title + date
import { Image } from 'astro:assets'
import BlogHeroFallback from './BlogHeroFallback.astro'
import FormattedDate from './FormattedDate.astro'

interface Props {
  id: string
  title: string
  pubDate: Date
  heroImage?: ImageMetadata | null
  description?: string
}

const { id, title, pubDate, heroImage, description } = Astro.props
const href = `/blog/${id}/`
---

<a href={href}
   class="recent-post-card neu-card neu-card-hover group block rounded-2xl overflow-hidden no-underline
          transition-all duration-300 ease-out">
  <div class="overflow-hidden h-32">
    {heroImage ? (
      <Image
        width={480} height={240}
        src={heroImage}
        alt=""
        class="card-cover-img"
      />
    ) : (
      <BlogHeroFallback title={title} class="transition-transform duration-700 ease-out group-hover:scale-105" />
    )}
  </div>
  <div class="px-3 py-2.5">
    <h3 class="text-sm font-semibold text-[var(--text-heading)] truncate m-0
               group-hover:text-[var(--text-heading)]">
      {title}
    </h3>
    {description && (
      <p class="text-[var(--text-secondary)] text-xs mt-1 m-0 line-clamp-1">{description}</p>
    )}
    <p class="text-[var(--text-muted)] text-xs mt-1 m-0">
      <FormattedDate date={pubDate} />
    </p>
  </div>
</a>

