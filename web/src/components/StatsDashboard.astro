---
import FormattedDate from './FormattedDate.astro'

interface Props {
  totalPosts: number
  totalWords: number
  averageWords: number
  earliestDate: Date
  latestDate: Date
}

const { totalPosts, totalWords, averageWords, earliestDate, latestDate } = Astro.props
---

<section class="neu-card neu-card-section anim-fade" style="--delay:3.5">
  <h2 class="neu-section-title mb-4 sm:mb-6">
    📊 写作统计
    <span class="neu-section-divider"></span>
  </h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 sm:gap-4">
    <!-- Total posts -->
    <div class="neu-stat-cell">
      <span class="stat-value">{totalPosts}</span>
      <span class="stat-label mt-1 block">怼了 {totalPosts} 篇文章</span>
    </div>

    <!-- Total words -->
    <div class="neu-stat-cell">
      <span class="stat-value">
        {totalWords >= 10000 ? `${(totalWords / 10000).toFixed(1)}万` : totalWords.toLocaleString()}
      </span>
      <span class="stat-label mt-1 block">共 {totalWords.toLocaleString()} 字</span>
    </div>

    <!-- Average words -->
    <div class="neu-stat-cell">
      <span class="stat-value">{averageWords.toLocaleString()}</span>
      <span class="stat-label mt-1 block">平均每篇 {averageWords.toLocaleString()} 字</span>
    </div>

    <!-- Site PV (busuanzi) -->
    <div class="neu-stat-cell">
      <span class="stat-value busuanzi-stats-value" id="stats_site_pv">-</span>
      <span class="stat-label mt-1 block">被怼了多少下儿</span>
    </div>

    <!-- Site UV (busuanzi) -->
    <div class="neu-stat-cell">
      <span class="stat-value busuanzi-stats-value" id="stats_site_uv">-</span>
      <span class="stat-label mt-1 block">多少老铁来过</span>
    </div>

    <!-- Date range (spans 2 cols on mobile) -->
    <div class="neu-stat-cell col-span-2 sm:col-span-1 md:col-span-2">
      <span class="block text-sm sm:text-base font-bold text-[var(--text-heading)]">
        <FormattedDate date={earliestDate} />
      </span>
      <span class="block text-[10px] sm:text-xs text-[var(--text-muted)]">~</span>
      <span class="block text-sm sm:text-base font-bold text-[var(--text-heading)]">
        <FormattedDate date={latestDate} />
      </span>
      <span class="stat-label mt-1 block">创作时间跨度</span>
    </div>
  </div>
</section>

<script>
  import { triggerReload } from '../lib/busuanzi-loader';

  function initStatsBusuanzi() {
    const pvEl = document.getElementById('stats_site_pv');
    const uvEl = document.getElementById('stats_site_uv');
    if (!pvEl || !uvEl) return;

    triggerReload().then(() => {
      let attempts = 0;
      const poll = setInterval(() => {
        // Read from the hidden busuanzi elements populated by the footer
        const srcPv = document.getElementById('busuanzi_site_pv');
        const srcUv = document.getElementById('busuanzi_site_uv');
        const pv = srcPv?.innerText?.trim() ?? '';
        const uv = srcUv?.innerText?.trim() ?? '';

        if (pv !== '' && /^\d+$/.test(pv) && uv !== '' && /^\d+$/.test(uv)) {
          clearInterval(poll);
          pvEl.textContent = Number(pv).toLocaleString();
          uvEl.textContent = Number(uv).toLocaleString();
        } else if (++attempts > 100) {
          clearInterval(poll);
        }
      }, 50);
    }).catch(() => {});
  }

  document.addEventListener('astro:page-load', initStatsBusuanzi);
</script>
