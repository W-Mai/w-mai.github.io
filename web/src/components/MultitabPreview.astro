---
// Tab keys supported (tab0 ~ tab10)
const TAB_KEYS = ['tab0','tab1','tab2','tab3','tab4','tab5','tab6','tab7','tab8','tab9','tab10'];

const slots = Astro.slots;
const labels: Record<string, string> = Astro.props.labels ?? {};
const syncKey: string | undefined = Astro.props.syncKey;

// Collect active tabs in order
const activeTabs = TAB_KEYS.filter(k => slots.has(k));
const hasPreview = slots.has('preview');
const hasTabs = activeTabs.length > 0;

// Unique ID for this instance to avoid conflicts when multiple on same page
const uid = Math.random().toString(36).slice(2, 8);
---

<div class="multitab-preview" data-sync-key={syncKey} data-uid={uid}>
  {hasTabs && (
    <div class="tab-bar" role="tablist">
      {activeTabs.map((key, i) => (
        <button
          role="tab"
          class:list={['tab-btn', { active: i === 0 }]}
          data-tab={key}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${uid}-${key}`}
          id={`tab-${uid}-${key}`}
        >
          {labels[key] ?? key}
        </button>
      ))}
    </div>
  )}

  {activeTabs.map((key, i) => (
    <div
      role="tabpanel"
      id={`panel-${uid}-${key}`}
      aria-labelledby={`tab-${uid}-${key}`}
      class:list={['tab-panel', { hidden: i !== 0 }]}
      data-tab={key}
    >
      {key === 'tab0' && <slot name="tab0" />}
      {key === 'tab1' && <slot name="tab1" />}
      {key === 'tab2' && <slot name="tab2" />}
      {key === 'tab3' && <slot name="tab3" />}
      {key === 'tab4' && <slot name="tab4" />}
      {key === 'tab5' && <slot name="tab5" />}
      {key === 'tab6' && <slot name="tab6" />}
      {key === 'tab7' && <slot name="tab7" />}
      {key === 'tab8' && <slot name="tab8" />}
      {key === 'tab9' && <slot name="tab9" />}
      {key === 'tab10' && <slot name="tab10" />}
    </div>
  ))}

  {!hasTabs && <slot />}

  {hasPreview && (
    <div class="preview-panel">
      <span class="preview-label">Output</span>
      <div class="preview-content">
        <slot name="preview" />
      </div>
    </div>
  )}
</div>

<style>
  .multitab-preview {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    background: #fff;
    margin: 1.5rem 0;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  /* Tab bar */
  .tab-bar {
    display: flex;
    gap: 0;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tab-bar::-webkit-scrollbar { display: none; }

  .tab-btn {
    padding: 0.6rem 1.1rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #64748b;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
    font-family: inherit;
  }
  .tab-btn:hover { color: #1e293b; }
  .tab-btn.active {
    color: #1e293b;
    border-bottom-color: #334155;
    background: #fff;
  }

  /* Tab panels */
  .tab-panel { display: block; }
  .tab-panel.hidden { display: none; }

  /* Strip top margin from first child inside panel (code blocks) */
  .tab-panel :global(> *:first-child),
  .tab-panel :global(.expressive-code:first-child) {
    margin-top: 0 !important;
    border-radius: 0 !important;
  }

  /* Preview section */
  .preview-panel {
    border-top: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .preview-label {
    display: block;
    padding: 0.4rem 1rem 0;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
  }
  .preview-content :global(> *:first-child),
  .preview-content :global(.expressive-code:first-child) {
    margin-top: 0 !important;
    border-radius: 0 !important;
    border-top: none !important;
  }
</style>

<script>
  // Tab switching logic — runs once per component instance
  document.querySelectorAll<HTMLElement>('.multitab-preview').forEach(container => {
    const uid = container.dataset.uid;
    const syncKey = container.dataset.syncKey;

    container.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab!;

        // Update buttons
        container.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(b => {
          b.classList.toggle('active', b.dataset.tab === target);
          b.setAttribute('aria-selected', b.dataset.tab === target ? 'true' : 'false');
        });

        // Update panels
        container.querySelectorAll<HTMLElement>('.tab-panel').forEach(p => {
          p.classList.toggle('hidden', p.dataset.tab !== target);
        });

        // Sync other instances with same syncKey
        if (syncKey) {
          document.querySelectorAll<HTMLElement>(`.multitab-preview[data-sync-key="${syncKey}"]`).forEach(other => {
            if (other === container) return;
            other.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(b => {
              b.classList.toggle('active', b.dataset.tab === target);
              b.setAttribute('aria-selected', b.dataset.tab === target ? 'true' : 'false');
            });
            other.querySelectorAll<HTMLElement>('.tab-panel').forEach(p => {
              p.classList.toggle('hidden', p.dataset.tab !== target);
            });
          });
        }
      });
    });
  });
</script>
