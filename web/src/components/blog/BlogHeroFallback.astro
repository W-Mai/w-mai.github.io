---
/**
 * Fallback hero image generated from post title.
 * Uses gradient background with geometric decorations,
 * similar to FeaturedProjectCard's no-banner style.
 */
interface Props {
	title: string;
	class?: string;
}

const { title, class: className } = Astro.props;

// Generate hue from title characters
const hue = title.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % 360;
const gradient = `linear-gradient(135deg, hsl(${hue}, 55%, 92%) 0%, hsl(${hue + 30}, 45%, 87%) 50%, hsl(${hue + 60}, 35%, 90%) 100%)`;
const accentColor = `hsl(${hue}, 50%, 60%)`;

// Pick an emoji based on hue range
const emojis = ['📝', '💡', '🚀', '🔧', '📚', '🎯', '⚡', '🌟', '🔍', '💻', '🎨', '🧩'];
const emoji = emojis[Math.floor(hue / 30) % emojis.length];
---

<div
	class:list={['blog-hero-fallback', className]}
	style={`background: ${gradient}; position: relative; overflow: hidden; width: 100%; height: 100%;`}
>
	{/* Geometric circles */}
	<div
		class="absolute top-4 right-6 size-28 rounded-full opacity-15"
		style={`background: ${accentColor}`}
	/>
	<div
		class="absolute -bottom-8 -left-8 size-36 rounded-full opacity-10"
		style={`background: ${accentColor}`}
	/>
	<div
		class="absolute top-1/2 right-1/4 size-16 rounded-full opacity-10"
		style={`background: ${accentColor}`}
	/>

	{/* Center content */}
	<div class="absolute inset-0 flex flex-col items-center justify-center gap-2 px-8">
		<span class="text-4xl select-none">{emoji}</span>
		<span
			class="text-center font-bold select-none leading-tight max-w-[80%] line-clamp-2"
			style={`color: hsl(${hue}, 40%, 35%); font-size: clamp(0.9rem, 2.5vw, 1.3rem);`}
		>
			{title}
		</span>
	</div>

	{/* Subtle pattern overlay */}
	<div class="absolute inset-0 opacity-[0.03]"
		style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 20px 20px;"
	/>
</div>
