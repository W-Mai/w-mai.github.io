---
// Reading settings toolbar — circular neumorphism buttons above TOC
---

<div class="reading-settings">
  <button
    id="rs-font-toggle"
    class="neu-rs-btn"
    aria-label="Toggle pixel font"
    title="切换像素字体"
  >
    <span class="neu-rs-icon">Aa</span>
  </button>

  <button
    id="rs-serif-toggle"
    class="neu-rs-btn"
    aria-label="Toggle serif font"
    title="切换衬线体"
  >
    <span class="neu-rs-icon" style="font-family: serif; font-style: italic;">Se</span>
  </button>

  <button
    id="rs-zen-mode"
    class="neu-rs-btn"
    aria-label="Toggle zen reading mode"
    title="纯阅读模式"
  >
    <span class="neu-rs-icon">📖</span>
  </button>

  <button
    id="rs-scroll-top"
    class="neu-rs-btn"
    aria-label="Scroll to top"
    title="回到顶部"
  >
    <span class="neu-rs-icon">↑</span>
  </button>
</div>

<script>
  function initReadingSettings() {
    // Both desktop aside and mobile drawer have copies — bind all instances
    const fontToggles = document.querySelectorAll<HTMLButtonElement>('[id="rs-font-toggle"]')
    const serifToggles = document.querySelectorAll<HTMLButtonElement>('[id="rs-serif-toggle"]')
    const zenModes = document.querySelectorAll<HTMLButtonElement>('[id="rs-zen-mode"]')
    const scrollTops = document.querySelectorAll<HTMLButtonElement>('[id="rs-scroll-top"]')
    if (fontToggles.length === 0) return

    const FONT_KEY = 'rs-font-mode'
    const ZEN_KEY = 'rs-zen-mode'

    type FontMode = 'pixel' | 'sans' | 'serif'
    let fontMode = (localStorage.getItem(FONT_KEY) || 'pixel') as FontMode
    let zenActive = localStorage.getItem(ZEN_KEY) === 'on'

    function applyFontMode(mode: FontMode) {
      fontMode = mode
      const html = document.documentElement
      html.classList.remove('no-pixel-font', 'serif-font')
      fontToggles.forEach(b => b.classList.remove('neu-rs-active'))
      serifToggles.forEach(b => b.classList.remove('neu-rs-active'))

      if (mode === 'sans') {
        html.classList.add('no-pixel-font')
        fontToggles.forEach(b => b.classList.add('neu-rs-active'))
      } else if (mode === 'serif') {
        html.classList.add('no-pixel-font', 'serif-font')
        serifToggles.forEach(b => b.classList.add('neu-rs-active'))
      }
      localStorage.setItem(FONT_KEY, mode)
    }

    function applyZenMode(active: boolean) {
      zenActive = active
      document.documentElement.classList.toggle('zen-mode', active)
      zenModes.forEach(b => b.classList.toggle('neu-rs-active', active))
      const exitBtn = document.getElementById('rs-zen-exit')
      exitBtn?.classList.toggle('neu-rs-zen-exit-visible', active)
      localStorage.setItem(ZEN_KEY, active ? 'on' : 'off')
    }

    applyFontMode(fontMode)
    applyZenMode(zenActive)

    fontToggles.forEach(b => b.addEventListener('click', () => {
      applyFontMode(fontMode === 'sans' ? 'pixel' : 'sans')
    }))

    serifToggles.forEach(b => b.addEventListener('click', () => {
      applyFontMode(fontMode === 'serif' ? 'pixel' : 'serif')
    }))

    zenModes.forEach(b => b.addEventListener('click', () => applyZenMode(!zenActive)))
    document.getElementById('rs-zen-exit')?.addEventListener('click', () => applyZenMode(false))

    scrollTops.forEach(b => b.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' })
    }))

    // ESC exits zen mode
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && zenActive) {
        applyZenMode(false)
      }
    })
  }

  document.addEventListener('astro:page-load', initReadingSettings)
</script>
