---
import TagChip from './TagChip.astro'
import FormattedDate from './FormattedDate.astro'
import { renderInlineMarkdown } from '../lib/markdown'
import type { Thought } from '../data/thoughts'

interface Props {
  thought: Thought
  isEditorMode?: boolean
}

const { thought, isEditorMode = false } = Astro.props
const html = renderInlineMarkdown(thought.content)
const date = new Date(thought.createdAt)
---

<div class="neu-card rounded-[2rem] p-5 sm:p-6">
  <div class="thought-content text-[var(--text-primary)] text-sm sm:text-base leading-relaxed" set:html={html} />

  <div class="flex items-center justify-between mt-3 gap-2">
    {thought.mood ? (
      <div class="neu-mood-time">
        <span class="neu-mood-badge">{thought.mood}</span>
        <span class="neu-time-pill"><FormattedDate date={date} /></span>
      </div>
    ) : (
      <span class="neu-time-pill"><FormattedDate date={date} /></span>
    )}

    <div class="flex items-center gap-1.5">
      {thought.tags && thought.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {thought.tags.map((tag) => (
            <TagChip tag={tag} interactive={false} />
          ))}
        </div>
      )}

      {isEditorMode && (
        <div class="flex gap-1 ml-2">
          <button
            class="neu-btn px-2 py-0.5 text-xs cursor-pointer"
            data-thought-edit={JSON.stringify(thought)}
            title="Edit"
          >✏️</button>
          <button
            class="neu-btn px-2 py-0.5 text-xs cursor-pointer"
            data-thought-delete={thought.id}
            title="Delete"
          >🗑️</button>
        </div>
      )}
    </div>
  </div>
</div>
