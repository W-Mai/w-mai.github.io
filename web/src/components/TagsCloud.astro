---
// Popular tags cloud — inset container with tag chips
import TagChip from './TagChip.astro'

interface Props {
  tags: Array<{ tag: string; count: number }>
}

const { tags } = Astro.props
if (tags.length === 0) return

const top = tags.slice(0, 12)
---

<nav aria-label="Popular tags">
  <h3 class="neu-section-title mb-3">
    标签
    <span class="neu-section-divider"></span>
  </h3>

  <div class="neu-inset-subtle rounded-xl p-3">
    <div class="flex flex-wrap gap-2">
      {top.map(({ tag }) => (
        <TagChip tag={tag} />
      ))}
    </div>
  </div>
</nav>
