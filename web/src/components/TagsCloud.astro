---
// Popular tags cloud — displays top 12 tags as clickable chips
import TagChip from './TagChip.astro'

interface Props {
  tags: Array<{ tag: string; count: number }>
}

const { tags } = Astro.props

// Do not render if no tags
if (tags.length === 0) return

// Take top 12 (assume pre-sorted by count descending from caller)
const top = tags.slice(0, 12)
---

<nav aria-label="Popular tags">
  <!-- Section heading -->
  <h3 class="neu-section-title mb-3">
    标签
    <span class="neu-section-divider"></span>
  </h3>

  <div class="flex flex-wrap gap-2">
    {top.map(({ tag }) => (
      <TagChip tag={tag} />
    ))}
  </div>
</nav>
