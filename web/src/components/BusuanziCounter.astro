---
// Busuanzi page view counter (v3.6.9) — self-hosted script with fetch API.
// Displays per-page PV with loading/error states.
---
<span class="busuanzi-pv-counter" aria-label="Page views">
  <span class="busuanzi-pv-loading"><span class="busuanzi-dot">·</span> 加载中...</span>
  <span class="busuanzi-pv-value busuanzi-hidden"><span class="busuanzi-dot">·</span> 被怼了 <span id="busuanzi_page_pv"></span> 下儿</span>
</span>

<script>
  function loadBusuanzi(): Promise<void> {
    return new Promise<void>((resolve, reject) => {
      // Reset the guard flag so the script re-executes on SPA navigation
      (window as any).busuanziRequestSent = false;

      // Remove previous script tag
      const old = document.getElementById('busuanzi-script');
      if (old) old.remove();

      const script = document.createElement('script');
      script.id = 'busuanzi-script';
      script.src = '/busuanzi.min.js';
      script.async = true;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('busuanzi script failed'));
      document.head.appendChild(script);
    });
  }

  // Shared reload state
  (window as any).__busuanziReloadPromise = null as Promise<void> | null;

  function triggerBusuanziReload(): Promise<void> {
    if (!(window as any).__busuanziReloadPromise) {
      (window as any).__busuanziReloadPromise = loadBusuanzi().finally(() => {
        (window as any).__busuanziReloadPromise = null;
      });
    }
    return (window as any).__busuanziReloadPromise;
  }

  (window as any).__triggerBusuanziReload = triggerBusuanziReload;

  function initBusuanziCounter() {
    const container = document.querySelector(
      '.busuanzi-pv-counter',
    ) as HTMLElement | null;
    const loading = container?.querySelector(
      '.busuanzi-pv-loading',
    ) as HTMLElement | null;
    const value = container?.querySelector(
      '.busuanzi-pv-value',
    ) as HTMLElement | null;

    if (!container || !loading || !value) return;

    loading.classList.remove('busuanzi-hidden');
    value.classList.add('busuanzi-hidden');
    container.style.display = '';

    const timeout = setTimeout(() => {
      container.style.display = 'none';
    }, 5000);

    triggerBusuanziReload()
      .then(() => {
        let attempts = 0;
        const poll = setInterval(() => {
          const pvEl = document.getElementById('busuanzi_page_pv');
          const pvText = pvEl?.innerText?.trim() ?? '';
          if (pvText !== '' && /^\d+$/.test(pvText)) {
            clearInterval(poll);
            clearTimeout(timeout);
            loading.classList.add('busuanzi-hidden');
            value.classList.remove('busuanzi-hidden');
          } else if (++attempts > 100) {
            clearInterval(poll);
            clearTimeout(timeout);
            container.style.display = 'none';
          }
        }, 50);
      })
      .catch(() => {
        clearTimeout(timeout);
        container.style.display = 'none';
      });
  }

  document.addEventListener('astro:page-load', initBusuanziCounter);
</script>

<style>
  .busuanzi-pv-counter {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    color: rgb(148 163 184);
    transition: opacity 0.3s ease;
  }

  .busuanzi-pv-loading {
    display: inline-block;
    animation: busuanzi-pv-pulse 1.5s ease-in-out infinite;
  }

  .busuanzi-hidden {
    display: none !important;
  }

  @keyframes busuanzi-pv-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
</style>
