---
// Busuanzi page view counter — displays per-page PV with loading/error states.
// Reloads busuanzi script on each page navigation to get fresh data.
---
<span class="busuanzi-pv-counter" aria-label="Page views">
  <span class="busuanzi-pv-loading">加载中...</span>
  <span class="busuanzi-pv-value busuanzi-hidden">被怼了 <span id="busuanzi_value_page_pv"></span> 下儿</span>
</span>

<script>
  /**
   * Load (or reload) the busuanzi script. Returns a promise that resolves
   * once the script's onload fires. Each call removes the old script tag
   * and injects a fresh one so busuanzi re-fetches data for the current page.
   */
  function reloadBusuanziScript(): Promise<void> {
    return new Promise<void>((resolve, reject) => {
      // Remove previous script so busuanzi re-executes its JSONP request
      const old = document.getElementById('busuanzi-script');
      if (old) old.remove();

      // Clear previous values so poll doesn't see stale data
      const ids = [
        'busuanzi_value_page_pv',
        'busuanzi_value_site_pv',
        'busuanzi_value_site_uv',
      ];
      for (const id of ids) {
        const el = document.getElementById(id);
        if (el) el.textContent = '';
      }

      const script = document.createElement('script');
      script.id = 'busuanzi-script';
      script.src =
        '//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
      script.async = true;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('busuanzi script failed'));
      document.head.appendChild(script);
    });
  }

  // Expose globally so BusuanziFooter can share the same reload
  (window as any).__reloadBusuanziScript = reloadBusuanziScript;
  // Track whether a reload is already in progress to avoid double-loading
  (window as any).__busuanziReloadPromise = null as Promise<void> | null;

  function triggerBusuanziReload(): Promise<void> {
    if (!(window as any).__busuanziReloadPromise) {
      (window as any).__busuanziReloadPromise = reloadBusuanziScript().finally(
        () => {
          (window as any).__busuanziReloadPromise = null;
        },
      );
    }
    return (window as any).__busuanziReloadPromise;
  }

  // Also expose the trigger
  (window as any).__triggerBusuanziReload = triggerBusuanziReload;

  function initBusuanziCounter() {
    const container = document.querySelector(
      '.busuanzi-pv-counter',
    ) as HTMLElement | null;
    const loading = container?.querySelector(
      '.busuanzi-pv-loading',
    ) as HTMLElement | null;
    const value = container?.querySelector(
      '.busuanzi-pv-value',
    ) as HTMLElement | null;

    if (!container || !loading || !value) return;

    // Reset visibility
    loading.classList.remove('busuanzi-hidden');
    value.classList.add('busuanzi-hidden');
    container.style.display = '';

    const timeout = setTimeout(() => {
      container.style.display = 'none';
    }, 5000);

    triggerBusuanziReload()
      .then(() => {
        let attempts = 0;
        const poll = setInterval(() => {
          const pvEl = document.getElementById('busuanzi_value_page_pv');
          if (pvEl && pvEl.textContent && pvEl.textContent.trim() !== '') {
            clearInterval(poll);
            clearTimeout(timeout);
            loading.classList.add('busuanzi-hidden');
            value.classList.remove('busuanzi-hidden');
          } else if (++attempts > 100) {
            clearInterval(poll);
            clearTimeout(timeout);
            container.style.display = 'none';
          }
        }, 50);
      })
      .catch(() => {
        clearTimeout(timeout);
        container.style.display = 'none';
      });
  }

  document.addEventListener('astro:page-load', initBusuanziCounter);
</script>

<style>
  .busuanzi-pv-counter {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    color: rgb(148 163 184);
    transition: opacity 0.3s ease;
  }

  .busuanzi-pv-loading {
    display: inline-block;
    animation: busuanzi-pv-pulse 1.5s ease-in-out infinite;
  }

  .busuanzi-hidden {
    display: none !important;
  }

  @keyframes busuanzi-pv-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
</style>
