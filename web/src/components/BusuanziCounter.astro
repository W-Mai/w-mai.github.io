---
// Busuanzi page view counter — displays per-page PV with loading/error states.
// Shares script loading with BusuanziFooter via a global promise.
---
<span class="busuanzi-pv-counter" aria-label="Page views">
  <span class="busuanzi-pv-loading">加载中...</span>
  <span class="busuanzi-pv-value busuanzi-hidden">被怼了 <span id="busuanzi_value_page_pv"></span> 下儿</span>
</span>

<script>
  function loadBusuanziScript(): Promise<void> {
    // Reuse a single global promise so the script is loaded exactly once
    if ((window as any).__busuanziPromise) return (window as any).__busuanziPromise;

    (window as any).__busuanziPromise = new Promise<void>((resolve, reject) => {
      // If script tag already exists and loaded, resolve immediately
      const existing = document.getElementById('busuanzi-script') as HTMLScriptElement | null;
      if (existing) {
        resolve();
        return;
      }

      const script = document.createElement('script');
      script.id = 'busuanzi-script';
      script.src = '//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
      script.async = true;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('busuanzi script failed'));
      document.head.appendChild(script);
    });

    return (window as any).__busuanziPromise;
  }

  function initBusuanziCounter() {
    const container = document.querySelector('.busuanzi-pv-counter') as HTMLElement | null;
    const loading = container?.querySelector('.busuanzi-pv-loading') as HTMLElement | null;
    const value = container?.querySelector('.busuanzi-pv-value') as HTMLElement | null;

    if (!container || !loading || !value) return;

    // Reset state for SPA navigation
    loading.classList.remove('busuanzi-hidden');
    value.classList.add('busuanzi-hidden');
    container.style.display = '';

    const timeout = setTimeout(() => {
      container.style.display = 'none';
    }, 5000);

    loadBusuanziScript()
      .then(() => {
        let attempts = 0;
        const poll = setInterval(() => {
          const pvEl = document.getElementById('busuanzi_value_page_pv');
          if (pvEl && pvEl.textContent && pvEl.textContent.trim() !== '') {
            clearInterval(poll);
            clearTimeout(timeout);
            loading.classList.add('busuanzi-hidden');
            value.classList.remove('busuanzi-hidden');
          } else if (++attempts > 50) {
            clearInterval(poll);
            clearTimeout(timeout);
            container.style.display = 'none';
          }
        }, 50);
      })
      .catch(() => {
        clearTimeout(timeout);
        container.style.display = 'none';
      });
  }

  // Expose loader globally so BusuanziFooter can reuse it
  (window as any).__loadBusuanziScript = loadBusuanziScript;

  document.addEventListener('astro:page-load', initBusuanziCounter);
</script>

<style>
  .busuanzi-pv-counter {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    color: rgb(148 163 184);
    transition: opacity 0.3s ease;
  }

  .busuanzi-pv-loading {
    display: inline-block;
    animation: busuanzi-pv-pulse 1.5s ease-in-out infinite;
  }

  .busuanzi-hidden {
    display: none !important;
  }

  @keyframes busuanzi-pv-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
</style>
