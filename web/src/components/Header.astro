---
import {SITE_TITLE, SOCIALS} from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';

const isEditorMode = import.meta.env.DEV && import.meta.env.EDITOR_MODE;

// Dropdown items with path → label mapping
const moreItems = [
	{ href: '/gamev1.8', label: '🎮 不大点儿游戏' },
	{ href: '/rss.xml', label: '📡 RSS', target: '_blank' },
];
// Items that collapse into dropdown on small screens
const collapseItems = [
	{ href: '/stats', label: '📊 统计' },
	{ href: '/friends', label: '🤝 友链' },
	{ href: '/thoughts', label: '🧠 想法' },
];
const allDropdownItems = [...collapseItems, ...moreItems];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const activeMore = moreItems.find(item => pathname === item.href || pathname.startsWith(item.href + '/'));
const moreBtnLabel = activeMore ? activeMore.label : '瞅瞅';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="tab-bar">
			<HeaderLink href="/">🏠 当门</HeaderLink>
			<HeaderLink href="/blog">✍️ 怼点文章</HeaderLink>
			<HeaderLink href="/about">🙋 自个儿</HeaderLink>
			{collapseItems.map(item => (
				<span class="hide-mobile"><HeaderLink href={item.href}>{item.label}</HeaderLink></span>
			))}
			{isEditorMode && <HeaderLink href="/admin/live-editor">✏️ 编辑器</HeaderLink>}
			<div class="more-menu">
				<button class="more-btn" aria-expanded="false" aria-haspopup="true" class:list={[{ active: !!activeMore }]}>
					<span class="more-label">{moreBtnLabel}</span> <span class="more-arrow">▾</span>
				</button>
				<div class="more-dropdown" role="menu">
					{collapseItems.map(item => (
						<a href={item.href} role="menuitem" class="show-mobile">{item.label}</a>
					))}
					{moreItems.map(item => (
						<a href={item.href} role="menuitem" target={item.target}>{item.label}</a>
					))}
				</div>
			</div>
		</div>
		<div class="social-links">
			<ThemeToggle />
			<div class="social-capsule neu-btn">
				{
					SOCIALS.map((social) => (
						<a href={social.url} target="_blank" class="social-icon">
							<span class="sr-only">{social.description}</span>
							<img src={social.icon} alt={social.description} />
						</a>
					))
				}
			</div>
		</div>
	</nav>
</header>

<script>
	function initHeaderMenu() {
		const btn = document.querySelector('.more-btn');
		const dropdown = document.querySelector('.more-dropdown');
		if (btn && dropdown) {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				const expanded = btn.getAttribute('aria-expanded') === 'true';
				btn.setAttribute('aria-expanded', String(!expanded));
				dropdown.classList.toggle('show');
			});
			document.addEventListener('click', () => {
				btn.setAttribute('aria-expanded', 'false');
				dropdown.classList.remove('show');
			});
		}
	}
	document.addEventListener('astro:page-load', initHeaderMenu)
</script>
<style>
	header {
		margin: 0;
		padding: 1em 2em;
		background: var(--bg-surface-glass);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	header::after {
		content: '';
		position: absolute;
		top: 100%;
		left: 5%;
		right: 5%;
		height: 12px;
		background: radial-gradient(ellipse at top center, rgba(163,177,198,0.3) 0%, transparent 70%);
		z-index: -1;
		pointer-events: none;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: rgb(var(--gray-dark));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
	}

	/* Tab bar — inset capsule container */
	.tab-bar {
		display: inline-flex;
		align-items: center;
		gap: 0.25em;
		padding: 0.4em;
		border-radius: 9999px;
		box-shadow: inset 2px 2px 5px var(--neu-shadow-dark-strong),
		            inset -2px -2px 5px var(--neu-shadow-light-strong);
	}
	/* Tab links — flat default, gradient hover, reverse gradient active */
	.tab-bar :global(a) {
		padding: 0.45em 1.1em;
		color: rgb(var(--gray));
		text-decoration: none;
		border-radius: 9999px;
		font-size: 0.85em;
		font-weight: 500;
		transition: background 200ms ease, box-shadow 200ms ease, color 200ms ease, transform 200ms ease;
		white-space: nowrap;
		border: none;
		background: transparent;
		box-shadow: none;
	}
	.tab-bar :global(a:hover) {
		color: rgb(var(--gray-dark));
		background: linear-gradient(145deg, var(--neu-gradient-light), var(--neu-gradient-dark));
		transform: translateY(-1px);
	}
	/* Active tab — reverse gradient inset */
	.tab-bar :global(a.active) {
		color: rgb(var(--black));
		font-weight: 700;
		text-decoration: none;
		background: linear-gradient(145deg, var(--neu-gradient-dark), var(--neu-gradient-light));
		box-shadow: inset 2px 2px 4px var(--neu-shadow-dark-strong),
		            inset -2px -2px 4px var(--neu-shadow-light-strong);
	}

	/* Social links */
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.6em;
	}
	/* Social capsule: pill container for all social icons */
	.social-capsule {
		display: flex;
		align-items: center;
		gap: 0.15em;
		padding: 0.3em 0.5em;
		border-radius: 9999px;
	}
	.social-capsule .social-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.8em;
		height: 1.8em;
		border-radius: 50%;
		transition: background 0.2s ease;
	}
	.social-capsule .social-icon:hover {
		background: var(--hover-bg);
	}
	.social-capsule :global(img) {
		width: 1em;
		height: 1em;
		border-radius: 0;
	}

	/* More dropdown menu */
	.more-menu {
		position: relative;
		display: inline-flex;
		align-items: center;
	}
	.more-btn {
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.45em 1em;
		font-size: 0.85em;
		font-family: inherit;
		font-weight: 500;
		color: rgb(var(--gray));
		display: inline-flex;
		align-items: center;
		gap: 0.25em;
		border-radius: 9999px;
		line-height: inherit;
		transition: background 200ms ease, box-shadow 200ms ease, color 200ms ease, transform 200ms ease;
		white-space: nowrap;
		box-shadow: none;
	}
	.more-btn:hover {
		color: rgb(var(--gray-dark));
		background: linear-gradient(145deg, var(--neu-gradient-light), var(--neu-gradient-dark));
		transform: translateY(-1px);
	}
	.more-arrow {
		font-size: 0.7em;
		transition: transform 0.2s ease;
	}
	.more-btn[aria-expanded="true"] .more-arrow {
		transform: rotate(180deg);
	}
	.more-btn[aria-expanded="true"],
	.more-btn.active {
		background: linear-gradient(145deg, var(--neu-gradient-dark), var(--neu-gradient-light));
		box-shadow: inset 2px 2px 4px var(--neu-shadow-dark-strong),
		            inset -2px -2px 4px var(--neu-shadow-light-strong);
		transform: translateY(0);
	}
	.more-btn.active {
		color: rgb(var(--black));
		font-weight: 700;
	}
	.more-dropdown {
		position: absolute;
		top: calc(100% + 0.5em);
		right: 0;
		background: var(--neu-bg);
		border-radius: 1.25rem;
		box-shadow: 6px 6px 12px var(--neu-shadow-dark), -6px -6px 12px var(--neu-shadow-light);
		min-width: 11rem;
		padding: 0.4rem;
		gap: 0.2rem;
		z-index: 50;
		display: flex;
		flex-direction: column;
		opacity: 0;
		transform: translateY(-8px) scale(0.96);
		pointer-events: none;
		transition: opacity 200ms ease, transform 200ms ease;
	}
	.more-dropdown.show {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}
	.more-dropdown a {
		padding: 0.6em 1em;
		border-bottom: none;
		border-radius: 9999px;
		font-size: 0.85em;
		white-space: nowrap;
		color: rgb(var(--gray));
		background: transparent;
		box-shadow: none;
		transition: background 200ms ease, color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
	}
	.more-dropdown a:hover {
		color: rgb(var(--gray-dark));
		background: linear-gradient(145deg, var(--neu-gradient-light), var(--neu-gradient-dark));
		transform: translateY(-1px);
	}
	.more-dropdown a:active {
		background: linear-gradient(145deg, var(--neu-gradient-dark), var(--neu-gradient-light));
		box-shadow: inset 2px 2px 4px var(--neu-shadow-dark-strong),
		            inset -2px -2px 4px var(--neu-shadow-light-strong);
		transform: translateY(0);
	}

	/* Responsive visibility for extra tabs */
	.hide-mobile { display: contents; }
	.show-mobile { display: none; }

	@media (max-width: 1080px) {
		.hide-mobile { display: none; }
		.show-mobile { display: block; }
	}

	@media (max-width: 860px) {
		.social-links .social-capsule {
			display: none;
		}
	}

	@media (max-width: 720px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5em;
			position: relative;
		}
		h2 {
			width: 100%;
			text-align: center;
		}
		.tab-bar {
			justify-content: center;
		}
		.social-links {
			position: absolute;
			top: 0;
			right: 0;
		}
	}
	@media (max-width: 440px) {
		header {
			padding: 0.5em 0.75em;
		}
		.tab-bar :global(a),
		.more-btn {
			padding: 0.3em 0.6em;
			font-size: 0.75em;
		}
		h2 {
			font-size: 0.8em;
		}
	}
	@media (max-width: 400px) {
		header {
			padding: 0.5em 0.75em;
		}
		.tab-bar {
			gap: 0.1em;
			padding: 0.3em;
		}
		.tab-bar :global(a),
		.more-btn {
			padding: 0.25em 0.4em;
			font-size: 0.7em;
		}
		h2 {
			font-size: 0.75em;
		}
	}

	/* Dark mode overrides */
	:global(html.dark) header::after {
		background: radial-gradient(ellipse at top center, rgba(0,0,0,0.3) 0%, transparent 70%);
	}
	:global(html.dark) .more-dropdown a:hover {
		box-shadow: inset 1px 1px 3px var(--neu-shadow-dark), inset -1px -1px 3px var(--neu-shadow-light);
	}
	.social-capsule :global(img) {
		filter: invert(var(--icon-invert));
	}
</style>
