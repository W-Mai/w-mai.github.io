---
import {SITE_TITLE, SOCIALS} from '../consts';
import HeaderLink from './HeaderLink.astro';

const isEditorMode = import.meta.env.DEV && import.meta.env.EDITOR_MODE;
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="tab-bar">
			<HeaderLink href="/">当门</HeaderLink>
			<HeaderLink href="/blog">怼点文章</HeaderLink>
			<HeaderLink href="/about">自个儿</HeaderLink>
			{isEditorMode && <HeaderLink href="/admin/live-editor">✏️ 编辑器</HeaderLink>}
			<div class="more-menu">
				<button class="more-btn" aria-expanded="false" aria-haspopup="true">
					瞅瞅 <span class="more-arrow">▾</span>
				</button>
				<div class="more-dropdown" role="menu">
					<a href="/stats" role="menuitem">📊 统计</a>
					<a href="/gamev1.8" role="menuitem">🎮 不大点儿游戏</a>
					<a href="/rss.xml" target="_blank" role="menuitem">📡 RSS</a>
				</div>
			</div>
		</div>
		<div class="social-links">
            {
                SOCIALS.map((social) => (
                    <a href={social.url} target="_blank" class="social-icon">
                        <span class="sr-only">{social.description}</span>
                        <img src={social.icon} alt={social.description} />
                    </a>
                ))
            }
		</div>
	</nav>
</header>

<script>
	function initHeaderMenu() {
		const btn = document.querySelector('.more-btn');
		const dropdown = document.querySelector('.more-dropdown');
		if (btn && dropdown) {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				const expanded = btn.getAttribute('aria-expanded') === 'true';
				btn.setAttribute('aria-expanded', String(!expanded));
				dropdown.classList.toggle('show');
			});
			document.addEventListener('click', () => {
				btn.setAttribute('aria-expanded', 'false');
				dropdown.classList.remove('show');
			});
		}
	}
	document.addEventListener('astro:page-load', initHeaderMenu)
</script>
<style>
	header {
		margin: 0;
		padding: 1em 2em;
		background: rgba(224, 229, 236, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	header::after {
		content: '';
		position: absolute;
		top: 100%;
		left: 5%;
		right: 5%;
		height: 12px;
		background: radial-gradient(ellipse at top center, rgba(163,177,198,0.3) 0%, transparent 70%);
		z-index: -1;
		pointer-events: none;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: rgb(var(--gray-dark));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
	}

	/* Tab bar — flat container, tabs are individual buttons */
	.tab-bar {
		display: flex;
		align-items: center;
		gap: 0.6em;
	}
	/* Tab links — raised pill buttons */
	.tab-bar :global(a) {
		padding: 0.5em 1.2em;
		color: rgb(var(--gray));
		text-decoration: none;
		border-radius: 0.85rem;
		font-size: 0.85em;
		font-weight: 500;
		transition: all 0.2s ease;
		white-space: nowrap;
		border: none;
		background: var(--neu-bg);
		box-shadow: 3px 3px 6px rgb(163 177 198 / 0.5), -3px -3px 6px rgb(255 255 255 / 0.4);
	}
	.tab-bar :global(a:hover) {
		color: rgb(var(--gray-dark));
		box-shadow: 1px 1px 3px rgb(163 177 198 / 0.4), -1px -1px 3px rgb(255 255 255 / 0.3);
	}
	/* Active tab — pressed inset effect */
	.tab-bar :global(a.active) {
		color: rgb(var(--black));
		font-weight: 700;
		text-decoration: none;
		background: var(--neu-bg);
		box-shadow: inset 2px 2px 5px rgb(163 177 198 / 0.6), inset -2px -2px 5px rgb(255 255 255 / 0.7);
	}

	/* Social links */
	.social-links {
		display: flex;
		gap: 0.25em;
	}
	.social-links :global(a) {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.2em;
		height: 2.2em;
		border-radius: 0.6em;
		transition: all 0.2s ease;
		padding: 0;
		border: none;
	}
	.social-links :global(a:hover) {
		background: rgba(255, 255, 255, 0.3);
	}
	.social-links :global(img) {
		width: 1em;
		height: 1em;
		border-radius: 0;
	}

	/* More dropdown menu */
	.more-menu {
		position: relative;
		display: inline-flex;
		align-items: center;
	}
	.more-btn {
		background: var(--neu-bg);
		border: none;
		cursor: pointer;
		padding: 0.5em 1em;
		font-size: 0.85em;
		font-family: inherit;
		font-weight: 500;
		color: rgb(var(--gray));
		display: inline-flex;
		align-items: center;
		gap: 0.25em;
		border-radius: 0.85rem;
		line-height: inherit;
		transition: all 0.2s ease;
		white-space: nowrap;
		box-shadow: 3px 3px 6px rgb(163 177 198 / 0.5), -3px -3px 6px rgb(255 255 255 / 0.4);
	}
	.more-btn:hover {
		color: rgb(var(--gray-dark));
		box-shadow: 1px 1px 3px rgb(163 177 198 / 0.4), -1px -1px 3px rgb(255 255 255 / 0.3);
	}
	.more-arrow {
		font-size: 0.7em;
		transition: transform 0.2s ease;
	}
	.more-btn[aria-expanded="true"] .more-arrow {
		transform: rotate(180deg);
	}
	.more-btn[aria-expanded="true"] {
		background: var(--neu-bg);
		box-shadow: inset 2px 2px 5px rgb(163 177 198 / 0.6), inset -2px -2px 5px rgb(255 255 255 / 0.7);
	}
	.more-dropdown {
		display: none;
		position: absolute;
		top: calc(100% + 0.5em);
		right: 0;
		background: var(--neu-bg);
		border-radius: 1rem;
		box-shadow: 6px 6px 12px var(--neu-shadow-dark), -6px -6px 12px var(--neu-shadow-light);
		min-width: 11rem;
		padding: 0.4rem;
		z-index: 50;
	}
	.more-dropdown.show {
		display: flex;
		flex-direction: column;
	}
	.more-dropdown a {
		padding: 0.65em 1em;
		border-bottom: none;
		border-radius: 0.65rem;
		font-size: 0.85em;
		white-space: nowrap;
		color: rgb(var(--gray-dark));
		transition: all 0.15s ease;
	}
	.more-dropdown a:hover {
		background: rgba(255, 255, 255, 0.35);
		box-shadow: inset 1px 1px 3px rgb(163 177 198 / 0.3), inset -1px -1px 3px rgb(255 255 255 / 0.4);
	}

	@media (max-width: 720px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5em;
		}
		h2 {
			width: 100%;
			text-align: center;
		}
		.tab-bar {
			justify-content: center;
			width: 100%;
		}
		.social-links {
			display: none;
		}
	}
	@media (max-width: 400px) {
		header {
			padding: 0.5em 0.75em;
		}
		.tab-bar :global(a),
		.more-btn {
			padding: 0.4em 0.6em;
			font-size: 0.78em;
		}
		h2 {
			font-size: 0.85em;
		}
	}
</style>
