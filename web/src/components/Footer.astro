---
const today = new Date();
import {SOCIALS} from '../consts';
---

<footer>
	&copy; {today.getFullYear()} Benign X. All rights reserved.
	<a href="/gamev1.8" class="game-link">🎮</a>
	<div class="social-links">
        {
            SOCIALS.map((social) => (
                    <a href={social.url} target="_blank">
                        <span class="sr-only">{social.description}</span>
                        <img src={social.icon} alt={social.description} />
                    </a>
            ))
        }
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: #e8ecf1;
		/* Neumorphism top separation shadow */
		box-shadow: 0 -4px 8px #c8ccd1;
		position: relative;
		z-index: 10;
		color: rgb(var(--gray));
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.game-link {
		text-decoration: none;
		opacity: 0.3;
		transition: opacity 0.2s;
		margin-left: 0.5em;
		font-size: 0.8em;
	}
	.game-link:hover {
		opacity: 0.8;
	}
</style>
