---
import WithSidebar from '~/layouts/WithSidebar.astro'
import ArchiveTimeline from '~/components/profile/ArchiveTimeline.astro'
import YearHeatmap from '~/components/profile/YearHeatmap.astro'
import ThoughtTimeline from '~/components/thought/ThoughtTimeline.astro'
import ThoughtEditor from '~/components/editor/thought/Editor'
import { loadThoughts } from '~/data/thoughts'
import { fetchThoughtComments } from '~/data/giscus-comments'
import type { YearGroup } from '~/lib/blog/archive'
import { siteYear, siteMonth, siteISODate, parseSiteDate } from '~/lib/date-utils'

const CHUNK_SIZE = 2

const thoughts = await loadThoughts()
const commentMap = await fetchThoughtComments()
const initialThoughts = thoughts.slice(0, CHUNK_SIZE)
const totalChunks = Math.ceil((thoughts.length - CHUNK_SIZE) / CHUNK_SIZE)
const allTags = [...new Set(thoughts.flatMap((t) => t.tags ?? []))]
const isEditorMode = import.meta.env.DEV && import.meta.env.EDITOR_MODE

// Build archive groups from thoughts
const archiveMap = new Map<number, Map<number, number>>()
for (const t of thoughts) {
  const d = parseSiteDate(t.createdAt)
  const y = siteYear(d)
  const m = siteMonth(d)
  if (!archiveMap.has(y)) archiveMap.set(y, new Map())
  const mm = archiveMap.get(y)!
  mm.set(m, (mm.get(m) ?? 0) + 1)
}
const thoughtArchives: YearGroup[] = Array.from(archiveMap.entries())
  .map(([year, mm]) => ({
    year,
    months: Array.from(mm.entries())
      .map(([month, count]) => ({ month, count }))
      .sort((a, b) => b.month - a.month),
  }))
  .sort((a, b) => b.year - a.year)

// Build daily counts for heatmap (current year)
const currentYear = siteYear(new Date())
const dateCounts: Record<string, number> = {}
for (const t of thoughts) {
  const d = parseSiteDate(t.createdAt)
  if (siteYear(d) === currentYear) {
    const iso = siteISODate(d)
    dateCounts[iso] = (dateCounts[iso] ?? 0) + 1
  }
}
---

<WithSidebar>
  <Fragment slot="sidebar">
    <ArchiveTimeline archives={thoughtArchives} title="那些年" />
  </Fragment>

  <h1 class="page-title anim-fade" style="--delay:0">🧠 怼点想法</h1>
  <p class="page-subtitle anim-fade" style="--delay:1">脑子里蹦出来的碎碎念，不成文章，但值得记一笔</p>

  <YearHeatmap dateCounts={dateCounts} />

  {isEditorMode && (
    <div class="mb-6 anim-fade" style="--delay:2">
      <ThoughtEditor client:load allTags={allTags} />
    </div>
  )}

  {allTags.length > 0 && (
    <div class="mb-6 anim-fade" style={`--delay:${isEditorMode ? 3 : 2}`}>
      <button id="tag-toggle" class="neu-btn neu-filter-btn mb-2" aria-expanded="false">
        🏷️ TAGS <span class="tag-toggle-arrow">▸</span>
      </button>
      <div id="tag-panel" class="tag-panel-collapsed">
        <div class="neu-tag-filter-capsule">
          {allTags.map((tag) => (
            <button class="neu-tag-filter-item" data-tag={tag}>{tag}</button>
          ))}
        </div>
      </div>
    </div>
  )}

  {initialThoughts.length > 0 ? (
    <>
      <ThoughtTimeline thoughts={initialThoughts} isEditorMode={isEditorMode} commentMap={commentMap} />
      {totalChunks > 0 && (
        <div id="thought-sentinel" data-next="1" data-total={totalChunks} class="flex justify-center py-8">
          <span class="text-[var(--text-muted)] text-sm">加载中…</span>
        </div>
      )}
    </>
  ) : (
    <p class="text-[var(--text-muted)] text-center py-12 anim-fade" style="--delay:2">
      还没有想法呢，再等等～
    </p>
  )}
</WithSidebar>

<script>
  function initThoughtPage() {
    // Tag panel toggle
    const tagToggle = document.getElementById('tag-toggle')
    const tagPanel = document.getElementById('tag-panel')
    if (tagToggle && tagPanel) {
      tagToggle.addEventListener('click', () => {
        const expanded = tagPanel.classList.toggle('tag-panel-expanded')
        tagPanel.classList.toggle('tag-panel-collapsed', !expanded)
        tagToggle.setAttribute('aria-expanded', String(expanded))
        tagToggle.querySelector('.tag-toggle-arrow')!.textContent = expanded ? '▾' : '▸'
      })
    }

    // Tag filter
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-tag]')
    let activeTag: string | null = null

    function applyTagFilter() {
      const items = document.querySelectorAll<HTMLElement>('.timeline-item')
      items.forEach((item) => {
        if (!activeTag) {
          item.style.display = ''
          return
        }
        const itemTags = Array.from(item.querySelectorAll('.neu-tag-chip'))
          .map((el) => el.textContent?.trim() ?? '')
        item.style.display = itemTags.includes(activeTag) ? '' : 'none'
      })
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag!
        if (activeTag === tag) {
          activeTag = null
          buttons.forEach((b) => b.classList.remove('neu-filter-active'))
        } else {
          activeTag = tag
          buttons.forEach((b) => {
            b.classList.toggle('neu-filter-active', b.dataset.tag === tag)
          })
        }
        applyTagFilter()
      })
    })

    // Editor mode: wire up edit/delete buttons on given root
    function wireEditorButtons(root: ParentNode) {
      root.querySelectorAll<HTMLButtonElement>('[data-thought-edit]:not([data-wired])').forEach((btn) => {
        btn.dataset.wired = '1'
        btn.addEventListener('click', () => {
          const raw = btn.dataset.thoughtEdit
          if (!raw) return
          try {
            const thought = JSON.parse(raw)
            ;(window as any).__thoughtEditor?.startEdit(thought)
            document.querySelector('.mb-6.anim-fade')?.scrollIntoView({ behavior: 'smooth' })
          } catch {}
        })
      })

      root.querySelectorAll<HTMLButtonElement>('[data-thought-delete]:not([data-wired])').forEach((btn) => {
        btn.dataset.wired = '1'
        btn.addEventListener('click', () => {
          const id = btn.dataset.thoughtDelete
          if (!id) return
          ;(window as any).__thoughtEditor?.handleDelete(id)
        })
      })
    }

    wireEditorButtons(document)

    // Infinite scroll — fetch pre-rendered HTML chunks
    const sentinel = document.getElementById('thought-sentinel')
    if (!sentinel) return

    const timeline = document.querySelector('.thought-timeline')
    if (!timeline) return

    // Ensure SSR items are visible (scroll-restored pages)
    timeline.querySelectorAll<HTMLElement>('.anim-fade:not(.visible)').forEach((el) => {
      el.classList.add('visible')
    })

    let nextPage = parseInt(sentinel.dataset.next ?? '1', 10)
    const totalChunks = parseInt(sentinel.dataset.total ?? '0', 10)
    let loading = false

    async function loadChunk(): Promise<boolean> {
      if (nextPage > totalChunks) return false
      const res = await fetch(`/thoughts/chunks/${nextPage}/`)
      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      const html = await res.text()

      const doc = new DOMParser().parseFromString(html, 'text/html')
      const hasMore = doc.body.dataset.hasMore === 'true'
      // Extract separators and timeline items in DOM order
      const newElements = doc.body.querySelectorAll<HTMLElement>('.timeline-separator, .timeline-item')
      const animTargets: HTMLElement[] = []
      const wireTargets: HTMLElement[] = []
      newElements.forEach((el, i) => {
        el.style.setProperty('--delay', String(i))
        if (!el.classList.contains('anim-fade')) el.classList.add('anim-fade')
        animTargets.push(el)
        if (el.classList.contains('timeline-item')) wireTargets.push(el)
        timeline!.appendChild(el)
      })
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          animTargets.forEach((el) => el.classList.add('visible'))
        })
      })

      // Wire edit/delete buttons on newly loaded items
      wireTargets.forEach((el) => wireEditorButtons(el))

      nextPage++
      applyTagFilter()
      return hasMore
    }

    const observer = new IntersectionObserver(async (entries) => {
      if (!entries[0].isIntersecting || loading || nextPage > totalChunks) return
      loading = true

      try {
        const hasMore = await loadChunk()
        if (!hasMore || nextPage > totalChunks) {
          sentinel.textContent = ''
          observer.disconnect()
        }
      } catch (e) {
        console.error('[thoughts] Failed to load chunk:', e)
        sentinel.innerHTML = '<span class="text-[var(--text-muted)] text-sm">加载失败</span>'
        observer.disconnect()
      } finally {
        loading = false
      }
    }, { rootMargin: '200px' })

    observer.observe(sentinel)

    // Load all remaining chunks then scroll to a specific thought
    async function loadAllAndScrollTo(anchorId: string) {
      loading = true
      try {
        while (await loadChunk()) { /* keep loading */ }
        if (sentinel) sentinel.textContent = ''
        observer.disconnect()
      } catch { /* ignore */ } finally {
        loading = false
      }
      requestAnimationFrame(() => requestAnimationFrame(() => {
        const target = document.getElementById(anchorId)
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' })
          target.classList.add('neu-highlight-pulse')
          target.addEventListener('animationend', () => {
            target.classList.remove('neu-highlight-pulse')
          }, { once: true })
        }
      }))
    }

    // If URL has a thought anchor, load all chunks then scroll to target
    const hash = window.location.hash
    if (hash && hash.startsWith('#thought-')) {
      loadAllAndScrollTo(hash.slice(1))
    }

    // Listen for search-triggered scroll requests (same-page navigation)
    function onSearchScroll(e: Event) {
      const { anchorId } = (e as CustomEvent).detail
      if (anchorId) {
        // If target already exists in DOM, scroll directly
        const existing = document.getElementById(anchorId)
        if (existing) {
          existing.scrollIntoView({ behavior: 'smooth', block: 'center' })
          existing.classList.add('neu-highlight-pulse')
          existing.addEventListener('animationend', () => {
            existing.classList.remove('neu-highlight-pulse')
          }, { once: true })
        } else {
          loadAllAndScrollTo(anchorId)
        }
      }
    }
    window.addEventListener('search:scroll-to-thought', onSearchScroll)
  }

  document.addEventListener('astro:page-load', initThoughtPage)
</script>
