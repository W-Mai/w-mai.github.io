---
import type { GetStaticPaths } from 'astro'
import { getImage } from 'astro:assets'
import BaseHead from '~/components/layout/BaseHead.astro'
import Header from '~/components/layout/Header.astro'
import Footer from '~/components/layout/Footer.astro'
import ThoughtCard from '~/components/thought/ThoughtCard.astro'
import Giscus from '~/components/shared/Giscus.astro'
import ShareCard from '~/components/shared/ShareCard'
import { GISCUS_THOUGHT_CATEGORY, GISCUS_THOUGHT_CATEGORY_ID, AVATAR_URL, SITE_LANG } from '~/consts'
import { loadThoughts, type Thought } from '~/data/thoughts'
import { fetchThoughtComments } from '~/data/giscus-comments'
import { siteLocaleDateString, siteTimeString, parseSiteDate } from '~/lib/date-utils'

export const getStaticPaths: GetStaticPaths = async () => {
  const thoughts = await loadThoughts()
  const commentMap = await fetchThoughtComments()
  return thoughts.map((t) => ({
    params: { id: t.id },
    props: { thought: t, commentData: commentMap.get(t.id) },
  }))
}

interface Props {
  thought: Thought
  commentData?: import('~/data/giscus-comments').ThoughtCommentData
}

const { thought, commentData } = Astro.props
const date = parseSiteDate(thought.createdAt)
const dateLabel = `${siteLocaleDateString(date, 'zh-CN')} ${siteTimeString(date)}`
const ogImageUrl = `/og/thoughts/${thought.id}.png`
const pageFullUrl = `${import.meta.env.SITE ?? 'https://benign.host'}/thoughts/${thought.id}/`
const avatarImg = await getImage({ src: AVATAR_URL, width: 64, height: 64 })
---

<html lang={SITE_LANG}>
  <head>
    <BaseHead
      title={`想法 · ${dateLabel}`}
      description={thought.content.slice(0, 120)}
    />
  </head>
  <body class="neu-bg">
    <Header />

    <main class="max-w-2xl mx-auto px-4 py-10">
      <div class="mb-8 flex items-center gap-2">
        <a href="/thoughts"
           class="neu-btn neu-link-btn gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text-link)] group">
          <span class="group-hover:-translate-x-0.5 transition-transform">←</span>
          <span>返回想法</span>
        </a>
        <ShareCard client:idle ogUrl={ogImageUrl} pageUrl={pageFullUrl} title={`想法 · ${dateLabel}`} avatarUrl={avatarImg.src} />
      </div>

      <ThoughtCard thought={thought} showCommentAction={false} commentData={commentData} />

      <div class="mt-8">
        <Giscus category={GISCUS_THOUGHT_CATEGORY} categoryId={GISCUS_THOUGHT_CATEGORY_ID} />
      </div>
    </main>

    <Footer />
  </body>
</html>
