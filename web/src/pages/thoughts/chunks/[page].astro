---
import type { GetStaticPaths } from 'astro'
import ThoughtCard from '~/components/thought/ThoughtCard.astro'
import TimelineDateSeparator from '~/components/thought/TimelineDateSeparator.astro'
import type { Thought } from '~/data/thoughts'
import { loadThoughts } from '~/data/thoughts'
import { fetchThoughtComments, type ThoughtCommentData } from '~/data/giscus-comments'
import { siteYear, siteMonth, siteDay, parseSiteDate } from '~/lib/date-utils'

export const getStaticPaths: GetStaticPaths = async () => {
  const CHUNK_SIZE = 2
  const thoughts = await loadThoughts()
  const commentMap = await fetchThoughtComments()
  const remaining = thoughts.slice(CHUNK_SIZE)
  const totalChunks = Math.ceil(remaining.length / CHUNK_SIZE)

  // Serialize comment map for each chunk's items
  return Array.from({ length: totalChunks }, (_, i) => {
    const chunkItems = remaining.slice(i * CHUNK_SIZE, (i + 1) * CHUNK_SIZE)
    const prevItem = i > 0 ? remaining[i * CHUNK_SIZE - 1] : thoughts[CHUNK_SIZE - 1]
    const pd = parseSiteDate(prevItem.createdAt)

    // Extract only relevant comment data for this chunk
    const chunkComments: Record<string, ThoughtCommentData> = {}
    for (const item of chunkItems) {
      const data = commentMap.get(item.id)
      if (data) chunkComments[item.id] = data
    }

    return {
      params: { page: String(i + 1) },
      props: {
        items: chunkItems,
        hasMore: i + 1 < totalChunks,
        prevYear: siteYear(pd),
        prevMonth: siteMonth(pd),
        prevDay: siteDay(pd),
        chunkComments,
      },
    }
  })
}

interface Props {
  items: Thought[]
  hasMore: boolean
  prevYear: number
  prevMonth: number
  prevDay: number
  chunkComments: Record<string, ThoughtCommentData>
}

const { items, hasMore, prevYear, prevMonth, prevDay, chunkComments } = Astro.props
const isEditorMode = import.meta.env.DEV && import.meta.env.EDITOR_MODE

let curYear = prevYear
let curMonth = prevMonth
let curDay = prevDay
---
<html><body data-has-more={String(hasMore)} data-prev-year={String(prevYear)} data-prev-month={String(prevMonth)} data-prev-day={String(prevDay)}>
{items.map((thought, i) => {
  const d = parseSiteDate(thought.createdAt)
  const y = siteYear(d)
  const m = siteMonth(d)
  const day = siteDay(d)
  const showYear = y !== curYear
  const showMonth = showYear || m !== curMonth
  const showDay = showMonth || day !== curDay
  curYear = y; curMonth = m; curDay = day
  return (
    <>
      {showYear && <TimelineDateSeparator level="year" date={d} />}
      {showMonth && <TimelineDateSeparator level="month" date={d} />}
      {showDay && <TimelineDateSeparator level="day" date={d} />}
      <div class="timeline-item" data-chunk>
        <div class="timeline-dot"></div>
        <div class="timeline-connector"></div>
        <ThoughtCard thought={thought} isEditorMode={isEditorMode} commentData={chunkComments[thought.id]} />
      </div>
    </>
  )
})}
</body></html>
