---
import BaseHead from '~/components/BaseHead.astro'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'
import DiagramRenderer from '~/components/DiagramRenderer'
import { architectureData } from '~/data/architecture'
import { NICK_NAME, SITE_DESCRIPTION } from '~/consts'
---

<html>
<head>
    <BaseHead title={`架构图 | ${NICK_NAME}`} description={SITE_DESCRIPTION} />
</head>

<body class="neu-bg">
<Header />

<main class="w-full max-w-6xl mx-auto px-5 sm:px-6 py-6 sm:py-12">
    <h1 class="page-title anim-fade" style="--delay:0">🏗️ 架构图</h1>
    <p class="page-subtitle anim-fade" style="--delay:1">项目的模块结构与数据流</p>

    <div class="anim-fade" style="--delay:2">
        <DiagramRenderer client:load data={architectureData} />
    </div>
</main>

<Footer />
</body>
</html>
