---
import { Image } from 'astro:assets'
import BaseHead from '~/components/BaseHead.astro'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'
import GitHubActivityCalendar from '~/components/GitHubActivityCalendar.astro'
import { fetchGitHubProfile } from '~/lib/github'
import { USER_NAME, NICK_NAME, SITE_DESCRIPTION, SOCIALS } from '~/consts'
import HeroImage from '@posts/assets/my_hero_img.png'

const profile = await fetchGitHubProfile()
const blogUrl = profile.blog
    ? profile.blog.startsWith('http') ? profile.blog : `https://${profile.blog}`
    : null

// Easter egg: random count of 俺 before and after 恁
const beforeCount = Math.floor(Math.random() * 60) + 20
const afterCount = Math.floor(Math.random() * 60) + 20
---

<html>
<head>
    <BaseHead title={`自个儿 | ${NICK_NAME}`} description={SITE_DESCRIPTION} image={HeroImage} />
</head>

<body class="neu-bg">
<Header />

<main class="w-full max-w-4xl mx-auto px-5 sm:px-6 py-6 sm:py-12">

    <!-- Hero section -->
    <section class="flex flex-col items-center text-center mb-8 sm:mb-12 anim-fade" style="--delay:0">
        <div class="neu-avatar-ring rounded-full anim-zoom inline-flex aspect-square">
            <Image
                class="size-24 sm:size-32 md:size-40 rounded-full aspect-square object-cover"
                src={profile.avatar_url}
                alt={USER_NAME}
                width={160}
                height={160}
            />
        </div>
        <h1 class="mt-4 sm:mt-6 text-2xl sm:text-3xl md:text-4xl font-bold text-slate-800">{profile.name ?? NICK_NAME}</h1>
        <p class="mt-1 text-base sm:text-lg text-slate-400">@{USER_NAME}</p>
        {profile.bio && (
            <p class="mt-2 sm:mt-3 text-sm sm:text-base md:text-lg text-slate-500 max-w-md px-2">{profile.bio}</p>
        )}

        <!-- Social links -->
        <div class="flex flex-wrap justify-center gap-2 sm:gap-3 mt-4 sm:mt-5">
            {SOCIALS.map((social) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer"
                   class="neu-btn flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-xl
                          text-xs sm:text-sm no-underline text-slate-600 hover:text-slate-800 transition-all">
                    <img class="size-4 rounded-none" src={social.icon} alt={social.name} />
                    <span class="hidden sm:inline">{social.name}</span>
                </a>
            ))}
        </div>
    </section>

    <!-- Stats bar -->
    <section class="neu-card rounded-2xl px-6 py-5 max-w-xs sm:max-w-sm mx-auto mb-8 sm:mb-12 anim-fade" style="--delay:1">
        <div class="flex justify-around">
            <div class="text-center">
                <span class="block text-xl sm:text-2xl font-bold text-slate-800">{profile.public_repos}</span>
                <span class="text-[11px] sm:text-sm text-slate-400">Repos</span>
            </div>
            <div class="w-px bg-slate-200/60"></div>
            <div class="text-center">
                <span class="block text-xl sm:text-2xl font-bold text-slate-800">{profile.followers}</span>
                <span class="text-[11px] sm:text-sm text-slate-400">Followers</span>
            </div>
            <div class="w-px bg-slate-200/60"></div>
            <div class="text-center">
                <span class="block text-xl sm:text-2xl font-bold text-slate-800">{profile.following}</span>
                <span class="text-[11px] sm:text-sm text-slate-400">Following</span>
            </div>
        </div>
    </section>

    <!-- Info cards -->
    <section class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 mb-8 sm:mb-12 anim-fade" style="--delay:2">
        {profile.location && (
            <div class="neu-card flex items-center gap-2.5 sm:gap-3 rounded-xl px-3.5 sm:px-5 py-3 sm:py-4">
                <span class="text-lg sm:text-xl">📍</span>
                <div class="min-w-0">
                    <p class="text-xs text-slate-400 m-0">Location</p>
                    <p class="text-xs sm:text-sm font-medium text-slate-700 m-0 truncate">{profile.location}</p>
                </div>
            </div>
        )}
        {profile.company && (
            <div class="neu-card flex items-center gap-2.5 sm:gap-3 rounded-xl px-3.5 sm:px-5 py-3 sm:py-4">
                <span class="text-lg sm:text-xl">🏢</span>
                <div class="min-w-0">
                    <p class="text-xs text-slate-400 m-0">Company</p>
                    <p class="text-xs sm:text-sm font-medium text-slate-700 m-0 truncate">{profile.company}</p>
                </div>
            </div>
        )}
        {blogUrl && (
            <a href={blogUrl} target="_blank" rel="noopener noreferrer"
               class="neu-btn flex items-center gap-2.5 sm:gap-3 rounded-xl px-3.5 sm:px-5 py-3 sm:py-4
                      no-underline transition-all">
                <span class="text-lg sm:text-xl">🔗</span>
                <div class="min-w-0">
                    <p class="text-xs text-slate-400 m-0">Blog</p>
                    <p class="text-xs sm:text-sm font-medium text-blue-600 m-0 truncate">{profile.blog}</p>
                </div>
            </a>
        )}
    </section>

    <!-- GitHub Activity -->
    <section class="neu-card rounded-2xl p-4 sm:p-6 md:p-8 mb-8 sm:mb-12 anim-fade" style="--delay:3">
        <h2 class="text-lg sm:text-xl font-bold text-slate-800 mb-4 sm:mb-6 flex items-center gap-2">
            🟩 GitHub 活动
            <span class="h-0.5 flex-1 bg-slate-200/60 rounded-full"></span>
        </h2>
        <div class="overflow-x-auto -mx-1">
            <GitHubActivityCalendar username={USER_NAME} />
        </div>
    </section>

    <!-- Easter egg: 找恁 -->
    <section class="neu-card-warm rounded-2xl p-4 sm:p-6 md:p-8 anim-fade" style="--delay:4">
        <h2 class="text-lg sm:text-xl font-bold text-slate-800 mb-3 sm:mb-4 flex items-center gap-2">
            🔍 找恁
            <span class="h-0.5 flex-1 bg-amber-200/60 rounded-full"></span>
        </h2>
        <p class="text-xs sm:text-sm text-slate-500 mb-3 sm:mb-4">从俺里边儿，找着恁搁哪儿嘞？</p>
        <div id="find-ren" class="text-xs sm:text-sm leading-relaxed text-amber-800/60 select-none break-all">
            {Array.from({ length: beforeCount }).map(() => (
                <span data-c="俺">俺 </span>
            ))}
            <span data-c="恁">恁 </span>
            {Array.from({ length: afterCount }).map(() => (
                <span data-c="俺">俺 </span>
            ))}
        </div>
        <div id="find-ren-toast" class="hidden mt-4 text-center text-lg animate-bounce">
            🥕🐱🧻 臻棒！ 🎉
        </div>
        <script>
            function initFindRen() {
                const container = document.getElementById('find-ren')
                const toast = document.getElementById('find-ren-toast')
                if (!container || !toast) return
                container.addEventListener('click', (e) => {
                    const target = e.target as HTMLElement
                    if (!target.dataset.c) return
                    container.querySelectorAll('.found').forEach(el => {
                        el.classList.remove('found')
                    })
                    if (target.dataset.c === '恁') {
                        target.classList.add('found')
                        toast.classList.remove('hidden')
                    } else {
                        toast.classList.add('hidden')
                    }
                })
            }
            document.addEventListener('astro:page-load', initFindRen)
        </script>
        <style>
            #find-ren span {
                cursor: pointer;
                transition: all 0.3s ease;
                display: inline;
            }
            #find-ren span.found {
                color: #ef4444;
                font-weight: bold;
                font-size: 1.5em;
            }
        </style>
    </section>

</main>

<Footer />

</body>
</html>


