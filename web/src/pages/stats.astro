---
import { getCollection } from 'astro:content'
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProfileSidebar from '~/components/profile/ProfileSidebar.astro'
import StatsDashboard from '~/components/profile/StatsDashboard.astro'
import FormattedDate from '~/components/shared/FormattedDate.astro'
import { fetchGitHubProfile } from '~/lib/github'
import { computeBlogStats, stripMarkdown, countWords, estimateReadingTime } from '~/lib/blog/reading-stats'
import { siteYear, siteMonth } from '~/lib/date-utils'

const profile = await fetchGitHubProfile()

const posts = await getCollection('blog')

// Compute overall blog stats
const blogStats = computeBlogStats(
  posts.map((p) => ({ body: p.body ?? '', pubDate: p.data.pubDate }))
)

// Post ranking: sorted by word count descending
const postRanking = posts
  .map((p) => {
    const stripped = stripMarkdown(p.body ?? '')
    const wc = countWords(stripped).total
    const readMin = estimateReadingTime(p.body ?? '')
    return {
      title: p.data.title,
      id: p.id,
      wordCount: wc,
      readingTime: readMin,
      pubDate: p.data.pubDate,
    }
  })
  .sort((a, b) => b.wordCount - a.wordCount)

// Monthly frequency: group by YYYY-MM, sorted descending
const monthlyMap = new Map<string, number>()
for (const post of posts) {
  const d = post.data.pubDate
  const key = `${siteYear(d)}-${String(siteMonth(d)).padStart(2, '0')}`
  monthlyMap.set(key, (monthlyMap.get(key) ?? 0) + 1)
}
const monthlyFrequency = [...monthlyMap.entries()]
  .sort((a, b) => b[0].localeCompare(a[0]))
  .map(([period, count]) => ({ period, count }))

// Yearly frequency: group by year, sorted descending
const yearlyMap = new Map<string, number>()
for (const post of posts) {
  const year = String(siteYear(post.data.pubDate))
  yearlyMap.set(year, (yearlyMap.get(year) ?? 0) + 1)
}
const yearlyFrequency = [...yearlyMap.entries()]
  .sort((a, b) => b[0].localeCompare(a[0]))
  .map(([year, count]) => ({ year, count }))
---

<WithSidebar>
  <Fragment slot="sidebar">
    <ProfileSidebar profile={profile} showBio />
  </Fragment>

  <h1 class="page-title anim-fade" style="--delay:0">📊 怼点统计</h1>
  <p class="page-subtitle anim-fade" style="--delay:1">
    俺写嘞文章，都搁这儿统计着嘞
    <a href="/blog" class="neu-btn neu-link-btn ml-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-link)]">
      ← 回去看文章
    </a>
  </p>

  <!-- Stats Dashboard -->
  <div class="anim-fade" style="--delay:2">
    <StatsDashboard
      totalPosts={blogStats.totalPosts}
      totalWords={blogStats.totalWords}
      averageWords={blogStats.averageWords}
      earliestDate={blogStats.earliestDate}
      latestDate={blogStats.latestDate}
    />
  </div>

  <!-- Post ranking -->
  <section class="board-container neu-board mb-8 anim-fade" style="--delay:3">
    <h2 class="neu-section-title mb-6">
      🏆 文章排行
      <span class="text-sm font-normal text-[var(--text-muted)] ml-1">{postRanking.length} 篇</span>
      <span class="neu-section-divider"></span>
    </h2>

    <div class="space-y-3">
      {postRanking.map((post, idx) => (
        <a href={`/blog/${post.id}/`}
           class="stats-rank-card neu-card neu-card-hover flex items-center gap-4 rounded-xl px-4 py-3
                  no-underline transition-all duration-200 anim-fade"
           style={`--delay:${3.5 + idx * 0.5}`}>
          <span class:list={[
            'flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold',
            idx === 0 ? 'bg-[var(--rank-gold-bg)] text-[var(--rank-gold-text)]' :
            idx === 1 ? 'bg-[var(--border-subtle)] text-[var(--text-secondary)]' :
            idx === 2 ? 'bg-[var(--rank-bronze-bg)] text-[var(--rank-bronze-text)]' :
            'bg-[var(--border-subtle)] text-[var(--text-muted)]'
          ]}>
            {idx + 1}
          </span>
          <div class="flex-1 min-w-0">
            <h3 class="text-sm font-semibold text-[var(--text-heading)] m-0 truncate">{post.title}</h3>
            <p class="text-xs text-[var(--text-muted)] m-0 mt-0.5">
              <FormattedDate date={post.pubDate} />
            </p>
          </div>
          <div class="flex-shrink-0 text-right">
            <span class="block text-sm font-bold text-[var(--text-primary)]">{post.wordCount.toLocaleString()} 字</span>
            <span class="block text-xs text-[var(--text-muted)]">{post.readingTime} 分钟</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Monthly / Yearly frequency -->
  <section class="board-container neu-board anim-fade" style="--delay:4">
    <h2 class="neu-section-title mb-6">
      📅 发布频率
      <span class="neu-section-divider"></span>
    </h2>

    <!-- Yearly summary -->
    <div class="mb-6">
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-3">年度汇总</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {yearlyFrequency.map((item, idx) => (
          <div class="neu-card neu-freq-card freq-card anim-fade"
               style={`--delay:${4.5 + idx * 0.5}`}>
            <span class="block text-lg font-bold text-[var(--text-heading)]">{item.count}</span>
            <span class="text-xs text-[var(--text-muted)]">{item.year} 年</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Monthly detail -->
    <div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-3">月度明细</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {monthlyFrequency.map((item, idx) => (
          <div class="neu-card neu-freq-card freq-card anim-fade"
               style={`--delay:${5 + idx * 0.5}`}>
            <span class="block text-lg font-bold text-[var(--text-heading)]">{item.count}</span>
            <span class="text-xs text-[var(--text-muted)]">{item.period}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</WithSidebar>

<style>
  /* Hover lift for frequency cards */
  .freq-card:hover {
    box-shadow: 3px 3px 6px var(--neu-shadow-dark), -3px -3px 6px var(--neu-shadow-light);
    transform: translateY(-4px);
  }
</style>
