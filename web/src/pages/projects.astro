---
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProjectCard from '../components/profile/ProjectCard.astro'
import FeaturedProjectCard from '../components/profile/FeaturedProjectCard.astro'
import ProfileSidebar from '../components/profile/ProfileSidebar.astro'
import { fetchGitHubProfile, fetchGitHubRepos, fetchFeaturedProjects } from '../lib/github'
import { PINNED_PROJECTS } from '../consts'

const profile = await fetchGitHubProfile()
const allRepos = await fetchGitHubRepos()
const featured = await fetchFeaturedProjects(PINNED_PROJECTS)
---

<WithSidebar>
    <Fragment slot="sidebar">
        <ProfileSidebar profile={profile} showBio />
    </Fragment>

    <h1 class="page-title anim-fade" style="--delay:0">🧩 怼点项目</h1>
    <p class="page-subtitle anim-fade" style="--delay:1">俺搁 GitHub 上怼嘞项目，都搁这儿了</p>

    <section class="board-container neu-board anim-fade" style="--delay:2">
        <h2 class="neu-section-title mb-6">
            📌 置顶项目
            <span class="neu-section-divider"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {featured.map((project) => (
                <FeaturedProjectCard
                    name={project.name}
                    description={project.description}
                    language={project.language}
                    stars={project.stargazers_count}
                    url={project.html_url}
                    homepage={project.homepage}
                    bannerUrl={project.bannerUrl}
                    logoUrl={project.logoUrl}
                    owner={project.owner}
                    badges={project.badges}
                />
            ))}
        </div>

        <h2 class="neu-section-title mb-6">
            全部项目
            <span class="text-sm font-normal text-[var(--text-muted)] ml-1">{allRepos.length} 个</span>
            <span class="neu-section-divider"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {allRepos.map((repo) => (
                <ProjectCard
                    name={repo.name}
                    description={repo.description}
                    language={repo.language}
                    stars={repo.stargazers_count}
                    url={repo.html_url}
                />
            ))}
        </div>
    </section>
</WithSidebar>
