---
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProjectCard from '../components/ProjectCard.astro'
import FeaturedProjectCard from '../components/FeaturedProjectCard.astro'
import { fetchGitHubProfile, fetchAllGitHubRepos, fetchFeaturedProjects } from '../lib/github'
import { SOCIALS, USER_NAME, NICK_NAME, PINNED_PROJECTS } from '../consts'
import { Image } from 'astro:assets'

const profile = await fetchGitHubProfile()
const allRepos = await fetchAllGitHubRepos()
const featured = await fetchFeaturedProjects(PINNED_PROJECTS)
---

<WithSidebar>
    <Fragment slot="sidebar">
        <aside class="neu-card rounded-2xl border-slate-200 p-6
        flex flex-col gap-y-2 md:text-sm text-2xl text-slate-800">
            <div class="flex flex-col items-center">
                <Image
                        class="size-46 md:size-36 rounded-full border-4 border-white shadow-md"
                        src={profile.avatar_url}
                        alt={USER_NAME}
                        width={184}
                        height={184}
                />
                <h4 class="mt-3 font-bold">{NICK_NAME}</h4>
                <h5 class="m-3 text-slate-500">@{USER_NAME}</h5>
            </div>
            <div class="flex justify-around text-center">
                <div>
                    <span class="font-bold block">{profile.followers}</span>
                    <span class="text-xs text-slate-500">followers</span>
                </div>
                <div>
                    <span class="font-bold block">{profile.following}</span>
                    <span class="text-xs text-slate-500">following</span>
                </div>
            </div>
            <div class="flex flex-col text-center py-4 gap-y-2 p-8 md:p-4">
                {
                    SOCIALS.map((social) => (
                            <a class="flex no-underline h-6 items-center" href={social.url} target="_blank">
                                <span class="sr-only">{social.description}</span>
                                <img class="scale-60" src={social.icon} alt={social.description}/>
                                <h6 class="text-slate-500 m-0">@{social.name}</h6>
                            </a>
                    ))
                }
            </div>
        </aside>
    </Fragment>

    <h1 class="text-4xl md:text-6xl font-bold mb-4 anim-fade" style="--delay:0">🧩 怼点项目</h1>
    <p class="text-lg text-slate-500 mb-8 anim-fade" style="--delay:1">俺搁 GitHub 上怼嘞项目，都搁这儿了</p>

    <section class="board-container neu-card rounded-2xl p-4 md:p-8 -mx-2 md:-mx-4 anim-fade" style="--delay:2">
        <h2 class="text-xl md:text-2xl font-bold mb-6 text-slate-800 flex items-center gap-2">
            📌 置顶项目
            <span class="h-0.5 flex-1 bg-slate-200 rounded-full"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
            {featured.map((project) => (
                <FeaturedProjectCard
                    name={project.name}
                    description={project.description}
                    language={project.language}
                    stars={project.stargazers_count}
                    url={project.html_url}
                    homepage={project.homepage}
                    bannerUrl={project.bannerUrl}
                    logoUrl={project.logoUrl}
                    owner={project.owner}
                    badges={project.badges}
                />
            ))}
        </div>

        <h2 class="text-xl md:text-2xl font-bold mb-6 text-slate-800 flex items-center gap-2">
            全部项目
            <span class="text-sm font-normal text-slate-400 ml-1">{allRepos.length} 个</span>
            <span class="h-0.5 flex-1 bg-slate-200 rounded-full"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {allRepos.map((repo) => (
                <ProjectCard
                    name={repo.name}
                    description={repo.description}
                    language={repo.language}
                    stars={repo.stargazers_count}
                    url={repo.html_url}
                />
            ))}
        </div>
    </section>
</WithSidebar>
