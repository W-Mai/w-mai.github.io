---
import { getCollection } from 'astro:content'
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProjectCard from '~/components/profile/ProjectCard.astro'
import FeaturedProjectCard from '~/components/profile/FeaturedProjectCard.astro'
import ProfileSidebar from '~/components/profile/ProfileSidebar.astro'
import RecentThoughts from '~/components/thought/RecentThoughts.astro'
import RecentPostCard from '~/components/blog/RecentPostCard.astro'
import { fetchGitHubProfile, fetchGitHubRepos, fetchFeaturedProjects } from '~/lib/github'
import { PINNED_PROJECTS, USER_NAME } from '~/consts'

const profile = await fetchGitHubProfile()
const repos = await fetchGitHubRepos(USER_NAME, 12)
const featured = await fetchFeaturedProjects(PINNED_PROJECTS)

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
const recentPosts = allPosts.slice(0, 4)
---

<WithSidebar collapsible={false}>
    <Fragment slot="sidebar">
        <ProfileSidebar profile={profile} showBio />
        <RecentThoughts />
    </Fragment>

    <h1 class="page-title anim-fade" style="--delay:0">👋 恁好，吃了冇</h1>

    <p class="page-subtitle anim-fade" style="--delay:1">可求欢迎恁来俺嘞网站，还能搁这儿：</p>

    <div class="flex flex-wrap gap-3 mb-12 anim-fade" style="--delay:2">
        <a href="/blog" class="group flex items-center gap-2 rounded-full neu-btn
                                px-4 py-2 no-underline text-[var(--text-primary)] transition-all duration-300
                                hover:bg-gradient-to-r hover:from-[var(--nav-blog-hover-from)] hover:to-transparent">
            <span class="text-base">🚀</span>
            <span class="text-xs font-semibold group-hover:text-[var(--nav-blog-group-text)] truncate">怼点文章</span>
            <span class="text-[var(--nav-blog-text)] text-xs group-hover:text-[var(--nav-blog-text-hover)] transition-colors">›</span>
        </a>
        <a href="/thoughts" class="group flex items-center gap-2 rounded-full neu-btn
                    px-4 py-2 no-underline text-[var(--text-primary)] transition-all duration-300
                    hover:bg-gradient-to-r hover:from-[var(--nav-blog-hover-from)] hover:to-transparent">
            <span class="text-base">⭐</span>
            <span class="text-xs font-semibold group-hover:text-[var(--nav-blog-group-text)] truncate">怼点想法</span>
            <span class="text-[var(--nav-blog-text)] text-xs group-hover:text-[var(--nav-blog-text-hover)] transition-colors">›</span>
        </a>
        <a href="/projects" class="group flex items-center gap-2 rounded-full neu-btn
                    px-4 py-2 no-underline text-[var(--text-primary)] transition-all duration-300
                    hover:bg-gradient-to-r hover:from-[var(--nav-proj-hover-from)] hover:to-transparent">
            <span class="text-base">🧩</span>
            <span class="text-xs font-semibold group-hover:text-[var(--nav-proj-group-text)] truncate">怼点项目</span>
            <span class="text-[var(--nav-proj-text)] text-xs group-hover:text-[var(--nav-proj-text-hover)] transition-colors">›</span>
        </a>
        <a href="/wishes" class="group flex items-center gap-2 rounded-full neu-btn
                    px-4 py-2 no-underline text-[var(--text-primary)] transition-all duration-300
                    hover:bg-gradient-to-r hover:from-[var(--nav-proj-hover-from)] hover:to-transparent">
            <span class="text-base">✅</span>
            <span class="text-xs font-semibold group-hover:text-[var(--nav-proj-group-text)] truncate">怼点想怼嘞</span>
            <span class="text-[var(--nav-proj-text)] text-xs group-hover:text-[var(--nav-proj-text-hover)] transition-colors">›</span>
        </a>
    </div>

    <!-- Recent posts -->
    {recentPosts.length > 0 && (
      <section class="mb-12 anim-fade" style="--delay:3">
        <h2 class="neu-section-title mb-6">
          ✍️ 近期文章
          <a href="/blog" class="text-sm font-normal text-[var(--text-muted)] hover:text-[var(--text-link)] no-underline transition-colors">瞅瞅 →</a>
          <span class="neu-section-divider"></span>
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {recentPosts.map((post) => (
            <RecentPostCard
              id={post.id}
              title={post.data.title}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              description={post.data.description}
            />
          ))}
        </div>
      </section>
    )}

    <section class="board-container neu-board anim-fade" style="--delay:4">
        <h2 class="neu-section-title mb-6">
            📌 置顶项目
            <span class="neu-section-divider"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {featured.map((project) => (
                <FeaturedProjectCard
                    name={project.name}
                    description={project.description}
                    language={project.language}
                    stars={project.stargazers_count}
                    url={project.html_url}
                    homepage={project.homepage}
                    bannerUrl={project.bannerUrl}
                    logoUrl={project.logoUrl}
                    owner={project.owner}
                    badges={project.badges}
                />
            ))}
        </div>

        <h2 class="neu-section-title mb-6">
            开源项目
            <a href="/projects" class="text-sm font-normal text-[var(--text-muted)] hover:text-[var(--text-link)] no-underline transition-colors">瞅瞅 →</a>
            <span class="neu-section-divider"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {repos.map((repo) => (
                <ProjectCard
                    name={repo.name}
                    description={repo.description}
                    language={repo.language}
                    stars={repo.stargazers_count}
                    url={repo.html_url}
                />
            ))}
        </div>

        <div class="mt-6 text-center">
            <a href="/projects" class="inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text-link)] no-underline transition-colors">
                瞅瞅全部项目 →
            </a>
        </div>
    </section>
</WithSidebar>
