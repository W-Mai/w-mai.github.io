---
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProjectCard from '../components/ProjectCard.astro'
import FeaturedProjectCard from '../components/FeaturedProjectCard.astro'
import ProfileSidebar from '../components/ProfileSidebar.astro'
import { fetchGitHubProfile, fetchGitHubRepos, fetchFeaturedProjects } from '../lib/github'
import { PINNED_PROJECTS } from '../consts'

const profile = await fetchGitHubProfile()
const repos = await fetchGitHubRepos()
const featured = await fetchFeaturedProjects(PINNED_PROJECTS)
---

<WithSidebar>
    <Fragment slot="sidebar">
        <ProfileSidebar profile={profile} showBio />
    </Fragment>

    <h1 class="text-4xl md:text-6xl font-bold mb-4 anim-fade" style="--delay:0">👋 恁好，吃了冇</h1>

    <p class="text-lg text-slate-500 mb-8 anim-fade" style="--delay:1">可求欢迎恁来俺嘞网站，还能搁这儿：</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 anim-fade" style="--delay:2">
        <a href="/blog" class="group flex items-center gap-2 rounded-xl neu-btn
                                px-4 py-3 no-underline text-slate-700 transition-all duration-200">
            <span class="text-base">🚀</span>
            <span class="text-xs font-semibold group-hover:text-blue-600 truncate">怼点文章</span>
            <span class="ml-auto text-blue-300 text-xs group-hover:text-blue-500 transition-colors">›</span>
        </a>
        <div class="flex items-center gap-2 rounded-xl neu-card opacity-60
                    px-4 py-3 text-slate-400 cursor-default">
            <span class="text-base grayscale-[30%]">⭐</span>
            <span class="text-xs font-medium truncate">怼点想法</span>
            <span class="ml-auto text-[9px] text-slate-400 whitespace-nowrap">soon</span>
        </div>
        <a href="/projects" class="group flex items-center gap-2 rounded-xl neu-btn
                    px-4 py-3 no-underline text-slate-700 transition-all duration-200">
            <span class="text-base">🧩</span>
            <span class="text-xs font-semibold group-hover:text-emerald-600 truncate">怼点项目</span>
            <span class="ml-auto text-emerald-300 text-xs group-hover:text-emerald-500 transition-colors">›</span>
        </a>
        <div class="flex items-center gap-2 rounded-xl neu-card opacity-60
                    px-4 py-3 text-slate-400 cursor-default">
            <span class="text-base grayscale-[30%]">✅</span>
            <span class="text-xs font-medium truncate">怼点想怼嘞</span>
            <span class="ml-auto text-[9px] text-slate-400 whitespace-nowrap">soon</span>
        </div>
    </div>

    <section class="board-container neu-inset rounded-[2rem] p-6 md:p-8 -mx-2 md:-mx-4 anim-fade" style="--delay:3">
        <h2 class="text-xl md:text-2xl font-bold mb-6 text-slate-800 flex items-center gap-2">
            📌 置顶项目
            <span class="h-0.5 flex-1 bg-slate-200 rounded-full"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {featured.map((project) => (
                <FeaturedProjectCard
                    name={project.name}
                    description={project.description}
                    language={project.language}
                    stars={project.stargazers_count}
                    url={project.html_url}
                    homepage={project.homepage}
                    bannerUrl={project.bannerUrl}
                    logoUrl={project.logoUrl}
                    owner={project.owner}
                    badges={project.badges}
                />
            ))}
        </div>

        <h2 class="text-xl md:text-2xl font-bold mb-6 text-slate-800 flex items-center gap-2">
            开源项目
            <a href="/projects" class="text-sm font-normal text-slate-400 hover:text-slate-600 no-underline transition-colors">瞅瞅 →</a>
            <span class="h-0.5 flex-1 bg-slate-200 rounded-full"></span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {repos.map((repo) => (
                <ProjectCard
                    name={repo.name}
                    description={repo.description}
                    language={repo.language}
                    stars={repo.stargazers_count}
                    url={repo.html_url}
                />
            ))}
        </div>

        <div class="mt-6 text-center">
            <a href="/projects" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-600 no-underline transition-colors">
                瞅瞅全部项目 →
            </a>
        </div>
    </section>
</WithSidebar>
