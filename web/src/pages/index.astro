---
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProjectCard from '../components/ProjectCard.astro'
import FeaturedProjectCard from '../components/FeaturedProjectCard.astro'
import { fetchGitHubProfile, fetchGitHubRepos, fetchFeaturedProjects } from '../lib/github'
import { SOCIALS, USER_NAME, NICK_NAME, PINNED_PROJECTS } from '../consts'

const profile = await fetchGitHubProfile()
const repos = await fetchGitHubRepos()
const featured = await fetchFeaturedProjects(PINNED_PROJECTS)
---

<WithSidebar>
    <Fragment slot="sidebar">
        <aside class="bg-white rounded-2xl border-slate-200 p-6
        flex flex-col gap-y-2 md:text-sm text-2xl text-slate-800">

            <div class="flex flex-col items-center">
                <img
                        class="size-46 md:size-36 rounded-full border-4 border-white shadow-md"
                        src={profile.avatar_url}
                        alt={USER_NAME}
                />
                <h4 class="mt-3 font-bold">{NICK_NAME}</h4>
                <h5 class="m-3 text-slate-500">@{USER_NAME}</h5>
                <h6 class="m-1.5 text-center text-slate-600">{profile.bio ?? 'Overflow Stack Developer.'}</h6>
            </div>

            <div class="flex justify-around text-center">
                <div>
                    <span class="font-bold block">{profile.followers}</span>
                    <span class="text-xs text-slate-500">followers</span>
                </div>
                <div>
                    <span class="font-bold block">{profile.following}</span>
                    <span class="text-xs text-slate-500">following</span>
                </div>
            </div>

            <div class="flex flex-col text-center py-4 gap-y-2 p-8 md:p-4">
                {
                    SOCIALS.map((social) => (
                            <a class="flex no-underline h-6 items-center" href={social.url} target="_blank">
                                <span class="sr-only">{social.description}</span>
                                <img class="scale-60" src={social.icon} alt={social.description}/>
                                <h6 class="text-slate-500 m-0">@{social.name}</h6>
                            </a>
                    ))
                }
            </div>
        </aside>
    </Fragment>

    <h1 class="text-4xl md:text-6xl font-bold mb-4">👋 恁好，吃了冇</h1>

    <p class="text-lg text-slate-500 mb-8">可求欢迎恁来俺嘞网站，还能搁这儿：</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-12">
        <a href="/blog" class="group flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4
                                no-underline text-slate-700 transition-all duration-200
                                hover:shadow-md hover:-translate-y-0.5 hover:border-slate-300">
            <span class="text-2xl">🚀</span>
            <span class="text-sm font-medium group-hover:text-blue-600">怼点文章</span>
        </a>
        <div class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-slate-700">
            <span class="text-2xl">⭐</span>
            <span class="text-sm font-medium">怼点想法</span>
        </div>
        <div class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-slate-700">
            <span class="text-2xl">🧩</span>
            <span class="text-sm font-medium">怼点项目</span>
        </div>
        <div class="flex flex-col items-center gap-2 rounded-xl border border-slate-200 bg-white p-4 text-slate-700">
            <span class="text-2xl">✅</span>
            <span class="text-sm font-medium">怼点日特怼想怼嘞</span>
        </div>
    </div>

    <h2 class="text-xl md:text-2xl font-bold mb-6 text-slate-800">📌 置顶项目</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
        {featured.map((project) => (
            <FeaturedProjectCard
                name={project.name}
                description={project.description}
                language={project.language}
                stars={project.stargazers_count}
                url={project.html_url}
                homepage={project.homepage}
                bannerUrl={project.bannerUrl}
                logoUrl={project.logoUrl}
                owner={project.owner}
            />
        ))}
    </div>

    <h2 class="text-xl md:text-2xl font-bold mb-6 text-slate-800">开源项目</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {repos.map((repo) => (
            <ProjectCard
                name={repo.name}
                description={repo.description}
                language={repo.language}
                stars={repo.stargazers_count}
                url={repo.html_url}
            />
        ))}
    </div>
</WithSidebar>
