---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '~/components/layout/BaseHead.astro';
import BlogHeroFallback from '~/components/blog/BlogHeroFallback.astro';
import Footer from '~/components/layout/Footer.astro';
import FormattedDate from '~/components/shared/FormattedDate.astro';
import Header from '~/components/layout/Header.astro';
import { SITE_TITLE } from '~/consts';
import { extractFirstBodyImage } from '~/lib/blog/hero';
import { getAllSeries, getPostsBySeries } from '~/lib/blog/series';
import { estimateReadingTime, stripMarkdown, countWords } from '~/lib/blog/reading-stats';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const series = getAllSeries(posts);
	return series.map((s) => ({
		params: { series: s.slug },
		props: { seriesInfo: s, posts: getPostsBySeries(posts, s.slug) },
	}));
}

const { series } = Astro.params;
const { seriesInfo, posts } = Astro.props;

// Glob-import all co-located post images for body image fallback
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../../../posts/**/*.{png,jpg,jpeg,gif,webp,svg}',
	{ eager: true },
);

function resolveBodyImage(path: string): ImageMetadata | null {
	const name = path.replace(/^\.\//, '');
	const key = Object.keys(assetImages).find((k) => k.endsWith(`/${name}`));
	return key ? assetImages[key].default : null;
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${seriesInfo.title} (${seriesInfo.count}) | ${SITE_TITLE}`}
		          description={`Series: ${seriesInfo.title}`} />
	</head>
	<body class="neu-bg">
		<Header />
		<main class="max-w-4xl mx-auto px-4 py-10">
			<a href="/blog/series/" class="neu-link-btn gap-1 mb-6 text-[var(--text-link)] text-sm">
				← 所有系列
			</a>

			<h1 class="text-[var(--text-heading)] text-4xl md:text-5xl font-bold mb-2 anim-fade" style="--delay:0">
				📚 {seriesInfo.title}
			</h1>
			<p class="text-[var(--text-secondary)] mb-10 text-lg anim-fade" style="--delay:1">
				共 {seriesInfo.count} 篇文章
			</p>

			{posts.length > 0 ? (
				<ol class="flex flex-col gap-6 list-none p-0 m-0 anim-fade" style="--delay:2">
					{posts.map((post, i) => {
						const bodyImg = !post.data.heroImage ? extractFirstBodyImage(post.body) : null;
						const bodyImgMeta = bodyImg ? resolveBodyImage(bodyImg) : null;
						const readMin = estimateReadingTime(post.body ?? '');
						const wc = countWords(stripMarkdown(post.body ?? '')).total;
						return (
							<li>
								<a href={`/blog/${post.id}/`}
								   class="series-post-card group flex gap-4 rounded-2xl overflow-hidden neu-card neu-card-hover
								          transition-all duration-300 ease-out no-underline">
									<div class="shrink-0 w-8 h-8 mt-5 ml-5 flex items-center justify-center
									            rounded-full text-sm font-bold
									            text-[var(--text-muted)] bg-[var(--neu-bg)]
									            shadow-[inset_2px_2px_4px_var(--neu-shadow-dark-strong),inset_-2px_-2px_4px_var(--neu-shadow-light-strong)]">
										{i + 1}
									</div>
									<div class="flex-1 min-w-0 p-5 pl-0">
										<p class="text-[var(--text-muted)] text-xs mb-1">
											<FormattedDate date={post.data.pubDate} />
											<span class="mx-1">·</span>
											<span>{readMin} 分钟</span>
											<span class="mx-1">·</span>
											<span>{wc} 字</span>
										</p>
										<h2 class="text-[var(--text-heading)] text-base font-bold m-0 mb-1 line-clamp-2
										           group-hover:text-[var(--text-heading)] transition-colors">
											{post.data.title}
										</h2>
										{post.data.description && (
											<p class="text-[var(--text-secondary)] text-sm m-0 line-clamp-2">
												{post.data.description}
											</p>
										)}
									</div>
									{(post.data.heroImage || bodyImgMeta) && (
										<div class="shrink-0 w-24 h-24 overflow-hidden self-center mr-4 rounded-xl">
											{post.data.heroImage ? (
												<Image width={96} height={96} src={post.data.heroImage} alt=""
												       class="w-full h-full object-cover" />
											) : bodyImgMeta ? (
												<Image width={96} height={96} src={bodyImgMeta} alt=""
												       class="w-full h-full object-cover" />
											) : null}
										</div>
									)}
								</a>
							</li>
						);
					})}
				</ol>
			) : (
				<p class="text-[var(--text-muted)] text-center py-10">该系列下暂无文章</p>
			)}
		</main>
		<Footer />
	</body>
</html>

