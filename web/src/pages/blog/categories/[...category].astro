---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '~/components/layout/BaseHead.astro';
import BlogHeroFallback from '~/components/blog/BlogHeroFallback.astro';
import Footer from '~/components/layout/Footer.astro';
import FormattedDate from '~/components/shared/FormattedDate.astro';
import Header from '~/components/layout/Header.astro';
import { SITE_TITLE } from '~/consts';
import { extractFirstBodyImage } from '~/lib/blog/hero';
import { getAllCategories, getPostsByCategory } from '~/lib/blog/tags';
import { estimateReadingTime, stripMarkdown, countWords } from '~/lib/blog/reading-stats';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const categories = getAllCategories(posts);
	return categories.map(({ category }) => ({
		params: { category },
		props: { posts: getPostsByCategory(posts, category) },
	}));
}

const { category } = Astro.params;
const { posts } = Astro.props;

// Glob-import all co-located post images for body image fallback
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../../../posts/**/*.{png,jpg,jpeg,gif,webp,svg}',
	{ eager: true },
);

/** Resolve a body image path like ./foo.png to an ImageMetadata object */
function resolveBodyImage(path: string): ImageMetadata | null {
	const name = path.replace(/^\.\//, '');
	const key = Object.keys(assetImages).find((k) => k.endsWith(`/${name}`));
	return key ? assetImages[key].default : null;
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${category} (${posts.length}) | ${SITE_TITLE}`} description={`Posts in category "${category}"`} />
	</head>
	<body class="neu-bg">
		<Header />
		<main class="max-w-4xl mx-auto px-4 py-10">
			<h1 class="text-[var(--text-heading)] text-4xl md:text-5xl font-bold mb-2 anim-fade" style="--delay:0">
				📂 {category}
			</h1>
			<p class="text-[var(--text-secondary)] mb-10 text-lg anim-fade" style="--delay:1">
				共 {posts.length} 篇文章
			</p>

			{posts.length > 0 ? (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-7 anim-fade" style="--delay:2">
					{posts.map((post) => {
						const bodyImg = !post.data.heroImage ? extractFirstBodyImage(post.body) : null;
						const bodyImgMeta = bodyImg ? resolveBodyImage(bodyImg) : null;
						const readMin = estimateReadingTime(post.body ?? '');
						const wc = countWords(stripMarkdown(post.body ?? '')).total;
						return (
							<a href={`/blog/${post.id}/`}
							   class="blog-post-card neu-card-hover group block rounded-2xl overflow-hidden neu-card
							          transition-all duration-300 ease-out
							          no-underline">
								<div class="overflow-hidden h-44">
									{post.data.heroImage ? (
										<Image
											width={720} height={360}
											src={post.data.heroImage}
											alt=""
											class="card-cover-img"
										/>
									) : bodyImgMeta ? (
										<Image
											width={720} height={360}
											src={bodyImgMeta}
											alt=""
											class="card-cover-img"
										/>
									) : (
										<BlogHeroFallback title={post.data.title} class="transition-transform duration-700 ease-out group-hover:scale-105" />
									)}
								</div>
								<div class="p-5">
									<p class="text-[var(--text-muted)] text-xs mb-1">
										<FormattedDate date={post.data.pubDate} />
										<span class="mx-1">·</span>
										<span>{readMin} 分钟</span>
										<span class="mx-1">·</span>
										<span>{wc} 字</span>
									</p>
									<h3 class="text-[var(--text-heading)] text-base font-bold transition-colors m-0 line-clamp-2
									           group-hover:text-[var(--text-heading)]">
										{post.data.title}
									</h3>
								</div>
							</a>
						);
					})}
				</div>
			) : (
				<p class="text-[var(--text-muted)] text-center py-10">该分类下暂无文章</p>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
</style>
