---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ArticleSidebar from '../../components/ArticleSidebar.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import BlogPost from '../../layouts/BlogPost.astro';
import { extractFirstBodyImage } from '../../lib/blog/hero';
import { getRelatedPosts } from '../../lib/blog/related';
import { getSeriesForPost } from '../../lib/blog/series';
import { formatReadingTime, stripMarkdown, countWords } from '../../lib/blog/reading-stats';

// Glob-import all co-located post images for body image fallback
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../../posts/**/*.{png,jpg,jpeg,gif,webp,svg}',
	{ eager: true },
);

function resolveBodyImage(path: string): ImageMetadata | null {
	const name = path.replace(/^\.\//, '');
	const key = Object.keys(assetImages).find((k) => k.endsWith(`/${name}`));
	return key ? assetImages[key].default : null;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

// Resolve fallback hero image from body content
const bodyImgPath = !post.data.heroImage ? extractFirstBodyImage(post.body) : null;
const bodyImgMeta = bodyImgPath ? resolveBodyImage(bodyImgPath) : null;

// Calculate reading stats at build time
const readingTime = formatReadingTime(post.body ?? '');
const wordCount = countWords(stripMarkdown(post.body ?? '')).total;

// Resolve series data if post belongs to a series
const allPosts = await getCollection('blog');
const seriesData = getSeriesForPost(allPosts, post.id);

// Compute sidebar data: related posts + TOC headings
const relatedPosts = getRelatedPosts(allPosts, post);
const tocDepths = [...new Set(headings.map((h) => h.depth))].sort((a, b) => a - b);
const tocTopLevel = tocDepths[0] ?? 2;
const tocSubLevel = tocDepths[1] ?? tocTopLevel + 1;
const tocHeadings = headings.filter((h) => h.depth === tocTopLevel || h.depth === tocSubLevel);
const showToc = tocHeadings.length >= 2;
---

<BlogPost {...post.data} bodyHeroImage={bodyImgMeta} readingTime={readingTime} wordCount={wordCount} seriesData={seriesData} postId={post.id}>
	{showToc && (
		<ArticleSidebar slot="sidebar" headings={headings} />
	)}
	<Content />
	<RelatedPosts slot="related" posts={relatedPosts} />
</BlogPost>
