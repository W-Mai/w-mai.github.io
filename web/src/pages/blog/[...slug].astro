---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { extractFirstBodyImage } from '../../lib/blog-hero';

// Glob-import all post assets for body image fallback
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../../posts/assets/*.{png,jpg,jpeg,gif,webp,svg}',
	{ eager: true },
);

function resolveBodyImage(path: string): ImageMetadata | null {
	const name = path.replace(/^\.\/assets\//, '');
	const key = Object.keys(assetImages).find((k) => k.endsWith(`/${name}`));
	return key ? assetImages[key].default : null;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Resolve fallback hero image from body content
const bodyImgPath = !post.data.heroImage ? extractFirstBodyImage(post.body) : null;
const bodyImgMeta = bodyImgPath ? resolveBodyImage(bodyImgPath) : null;
---

<BlogPost {...post.data} bodyHeroImage={bodyImgMeta}>
	<Content />
</BlogPost>
