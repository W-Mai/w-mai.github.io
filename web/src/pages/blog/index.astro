---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BlogHeroFallback from '~/components/blog/BlogHeroFallback.astro';
import BlogSidebar from '~/components/blog/BlogSidebar.astro';
import FormattedDate from '~/components/shared/FormattedDate.astro';
import SeriesBadge from '~/components/blog/SeriesBadge.astro';
import TagChip from '~/components/blog/TagChip.astro';
import WithSidebar from '~/layouts/WithSidebar.astro';
import { extractFirstBodyImage } from '~/lib/blog/hero';
import { truncateTags } from '~/lib/blog/tags';
import { estimateReadingTime, stripMarkdown, countWords } from '~/lib/blog/reading-stats';
import { siteYear, siteMonth } from '~/lib/date-utils';

// Glob-import all co-located post images for body image fallback
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../../posts/**/*.{png,jpg,jpeg,gif,webp,svg}',
	{ eager: true },
);

/** Resolve a body image path like ./foo.png to an ImageMetadata object */
function resolveBodyImage(path: string): ImageMetadata | null {
	const name = path.replace(/^\.\//, '');
	const key = Object.keys(assetImages).find((k) => k.endsWith(`/${name}`));
	return key ? assetImages[key].default : null;
}

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<WithSidebar>
	<BlogSidebar slot="sidebar" />

	<h1 class="text-4xl md:text-5xl font-bold mb-2 anim-fade text-[var(--text-heading)]" style="--delay:0">🚀 怼点文章</h1>
	<p class="text-[var(--text-secondary)] mb-10 text-lg anim-fade" style="--delay:1">俺搁这儿写嘞东西</p>

	<!-- Active filter indicator bar -->
	<div id="filter-bar" class="hidden mb-6 anim-fade">
		<div class="neu-inset-subtle flex items-center gap-2 px-4 py-2.5 rounded-xl flex-wrap">
			<span class="text-[var(--text-muted)] text-xs flex-shrink-0">筛选：</span>
			<div id="filter-chips" class="flex flex-wrap gap-1.5 flex-1"></div>
			<button
				id="filter-clear"
				type="button"
				class="neu-tag-chip ml-auto cursor-pointer text-xs flex-shrink-0"
			>✕ 清除全部</button>
		</div>
	</div>

	<!-- Empty state when all posts are filtered out -->
	<div id="filter-empty" class="hidden text-center py-8 sm:py-16">
		<p class="text-[var(--text-muted)] text-lg">没有符合条件的文章</p>
	</div>

	<div id="post-grid" class="grid grid-cols-1 md:grid-cols-2 gap-7 anim-fade" style="--delay:2">
		{posts.map((post, idx) => {
			const isHero = idx === 0;
			const bodyImg = !post.data.heroImage ? extractFirstBodyImage(post.body) : null;
			const bodyImgMeta = bodyImg ? resolveBodyImage(bodyImg) : null;
			const readMin = estimateReadingTime(post.body ?? '');
			const wc = countWords(stripMarkdown(post.body ?? '')).total;
			const postHref = `/blog/${post.id}/`;
			const year = siteYear(post.data.pubDate);
			const month = siteMonth(post.data.pubDate);
			const desc = post.data.description ? stripMarkdown(post.data.description) : '';
			return (
				<a href={postHref} class:list={[
					'blog-post-card neu-card neu-card-hover group block rounded-2xl overflow-hidden transition-all duration-300 ease-out cursor-pointer no-underline',
					isHero && 'hero-card md:col-span-2',
				]}
				     data-category={post.data.category ?? ''}
				     data-tags={post.data.tags.join(',')}
				     data-year={year}
				     data-month={month}
				     data-series={post.data.series ?? ''}>
					{isHero ? (
						<div class="md:flex">
							<div class="overflow-hidden md:w-3/5 aspect-[2/1]">
								{post.data.heroImage ? (
									<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} class="card-cover-img" />
								) : bodyImgMeta ? (
									<Image width={720} height={360} src={bodyImgMeta} alt={post.data.title} class="card-cover-img" />
								) : (
									<BlogHeroFallback title={post.data.title} class="transition-transform duration-700 ease-out group-hover:scale-105" />
								)}
							</div>
							<div class="p-5 md:w-2/5 flex flex-col justify-center">
								<p class="text-xs text-[var(--text-muted)] mb-2">
									<FormattedDate date={post.data.pubDate} />
									<span class="mx-1">·</span>
									<span>{readMin} 分钟</span>
									<span class="mx-1">·</span>
									<span>{wc} 字</span>
								</p>
								<h3 class="text-xl md:text-2xl font-bold text-[var(--text-heading)] m-0 line-clamp-2
								           group-hover:text-[var(--text-heading)]">
									{post.data.title}
								</h3>
								{desc && (
									<p class="text-[var(--text-secondary)] text-sm mt-2 m-0 line-clamp-3">{desc}</p>
								)}
								{post.data.tags.length > 0 && (() => {
									const { visible, remaining } = truncateTags(post.data.tags);
									return (
										<div class="flex flex-wrap gap-1.5 mt-3" onclick="event.preventDefault()">
											{post.data.series && (
												<SeriesBadge series={post.data.series} seriesTitle={post.data.seriesTitle} filter />
											)}
											{visible.map((tag) => (
												<TagChip tag={tag} filter />
											))}
											{remaining > 0 && (
												<span class="text-[var(--text-muted)] text-xs self-center">+{remaining}</span>
											)}
										</div>
									);
								})()}
							</div>
						</div>
					) : (
						<>
					<div class="overflow-hidden h-44">
						{post.data.heroImage ? (
							<Image
								width={720} height={360}
								src={post.data.heroImage}
								alt={post.data.title}
								class="card-cover-img"
							/>
						) : bodyImgMeta ? (
							<Image
								width={720} height={360}
								src={bodyImgMeta}
								alt={post.data.title}
								class="card-cover-img"
							/>
						) : (
							<BlogHeroFallback title={post.data.title} class="transition-transform duration-700 ease-out group-hover:scale-105" />
						)}
					</div>
					<div class="p-5">
						<p class="text-xs text-[var(--text-muted)] mb-1">
							<FormattedDate date={post.data.pubDate} />
							<span class="mx-1">·</span>
							<span>{readMin} 分钟</span>
							<span class="mx-1">·</span>
							<span>{wc} 字</span>
						</p>
						<h3 class="text-base font-bold text-[var(--text-heading)] transition-colors m-0 line-clamp-2
						           group-hover:text-[var(--text-heading)]">
							{post.data.title}
						</h3>
						{post.data.tags.length > 0 && (() => {
							const { visible, remaining } = truncateTags(post.data.tags);
							return (
								<div class="flex flex-wrap gap-1.5 mt-2" onclick="event.preventDefault()">
									{post.data.series && (
										<SeriesBadge series={post.data.series} seriesTitle={post.data.seriesTitle} filter />
									)}
									{visible.map((tag) => (
										<TagChip tag={tag} filter />
									))}
									{remaining > 0 && (
										<span class="text-[var(--text-muted)] text-xs self-center">+{remaining}</span>
									)}
								</div>
							);
						})()}
					</div>
						</>
					)}
				</a>
			);
		})}
	</div>
</WithSidebar>

<style>
  .blog-post-card {
    transition: box-shadow 300ms ease, transform 300ms ease;
  }
  .blog-post-card.filtered-out { display: none; }
  .blog-post-card.filter-enter { animation: cardIn 200ms ease both; }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #filter-bar { overflow: hidden; }
  #filter-bar.bar-hidden { display: none; }
  .filter-chip-enter { animation: chipIn 150ms ease both; }
  @keyframes chipIn {
    from { opacity: 0; transform: scale(0.85); }
    to   { opacity: 1; transform: scale(1); }
  }

  #filter-empty.empty-hidden { display: none; }
</style>

<script>
  function initBlogFilter() {
    const grid = document.getElementById('post-grid');
    const filterBar = document.getElementById('filter-bar');
    const filterChips = document.getElementById('filter-chips');
    const filterClear = document.getElementById('filter-clear');
    const filterEmpty = document.getElementById('filter-empty');
    if (!grid || !filterBar || !filterChips || !filterClear || !filterEmpty) return;

    const filters: Record<string, string> = {};
    let isFirstRun = true;

    const labelMap: Record<string, (v: string) => string> = {
      category: (v) => `分类：${v}`,
      tag: (v) => `标签：${v}`,
      archive: (v) => { const [y, m] = v.split('-'); return `${y}年${m}月`; },
      series: (v) => `系列：${v}`,
    };

    function matchCard(card: HTMLElement): boolean {
      if (filters.category && card.dataset.category !== filters.category) return false;
      if (filters.tag && !(card.dataset.tags ?? '').split(',').includes(filters.tag)) return false;
      if (filters.archive) {
        const [y, m] = filters.archive.split('-');
        if (card.dataset.year !== y || card.dataset.month !== m) return false;
      }
      if (filters.series && card.dataset.series !== filters.series) return false;
      return true;
    }

    function applyFilter() {
      const cards = grid!.querySelectorAll<HTMLElement>('.blog-post-card');
      const hasFilter = Object.keys(filters).length > 0;
      let visibleCount = 0;

      for (const card of cards) {
        const show = !hasFilter || matchCard(card);
        const wasHidden = card.classList.contains('filtered-out');
        card.classList.toggle('filtered-out', !show);
        card.classList.remove('filter-enter');
        if (show) {
          visibleCount++;
          if (wasHidden && !isFirstRun) {
            void card.offsetWidth;
            card.classList.add('filter-enter');
          }
        }
      }

      // Filter bar
      filterBar!.classList.toggle('bar-hidden', !hasFilter);
      filterBar!.classList.remove('hidden');
      filterChips!.innerHTML = '';
      for (const [type, value] of Object.entries(filters)) {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'neu-tag-chip cursor-pointer text-xs filter-chip-enter';
        chip.textContent = `${labelMap[type]?.(value) ?? value} ✕`;
        chip.addEventListener('click', (e) => {
          e.stopPropagation();
          delete filters[type];
          applyFilter();
        });
        filterChips!.appendChild(chip);
      }

      // Empty state
      filterEmpty!.classList.toggle('empty-hidden', visibleCount > 0 || !hasFilter);

      // Sync button active states
      for (const btn of document.querySelectorAll<HTMLElement>('[data-filter-type]')) {
        btn.classList.toggle('active', filters[btn.dataset.filterType!] === btn.dataset.filterValue);
      }

      isFirstRun = false;
    }

    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-filter-type]');
      if (!btn) return;
      const type = btn.dataset.filterType!;
      const value = btn.dataset.filterValue!;
      if (filters[type] === value) delete filters[type];
      else filters[type] = value;
      applyFilter();
    });

    filterClear.addEventListener('click', (e) => {
      e.stopPropagation();
      for (const k of Object.keys(filters)) delete filters[k];
      applyFilter();
    });

    applyFilter();
  }

  document.addEventListener('astro:page-load', initBlogFilter);
</script>
