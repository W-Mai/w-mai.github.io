---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-4xl mx-auto px-4 py-10">
			<h1 class="text-4xl md:text-5xl font-bold mb-2">🚀 怼点文章</h1>
			<p class="text-slate-500 mb-10 text-lg">俺搁这儿写嘞东西</p>

			{featured && (
				<a href={`/blog/${featured.id}/`}
				   class="group block rounded-3xl overflow-hidden bg-white shadow-md
				          hover:shadow-xl hover:-translate-y-1 transition-all duration-300 ease-out
				          no-underline mb-8">
					{featured.data.heroImage && (
						<div class="overflow-hidden h-64 md:h-80">
							<Image
								width={960} height={480}
								src={featured.data.heroImage}
								alt=""
								class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 rounded-none"
							/>
						</div>
					)}
					<div class="p-6">
						<p class="text-xs text-slate-400 mb-2">
							<FormattedDate date={featured.data.pubDate} />
						</p>
						<h2 class="text-2xl md:text-3xl font-bold text-slate-800 group-hover:text-slate-900 transition-colors m-0">
							{featured.data.title}
						</h2>
						{featured.data.description && (
							<p class="mt-2 text-slate-500 line-clamp-2">{featured.data.description}</p>
						)}
					</div>
				</a>
			)}

			{rest.length > 0 && (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					{rest.map((post) => (
						<a href={`/blog/${post.id}/`}
						   class="group block rounded-2xl overflow-hidden bg-white shadow-sm
						          hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 ease-out
						          no-underline">
							{post.data.heroImage && (
								<div class="overflow-hidden h-44">
									<Image
										width={720} height={360}
										src={post.data.heroImage}
										alt=""
										class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 rounded-none"
									/>
								</div>
							)}
							<div class="p-4">
								<p class="text-xs text-slate-400 mb-1">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3 class="text-base font-bold text-slate-800 group-hover:text-slate-900 transition-colors m-0 line-clamp-2">
									{post.data.title}
								</h3>
							</div>
						</a>
					))}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
