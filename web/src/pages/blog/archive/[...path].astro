---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BlogHeroFallback from '~/components/blog/BlogHeroFallback.astro';
import BlogSidebar from '~/components/blog/BlogSidebar.astro';
import FormattedDate from '~/components/shared/FormattedDate.astro';
import SeriesBadge from '~/components/blog/SeriesBadge.astro';
import TagChip from '~/components/blog/TagChip.astro';
import WithSidebar from '~/layouts/WithSidebar.astro';
import { getAllYearMonthPairs, getPostsByYearMonth } from '~/lib/blog/archive';
import { extractFirstBodyImage } from '~/lib/blog/hero';
import { truncateTags } from '~/lib/blog/tags';
import { estimateReadingTime, stripMarkdown, countWords } from '~/lib/blog/reading-stats';

// Glob-import all co-located post images for body image fallback
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
	'../../../../posts/**/*.{png,jpg,jpeg,gif,webp,svg}',
	{ eager: true },
);

function resolveBodyImage(path: string): ImageMetadata | null {
	const name = path.replace(/^\.\//, '');
	const key = Object.keys(assetImages).find((k) => k.endsWith(`/${name}`));
	return key ? assetImages[key].default : null;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const pairs = getAllYearMonthPairs(posts);
	return pairs.map(({ year, month }) => ({
		params: { path: `${year}/${month}` },
		props: {
			year,
			month,
			posts: getPostsByYearMonth(posts, year, month),
		},
	}));
}

const { year, month, posts } = Astro.props;
const monthLabel = `${year} 年 ${month} 月`;
---

<WithSidebar>
	<BlogSidebar slot="sidebar" />

	<h1 class="text-[var(--text-heading)] text-4xl md:text-5xl font-bold mb-2 anim-fade" style="--delay:0">
		📅 {monthLabel}
	</h1>
	<p class="text-[var(--text-secondary)] mb-10 text-lg anim-fade" style="--delay:1">
		共 {posts.length} 篇文章
	</p>

	{posts.length > 0 ? (
		<div class="grid grid-cols-1 md:grid-cols-2 gap-7 anim-fade" style="--delay:2">
			{posts.map((post) => {
				const bodyImg = !post.data.heroImage ? extractFirstBodyImage(post.body) : null;
				const bodyImgMeta = bodyImg ? resolveBodyImage(bodyImg) : null;
				const readMin = estimateReadingTime(post.body ?? '');
				const wc = countWords(stripMarkdown(post.body ?? '')).total;
				const postHref = `/blog/${post.id}/`;
				return (
					<div class="blog-post-card neu-card neu-card-hover group block rounded-2xl overflow-hidden
					            transition-all duration-300 ease-out cursor-pointer"
					     onclick={`window.location.href='${postHref}'`}
					     role="link" tabindex="0"
					     onkeydown={`if(event.key==='Enter')window.location.href='${postHref}'`}>
						<div class="overflow-hidden h-44">
							{post.data.heroImage ? (
								<Image
									width={720} height={360}
									src={post.data.heroImage}
									alt={post.data.title}
									class="card-cover-img"
								/>
							) : bodyImgMeta ? (
								<Image
									width={720} height={360}
									src={bodyImgMeta}
									alt={post.data.title}
									class="card-cover-img"
								/>
							) : (
								<BlogHeroFallback title={post.data.title} class="transition-transform duration-700 ease-out group-hover:scale-105" />
							)}
						</div>
						<div class="p-5">
							<p class="text-[var(--text-muted)] text-xs mb-1">
								<FormattedDate date={post.data.pubDate} />
								<span class="mx-1">·</span>
								<span>{readMin} 分钟</span>
								<span class="mx-1">·</span>
								<span>{wc} 字</span>
							</p>
							<h3 class="text-[var(--text-heading)] text-base font-bold m-0 line-clamp-2
							           transition-colors group-hover:text-[var(--text-heading)]">
								{post.data.title}
							</h3>
							{post.data.tags.length > 0 && (() => {
								const { visible, remaining } = truncateTags(post.data.tags);
								return (
									<div class="flex flex-wrap gap-1.5 mt-2" onclick="event.stopPropagation()">
										{post.data.series && (
											<SeriesBadge series={post.data.series} seriesTitle={post.data.seriesTitle} />
										)}
										{visible.map((tag) => (
											<TagChip tag={tag} />
										))}
										{remaining > 0 && (
											<span class="text-[var(--text-muted)] text-xs self-center">+{remaining}</span>
										)}
									</div>
								);
							})()}
						</div>
					</div>
				);
			})}
		</div>
	) : (
		<p class="text-[var(--text-muted)] text-center py-10">该月份暂无文章</p>
	)}
</WithSidebar>

<style>
</style>
