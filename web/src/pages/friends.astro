---
import WithSidebar from '~/layouts/WithSidebar.astro'
import ProfileSidebar from '../components/ProfileSidebar.astro'
import FriendCard from '../components/FriendCard.astro'
import Giscus from '../components/Giscus.astro'
import { fetchGitHubProfile } from '../lib/github'
import { FRIENDS } from '../data/friends'

const profile = await fetchGitHubProfile()
---

<WithSidebar>
    <Fragment slot="sidebar">
        <ProfileSidebar profile={profile} showBio />
    </Fragment>

    <h1 class="page-title anim-fade" style="--delay:0">🤝 怼点友链</h1>
    <p class="page-subtitle anim-fade" style="--delay:1">都是俺嘞好伙计，点进去瞅瞅中不中</p>

    <section class="board-container neu-board anim-fade" style="--delay:2">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {FRIENDS.map((friend) => (
                <FriendCard
                    name={friend.name}
                    url={friend.url}
                    avatar={friend.avatar}
                    description={friend.description}
                    tags={friend.tags}
                />
            ))}
        </div>
    </section>

    <section class="mt-24 anim-fade" style="--delay:3">
        <h2 class="text-2xl font-bold mb-2 text-[var(--text-heading)]">📮 交换友链</h2>
        <p class="text-sm text-[var(--text-secondary)] mb-6">想和俺交换友链？在下面留言，附上你的博客名称、链接和一句话介绍就中～</p>
        <Giscus />
    </section>
</WithSidebar>
